From 6f2106fdabea7e75f08fd90d48666365de2e6533 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sun, 19 Nov 2017 12:26:11 +0000
Subject: [PATCH] g2clib: avoid int overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=4329. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@40760 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/degrib/g2clib/g2_unpack4.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/gdal/frmts/grib/degrib/g2clib/g2_unpack4.c b/gdal/frmts/grib/degrib/g2clib/g2_unpack4.c
index 1823d6869151..4c636936b42d 100644
--- a/gdal/frmts/grib/degrib/g2clib/g2_unpack4.c
+++ b/gdal/frmts/grib/degrib/g2clib/g2_unpack4.c
@@ -1,5 +1,6 @@
 #include <stdio.h>
 #include <stdlib.h>
+#include <limits.h>
 #include "grib2.h"
 
 
@@ -139,6 +140,18 @@ g2int g2_unpack4(unsigned char *cgrib,g2int cgrib_length,g2int *iofst,g2int *ipd
         //   Unpack the rest of the Product Definition Template
         j=0;
         for (i=*mappdslen;i<newlen;i++) {
+          if( mappds->ext[j] < INT_MAX / 8 || mappds->ext[j] > INT_MAX / 8 )
+          {
+              ierr=6;
+              *numcoord=0;
+              *mappdslen=0;
+              *coordlist=0;    // NULL
+              *ipdstmpl=0;
+              free(mappds->ext);
+              free(mappds);
+              free(lipdstmpl);
+              return(ierr);
+          }
           nbits=abs(mappds->ext[j])*8;
           if ( mappds->ext[j] >= 0 ) {
             gbit2(cgrib,cgrib_length,lipdstmpl+i,*iofst,nbits);
