-                            && std::is_integral<CodepointT>::value && sizeof(CodepointT) == sizeof(uint32_t),
+    typename std::enable_if<is_char16<CharT>::value && is_char32<CodepointT>::value,
                             convert_result<CharT>>::type 
     to_codepoint(const CharT* first, const CharT* last, 
                  CodepointT& ch, 
@@ -557,8 +589,7 @@ namespace jsoncons { namespace unicode_traits {
     }
 
     template <class CharT,class CodepointT>
-    typename std::enable_if<std::is_integral<CharT>::value && sizeof(CharT) == sizeof(uint32_t)
-                            && std::is_integral<CodepointT>::value && sizeof(CodepointT) == sizeof(uint32_t),
+    typename std::enable_if<is_char32<CharT>::value && is_char32<CodepointT>::value,
                             convert_result<CharT>>::type 
     to_codepoint(const CharT* first, const CharT* last, 
                  CodepointT& ch, 
@@ -592,7 +623,7 @@ namespace jsoncons { namespace unicode_traits {
