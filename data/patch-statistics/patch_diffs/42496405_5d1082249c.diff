+    typename std::enable_if<is_char8<CharT>::value && is_char32<CodepointT>::value,
                             convert_result<CharT>>::type 
     to_codepoint(const CharT* first, const CharT* last, 
                  CodepointT& ch, 
@@ -504,8 +537,7 @@ namespace jsoncons { namespace unicode_traits {
     }
 
