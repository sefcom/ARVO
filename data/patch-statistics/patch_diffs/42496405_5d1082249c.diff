From 369fc95fc281309953a739c3feb1fedbb93de0c3 Mon Sep 17 00:00:00 2001
From: danielaparker <danielaparker@yahoo.com>
Date: Tue, 27 Apr 2021 21:21:53 -0400
Subject: [PATCH] is_char8,is_char16,is_char32

---
 include/jsoncons/unicode_traits.hpp | 102 ++++++++++++++++++----------
 1 file changed, 65 insertions(+), 37 deletions(-)

diff --git a/include/jsoncons/unicode_traits.hpp b/include/jsoncons/unicode_traits.hpp
index e97de058cc..5e907c318d 100644
--- a/include/jsoncons/unicode_traits.hpp
+++ b/include/jsoncons/unicode_traits.hpp
@@ -26,6 +26,42 @@
 
 namespace jsoncons { namespace unicode_traits {
 
+    // is_char8
+    template <typename CharT, typename Enable=void>
+    struct is_char8 : std::false_type {};
+
+    template <typename CharT>
+    struct is_char8<CharT, typename std::enable_if<std::is_integral<CharT>::value &&
+                                                   !std::is_same<CharT,bool>::value &&
+                                                   sizeof(uint8_t) == sizeof(CharT)>::type> : std::true_type {};
+
+    // is_char16
+    template <typename CharT, typename Enable=void>
+    struct is_char16 : std::false_type {};
+
+    template <typename CharT>
+    struct is_char16<CharT, typename std::enable_if<std::is_integral<CharT>::value &&
+                                                   !std::is_same<CharT,bool>::value &&
+                                                   (std::is_same<CharT,char16_t>::value || sizeof(uint16_t) == sizeof(CharT))>::type> : std::true_type {};
+
+    // is_char32
+    template <typename CharT, typename Enable=void>
+    struct is_char32 : std::false_type {};
+
+    template <typename CharT>
+    struct is_char32<CharT, typename std::enable_if<std::is_integral<CharT>::value &&
+                                                   !std::is_same<CharT,bool>::value &&
+                                                   (std::is_same<CharT,char32_t>::value || (!std::is_same<CharT,char16_t>::value && sizeof(uint32_t) == sizeof(CharT)))>::type> : std::true_type {};
+
+    // is_character
+    template <typename CharT, typename Enable=void>
+    struct is_character : std::false_type {};
+
+    template <typename CharT>
+    struct is_character<CharT, typename std::enable_if<is_char8<CharT>::value || 
+                                                       is_char16<CharT>::value ||
+                                                       is_char32<CharT>::value>::type> : std::true_type {};
+
     enum class encoding_kind {undetected,utf8,utf16le,utf16be,utf32le,utf32be};
 
     inline
@@ -329,14 +365,12 @@ namespace jsoncons { namespace unicode_traits {
 
     // utf8
 
-    template <class Iterator>
-    typename std::enable_if<std::is_integral<typename std::iterator_traits<Iterator>::value_type>::value 
-                                  && sizeof(typename std::iterator_traits<Iterator>::value_type) == sizeof(uint8_t), 
-                                  conv_errc >::type
-    is_legal_utf8(Iterator first, std::size_t length) 
+    template <class CharT>
+    typename std::enable_if<is_char8<CharT>::value, conv_errc>::type
+    is_legal_utf8(const CharT* first, std::size_t length) 
     {
         uint8_t a;
-        Iterator srcptr = first+length;
+        const CharT* srcptr = first+length;
         switch (length) {
         default:
             return conv_errc::over_long_utf8_sequence;
@@ -405,7 +439,7 @@ namespace jsoncons { namespace unicode_traits {
     template<class Container, class CharT>
     struct is_compatible_back_insertable<Container,CharT,
         typename std::enable_if<jsoncons::detail::is_back_insertable<Container>::value
-                                && std::is_integral<typename Container::value_type>::value 
+                                && is_character<typename Container::value_type>::value 
                                 && is_same_size<typename Container::value_type,CharT>::value>::type
     > : std::true_type {};
 
@@ -421,8 +455,7 @@ namespace jsoncons { namespace unicode_traits {
     // to_codepoint
 
