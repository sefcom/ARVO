</table><div class='diffstat-summary'>1 files changed, 2 insertions, 0 deletions</div><table summary='diff' class='diff'><tr><td><div class='head'>diff --git a/src/p2p/p2p.c b/src/p2p/p2p.c<br/>index 74b7b52ae..5cbfc217f 100644<br/>--- a/<a href='/cgit/hostap/tree/src/p2p/p2p.c?id=25df656a8a5c95bd3989d1dba6ce96dc699747d8'>src/p2p/p2p.c</a><br/>+++ b/<a href='/cgit/hostap/tree/src/p2p/p2p.c?id=947272febe24a8f0ea828b5b2f35f13c3821901e'>src/p2p/p2p.c</a></div><div class='hunk'>@@ -453,6 +453,8 @@ static void p2p_copy_client_info(struct p2p_device *dev,</div><div class='ctx'> 	dev-&gt;info.config_methods = cli-&gt;config_methods;</div><div class='ctx'> 	os_memcpy(dev-&gt;info.pri_dev_type, cli-&gt;pri_dev_type, 8);</div><div class='ctx'> 	dev-&gt;info.wps_sec_dev_type_list_len = 8 * cli-&gt;num_sec_dev_types;</div><div class='add'>+	if (dev-&gt;info.wps_sec_dev_type_list_len &gt; WPS_SEC_DEV_TYPE_MAX_LEN)</div><div class='add'>+		dev-&gt;info.wps_sec_dev_type_list_len = WPS_SEC_DEV_TYPE_MAX_LEN;</div><div class='ctx'> 	os_memcpy(dev-&gt;info.wps_sec_dev_type_list, cli-&gt;sec_dev_types,</div><div class='ctx'> 		  dev-&gt;info.wps_sec_dev_type_list_len);</div><div class='ctx'> }</div></td></tr></table></div> <!-- class=content -->
