From 9730b5b9dac48c068933986583ba72f405a893f0 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sun, 24 Dec 2017 11:43:57 +0000
Subject: [PATCH] Degrib: avoid int overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=4752. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41128 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/degrib/degrib/clock.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/frmts/grib/degrib/degrib/clock.c b/gdal/frmts/grib/degrib/degrib/clock.c
index b193b74b0001..291e5824b8f8 100644
--- a/gdal/frmts/grib/degrib/degrib/clock.c
+++ b/gdal/frmts/grib/degrib/degrib/clock.c
@@ -1755,6 +1755,8 @@ void Clock_ScanDate (double *l_clock, sInt4 year, int mon, int day)
 
    if ((mon < 1) || (mon > 12) || (day < 0) || (day > 31))
       return;
+   if( year < -10000 || year > 10000 )
+       return;
    totDay = Clock_NumDay (mon, day, year, 0);
    if (day > totDay)
       return;
