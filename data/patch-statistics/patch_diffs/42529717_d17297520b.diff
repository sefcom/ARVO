From 17eea00d192455dd4248b206caacaf311356cc20 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Mon, 30 Oct 2023 17:38:33 +0100
Subject: [PATCH] decode_r11: more wrong obj->size checks

Fixes more preR13 fuzzing tests
$ examples/llvmfuzz_standalone ../tz/*/clusterfuzz-testcase-*

but breaks ./rw r11/ACEB10
---
 src/decode.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/src/decode.c b/src/decode.c
index a843214f4e..0d6de1f774 100644
--- a/src/decode.c
+++ b/src/decode.c
@@ -6917,7 +6917,8 @@ decode_preR13_entities (BITCODE_RL start, BITCODE_RL end,
               {
                 PRE (R_11) // no crc16
                 {
-                  if (obj->size > dat->size - oldpos)
+                  if (obj->size > dat->size - oldpos ||
+                      obj->size + obj->address > dat->byte)
                     {
                       LOG_ERROR ("Invalid obj->size " FORMAT_RL " changed to %" PRIuSIZE,
                                  obj->size, dat->byte - oldpos);
@@ -6953,7 +6954,8 @@ decode_preR13_entities (BITCODE_RL start, BITCODE_RL end,
                 }
                 LATER_VERSIONS
                 {
-                  if (obj->size > dat->size - oldpos)
+                  if (obj->size > dat->size - oldpos ||
+                      obj->size + obj->address > dat->byte)
                     {
                       LOG_ERROR ("Invalid obj->size " FORMAT_RL " changed to %" PRIuSIZE,
                                  obj->size, dat->byte + 2 - oldpos);
