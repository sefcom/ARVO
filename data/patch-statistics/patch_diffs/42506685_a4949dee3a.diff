From d8f56d14a35371757545c5744de6725f65caf092 Mon Sep 17 00:00:00 2001
From: Ineiev <ineiev@gnu.org>
Date: Sat, 15 Jan 2022 13:19:46 +0000
Subject: [PATCH] sr, ru: use t from Serbian in Russian

---
 phsource/ph_russian          | 15 +++++++--------
 phsource/ph_serbian          | 12 ++----------
 phsource/phonemes            | 14 ++++++++++++++
 tests/language-phonemes.test |  6 +++---
 4 files changed, 26 insertions(+), 21 deletions(-)

diff --git a/phsource/ph_russian b/phsource/ph_russian
index 42b73d5fe4..2eac8b74c2 100644
--- a/phsource/ph_russian
+++ b/phsource/ph_russian
@@ -146,21 +146,20 @@ phoneme tS;
 endphoneme
 
 
-// Palatalized versions of consonants
-
-
 phoneme t
-  import_phoneme pl/t
+  import_phoneme ru-base/t
 endphoneme
 
 
-phoneme t;
-  import_phoneme pl/t;
+phoneme d
+  import_phoneme pl/d
 endphoneme
 
 
-phoneme d
-  import_phoneme pl/d
+// Palatalized versions of consonants
+
+phoneme t;
+  import_phoneme pl/t;
 endphoneme
 
 
diff --git a/phsource/ph_serbian b/phsource/ph_serbian
index 0c29cd157e..b2c8db7f3d 100644
--- a/phsource/ph_serbian
+++ b/phsource/ph_serbian
@@ -30,16 +30,8 @@ endphoneme
 
 
 
-phoneme t        // dental variant of /t/
-  vls dnt stp
-  lengthmod 2
-  voicingswitch d
-  Vowelin f1=0  f2=1600 -300 300  f3=-100 80
-  Vowelout f1=0 f2=1600 -300 250  f3=-100 80  rms=20
-  IF nextPh(isPause2) THEN
-    WAV(ustop/t_sr, 35)
-  ENDIF
-  WAV(ustop/t_sr, 50)
+phoneme t
+  import_phoneme ru-base/t
 endphoneme
 
 
diff --git a/phsource/phonemes b/phsource/phonemes
index fe5fafe597..4cb5ff52da 100644
--- a/phsource/phonemes
+++ b/phsource/phonemes
@@ -1793,6 +1793,20 @@ include ph_quechua
 
 phonemetable quc base1
 
+phonemetable ru-base base1
+
+phoneme t        // dental variant of /t/
+  vls dnt stp
+  lengthmod 2
+  voicingswitch d
+  Vowelin f1=0  f2=1600 -300 300  f3=-100 80
+  Vowelout f1=0 f2=1600 -300 250  f3=-100 80  rms=20
+  IF nextPh(isPause2) THEN
+    WAV(ustop/t_sr, 35)
+  ENDIF
+  WAV(ustop/t_sr, 50)
+endphoneme
+
 phonemetable ru base1
 include ph_russian
 
