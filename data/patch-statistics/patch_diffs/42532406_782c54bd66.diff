From 9efb5977c5b7a45e52acd83533076c18bc8f294a Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 30 Jan 2024 14:07:04 +0100
Subject: [PATCH] fix buffer overflow on mp3 bitrate index

ossfuzz issue 66196
---
 src/media_tools/av_parsers.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/media_tools/av_parsers.c b/src/media_tools/av_parsers.c
index 9923a46735..f147c05468 100644
--- a/src/media_tools/av_parsers.c
+++ b/src/media_tools/av_parsers.c
@@ -4520,6 +4520,10 @@ u32 gf_mp3_bit_rate(u32 hdr)
 		GF_LOG(GF_LOG_ERROR, GF_LOG_CODING, ("[MPEG-1/2 Audio] layer index not valid\n"));
 		return 0;
 	}
+	if (bitRateIndex>14) {
+		GF_LOG(GF_LOG_ERROR, GF_LOG_CODING, ("[MPEG-1/2 Audio] Bitrate index not valid\n"));
+		return 0;
+	}
 	return bitrate_table[lidx][bitRateIndex];
 }
 
