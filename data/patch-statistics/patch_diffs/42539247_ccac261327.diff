From 9afd63a740d2150bd13e7ba26eb02171e5826d6d Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Tue, 17 Apr 2018 14:58:17 +0200
Subject: [PATCH] EXIFPrintData(): fix regression introduced yesterday per
 ec7b85e6bb8f9737693a31f0bf7166e31e10992e. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=7743. Credit to OSS
 Fuzz

---
 gdal/gcore/gdalexif.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gdal/gcore/gdalexif.cpp b/gdal/gcore/gdalexif.cpp
index 3bfa6c05f38e..2af201779fca 100644
--- a/gdal/gcore/gdalexif.cpp
+++ b/gdal/gcore/gdalexif.cpp
@@ -327,7 +327,7 @@ static void EXIFPrintData(char* pszData, GUInt16 type,
   case TIFF_SLONG: {
     const GInt32 *lp = reinterpret_cast<const GInt32 *>(data);
     for(;count>0;count--) {
-      snprintf(szTemp, sizeof(szTemp), "%s%d", sep, *lp++);
+      snprintf(szTemp, sizeof(szTemp), "%s%d", sep, *lp);
       lp++;
       sep = " ";
       if (strlen(szTemp) + pszDataEnd - pszData >= MAXSTRINGLENGTH)
