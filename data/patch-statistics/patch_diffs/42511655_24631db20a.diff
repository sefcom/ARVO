Subject: oss-fuzz 47513: Set error code for unknown object type

when converting pdfi object to PS objects
---
 psi/zpdfops.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/psi/zpdfops.c b/psi/zpdfops.c
index e9088d255..20e3b1212 100644
--- a/psi/zpdfops.c
+++ b/psi/zpdfops.c
@@ -810,7 +810,7 @@ static int PDFobj_to_PSobj(i_ctx_t *i_ctx_p, pdfctx_t *pdfctx, pdf_obj *PDFobj,
             code = PDFarray_to_PSarray(i_ctx_p, pdfctx, (pdf_array *)PDFobj, PSobj);
             break;
         default:
-            gs_note_error(gs_error_typecheck);
+            code = gs_note_error(gs_error_typecheck);
             break;
     }
 
