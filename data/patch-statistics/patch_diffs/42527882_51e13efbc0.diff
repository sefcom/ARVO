+static void printOperand(MCInst *MI, int OpNum, SStream *O)
+{
+	add_cs_detail(MI, XTENSA_OP_GROUP_OPERAND, OpNum);
+	const MCOperand *MC = MCInst_getOperand(MI, (OpNum));
+	if (MCOperand_isReg(MC)) {
