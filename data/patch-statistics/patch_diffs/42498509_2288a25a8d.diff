From 1785a2fe97eda2de3d065147a0a4e5b509f0e3c0 Mon Sep 17 00:00:00 2001
From: Hajime Fujita <crisp.fujita@nifty.com>
Date: Mon, 5 Jul 2021 17:20:13 +0000
Subject: [PATCH] qpack: do not derefence a pointer before range check

This fixes a ClusterFuzz issue 35675.
---
 lib/http3/qpack.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/lib/http3/qpack.c b/lib/http3/qpack.c
index a1066cdd20..2664ab6444 100644
--- a/lib/http3/qpack.c
+++ b/lib/http3/qpack.c
@@ -626,8 +626,8 @@ static h2o_iovec_t decode_header_value_literal(h2o_mem_pool_t *pool, unsigned *s
                                                const uint8_t *src_end, const char **err_desc)
 {
     h2o_iovec_t buf;
-    int is_huff = (**src & 0x80) != 0;
     int64_t len;
+    const uint8_t *src_head = *src;
 
     if (decode_int(&len, src, src_end, 7) != 0 || len > MAX_HEADER_VALUE_LENGTH) {
         *err_desc = h2o_qpack_err_header_value_too_long;
@@ -636,6 +636,8 @@ static h2o_iovec_t decode_header_value_literal(h2o_mem_pool_t *pool, unsigned *s
     if (src_end - *src < len)
         goto Fail;
 
+    int is_huff = (*src_head & 0x80) != 0;
+
     buf.base = h2o_mem_alloc_pool(pool, char, is_huff ? len * 2 + 1 : len + 1);
     if ((buf.len = decode_value(buf.base, soft_errors, is_huff, *src, len, err_desc)) == SIZE_MAX)
         goto Fail;
