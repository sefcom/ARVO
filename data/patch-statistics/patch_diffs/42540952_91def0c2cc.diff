From 361363f724e59bc2da002cd9cdec05578e1c163b Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Sun, 8 Jul 2018 10:16:23 +0200
Subject: [PATCH] BitStuffer2::Decode(): prevent index out of bound access.
 Fixes https://oss-fuzz.com/v2/testcase-detail/5696299335680000. Credit to OSS
 Fuzz

---
 gdal/third_party/LercLib/BitStuffer2.cpp | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/gdal/third_party/LercLib/BitStuffer2.cpp b/gdal/third_party/LercLib/BitStuffer2.cpp
index aad526582340..9f4e898cc9a0 100644
--- a/gdal/third_party/LercLib/BitStuffer2.cpp
+++ b/gdal/third_party/LercLib/BitStuffer2.cpp
@@ -235,7 +235,13 @@ bool BitStuffer2::Decode(const Byte** ppByte, size_t& nBytesRemaining, vector<un
     // replace indexes by values
     m_tmpLutVec.insert(m_tmpLutVec.begin(), 0);    // put back in the 0
     for (unsigned int i = 0; i < numElements; i++)
+    {
+      if( dataVec[i] >= m_tmpLutVec.size() )
+      {
+        return false;
+      }
       dataVec[i] = m_tmpLutVec[dataVec[i]];
+    }
   }
 
   return true;
