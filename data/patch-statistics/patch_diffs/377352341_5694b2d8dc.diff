From ab0565a6a9359c32961b84d96c99a09a67732418 Mon Sep 17 00:00:00 2001
From: Dirk Farin <dirk.farin@gmail.com>
Date: Tue, 5 Nov 2024 21:13:02 +0100
Subject: [PATCH] convert to signed int in a type-safe manner

---
 libheif/image-items/overlay.cc | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/libheif/image-items/overlay.cc b/libheif/image-items/overlay.cc
index df91f83e81..eec4bd0f31 100644
--- a/libheif/image-items/overlay.cc
+++ b/libheif/image-items/overlay.cc
@@ -47,13 +47,12 @@ static int32_t readvec_signed(const std::vector<uint8_t>& data, int& ptr, int le
   }
 
   bool negative = (val & high_bit) != 0;
-  val &= ~high_bit;
 
   if (negative) {
-    return -(high_bit - val);
+    return -static_cast<int32_t>((~val) & 0x7fffffff) -1;
   }
   else {
-    return val;
+    return static_cast<int32_t>(val);
   }
 
   return val;
