From e8a640d7fdccc41ab65c7d22896632bdb7ebf283 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Fri, 30 Sep 2022 16:45:16 +0200
Subject: [PATCH] shapefuzzer: avoid too long processing time

should help for https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=51551
and on other broken files
---
 fuzzers/shapefuzzer.c | 20 ++++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/fuzzers/shapefuzzer.c b/fuzzers/shapefuzzer.c
index d1481910ab..7a0e3c51f1 100644
--- a/fuzzers/shapefuzzer.c
+++ b/fuzzers/shapefuzzer.c
@@ -1,6 +1,8 @@
 #include "mapserver.h"
 #include "mapshape.h"
 
+#include "cpl_vsi.h"
+
 #include <stdlib.h>
 #include <string.h>
 #include <stdbool.h>
@@ -68,12 +70,26 @@ LLVMFuzzerTestOneInput(GByte *data, size_t size)
   VSILFILE *dbf = SegmentFile("/vsimem/foo.dbf", &data, &size);
 
   shapefileObj file;
+  errorObj *ms_error = msGetErrorObj();
   if (msShapefileOpenVirtualFile(&file, "/vsimem/foo.shp", shp, shx, dbf, false) == 0) {
+    if (file.numshapes > 100 * 1000 )
+    {
+        VSIStatBufL sStat;
+        if( VSIStatL("/vsimem/foo.shx", &sStat) == 0 &&
+            sStat.st_size >= 100 &&
+            file.numshapes > (int)(sStat.st_size - 100) / 8 )
+        {
+            file.numshapes = (int)(sStat.st_size - 100) / 8;
+        }
+    }
     for (int i = 0; i < file.numshapes; ++i) {
       shapeObj shape;
       msInitShape(&shape);
       msSHPReadShape(file.hSHP, i, &shape);
       msFreeShape(&shape);
+      // Give up as soon an error is triggered to avoid too long processing time.
+      if( ms_error->code != MS_NOERR )
+          break;
     }
 
     msShapefileClose(&file);
@@ -81,5 +97,9 @@ LLVMFuzzerTestOneInput(GByte *data, size_t size)
 
   msResetErrorList();
 
+  VSIUnlink("/vsimem/foo.shp");
+  VSIUnlink("/vsimem/foo.shx");
+  VSIUnlink("/vsimem/foo.dbf");
+
   return EXIT_SUCCESS;
 }
