     writeRead (pi, ph, pf, filename.c_str(), lorder, W, H,
-               xSize, ySize, dx, dy, comp, MIPMAP_LEVELS, rmode);
+               xSize, ySize, dx, dy, comp, RIPMAP_LEVELS, rmode , false);
     writeRead (pi, ph, pf, filename.c_str(), lorder, W, H,
