From 067d295c3527dad9f39da9d973235fac3dba1685 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Mon, 19 Mar 2018 22:46:43 +0000
Subject: [PATCH] Geoconcept writer: avoid off-by-one write heap buffer
 overflow. Fixes https://github.com/google/oss-fuzz/issues/1255. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41868 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/ogr/ogrsf_frmts/geoconcept/geoconcept.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gdal/ogr/ogrsf_frmts/geoconcept/geoconcept.c b/gdal/ogr/ogrsf_frmts/geoconcept/geoconcept.c
index 26455342d798..426e921ce4b7 100644
--- a/gdal/ogr/ogrsf_frmts/geoconcept/geoconcept.c
+++ b/gdal/ogr/ogrsf_frmts/geoconcept/geoconcept.c
@@ -4715,7 +4715,7 @@ static char GCIOAPI_CALL1(*) _escapeString_GCIO (
     res= CPLStrdup(theString);
     return res;
   }
-  if( (res= (char *)CPLMalloc(l*2)) )
+  if( (res= (char *)CPLMalloc(l*2+1)) )
   {
     for (i= 0, o= 0; i<l; i++, o++)
     {
