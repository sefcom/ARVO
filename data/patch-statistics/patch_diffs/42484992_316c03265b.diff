From f96a1159644dd12c824651f610c2f1402aec8af1 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Tue, 16 Jun 2020 07:51:44 +0200
Subject: [PATCH] Switch to v2 of actions/checkout.

---
 .github/workflows/master.yml | 15 ++++++++-------
 1 file changed, 8 insertions(+), 7 deletions(-)

diff --git a/.github/workflows/master.yml b/.github/workflows/master.yml
index 2a9bafbbb25..a3ddb79a3a3 100644
--- a/.github/workflows/master.yml
+++ b/.github/workflows/master.yml
@@ -28,7 +28,7 @@ jobs:
         apt-get update -y
         apt-get install -y autoconf pkg-config ${{matrix.compiler}}
 
-    - uses: actions/checkout@v1
+    - uses: actions/checkout@v2
       with:
         fetch-depth: 1
 
@@ -49,7 +49,7 @@ jobs:
     runs-on: macos-latest
 
     steps:
-    - uses: actions/checkout@v1
+    - uses: actions/checkout@v2
       with:
         fetch-depth: 1
 
@@ -75,35 +75,36 @@ jobs:
     runs-on: windows-latest
 
     steps:
-    - uses: actions/checkout@v1
+    - uses: actions/checkout@v2
       with:
         repository: ImageMagick/ImageMagick-Windows
+        path: ImageMagick-Windows
         ref: refs/heads/master
         fetch-depth: 1
 
     - name: Clone repositories
       shell: cmd
       run: |
-        cd %RUNNER_WORKSPACE%\ImageMagick-Windows
+        cd %GITHUB_WORKSPACE%\ImageMagick-Windows
         CloneRepositories.cmd https://github.com/ImageMagick shallow
 
     - name: Build configure
       shell: cmd
       run: |
         call "C:\Program Files (x86)\Microsoft Visual Studio\2019\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd %RUNNER_WORKSPACE%\ImageMagick-Windows\VisualMagick\configure
+        cd %GITHUB_WORKSPACE%\ImageMagick-Windows\VisualMagick\configure
         devenv /upgrade configure.vcxproj
         msbuild configure.sln /m /t:Rebuild /p:Configuration=Release,Platform=Win32
 
     - name: Configure ImageMagick
       shell: cmd
       run: |
-        cd %RUNNER_WORKSPACE%\ImageMagick-Windows\VisualMagick\configure
+        cd %GITHUB_WORKSPACE%\ImageMagick-Windows\VisualMagick\configure
         configure.exe /noWizard /VS2019 /x64 /smtd
 
     - name: Build ImageMagick
       shell: cmd
       run: |
         call "C:\Program Files (x86)\Microsoft Visual Studio\2019\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd %RUNNER_WORKSPACE%\ImageMagick-Windows\VisualMagick
+        cd %GITHUB_WORKSPACE%\ImageMagick-Windows\VisualMagick
         msbuild VisualStaticMTD.sln /m /t:Rebuild /p:Configuration=Release,Platform=x64
