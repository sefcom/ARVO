From 2b3e0837830e14c7747ac1e175017c733d9d62b3 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Sun, 23 Feb 2025 10:01:12 -0800
Subject: [PATCH] libsnmp: Make 'optind' handling more robust

Fixes: https://issues.oss-fuzz.com/issues/398067543
---
 snmplib/mib.c             | 4 ++--
 snmplib/snmp_parse_args.c | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/snmplib/mib.c b/snmplib/mib.c
index c804bf8a1a..15a8803849 100644
--- a/snmplib/mib.c
+++ b/snmplib/mib.c
@@ -2382,7 +2382,7 @@ snmp_in_options(char *optarg, int argc, char *const *argv)
             break;
         case 's':
             if (!*(++cp)) {
-                cp = argv[optind++];
+                cp = optind < argc ? argv[optind++] : NULL;
                 if (!cp)
                     return "?";
             }
@@ -2393,7 +2393,7 @@ snmp_in_options(char *optarg, int argc, char *const *argv)
 
         case 'S':
             if (!*(++cp)) {
-                cp = argv[optind++];
+                cp = optind < argc ? argv[optind++] : NULL;
                 if (!cp)
                     return "?";
             }
diff --git a/snmplib/snmp_parse_args.c b/snmplib/snmp_parse_args.c
index 872fac20b2..4c8c248d20 100644
--- a/snmplib/snmp_parse_args.c
+++ b/snmplib/snmp_parse_args.c
@@ -634,7 +634,7 @@ netsnmp_parse_args(int argc,
     /*
      * get the hostname 
      */
-    if (optind == argc) {
+    if (optind >= argc) {
         fprintf(stderr, "No hostname specified.\n");
         ret = NETSNMP_PARSE_ARGS_ERROR_USAGE;
         goto out;
