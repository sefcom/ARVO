From a2e0d7447761e584cdffca0449d2cf907ae0d31f Mon Sep 17 00:00:00 2001
From: Richard Hughes <richard@hughsie.com>
Date: Wed, 24 Apr 2024 09:50:42 +0100
Subject: [PATCH] Fix a logic thinko when parsing GUID strings

Fixes https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=68255
---
 libfwupd/fwupd-common.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/libfwupd/fwupd-common.c b/libfwupd/fwupd-common.c
index 473579f6ea6a..38d50eb075de 100644
--- a/libfwupd/fwupd-common.c
+++ b/libfwupd/fwupd-common.c
@@ -784,8 +784,8 @@ fwupd_guid_from_string(const gchar *guidstr,
 				    "GUID is not valid format, no dashes");
 		return FALSE;
 	}
-	if (strlen(split[0]) != 8 && strlen(split[1]) != 4 && strlen(split[2]) != 4 &&
-	    strlen(split[3]) != 4 && strlen(split[4]) != 12) {
+	if (strlen(split[0]) != 8 || strlen(split[1]) != 4 || strlen(split[2]) != 4 ||
+	    strlen(split[3]) != 4 || strlen(split[4]) != 12) {
 		g_set_error_literal(error,
 				    FWUPD_ERROR,
 				    FWUPD_ERROR_INVALID_DATA,
