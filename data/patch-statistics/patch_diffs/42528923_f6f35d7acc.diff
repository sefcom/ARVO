From 7672814a9c93550e00e0461e61d52a9950fdd387 Mon Sep 17 00:00:00 2001
From: Luca Deri <deri@ntop.org>
Date: Sat, 7 Oct 2023 10:38:07 +0200
Subject: [PATCH] Added boundary check to prevent heap overflow

---
 src/Flow.cpp | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/Flow.cpp b/src/Flow.cpp
index 82e9b5d7643d..6296620432c5 100644
--- a/src/Flow.cpp
+++ b/src/Flow.cpp
@@ -6138,6 +6138,9 @@ void Flow::dissectMDNS(u_int8_t *payload, u_int16_t payload_len) {
       first_char = false;
     }
 
+    if((i+sizeof(rsp)) >= payload_len)
+      return; /* packet too short */
+    
     memcpy(&rsp, &payload[i], sizeof(rsp));
     data_len = ntohs(rsp.data_len), rsp_type = ntohs(rsp.rsp_type);
 
