</table><div class='diffstat-summary'>1 files changed, 2 insertions, 2 deletions</div><table summary='diff' class='diff'><tr><td><div class='head'>diff --git a/src/tls/x509v3.c b/src/tls/x509v3.c<br/>index 2b0743116..5c8ac5676 100644<br/>--- a/<a href='/cgit/hostap/tree/src/tls/x509v3.c?id=703c2b6457e8b627c48d82678d46fe327e6b18dd'>src/tls/x509v3.c</a><br/>+++ b/<a href='/cgit/hostap/tree/src/tls/x509v3.c?id=76162b18280b174cd5e7101c9678f69785409fa3'>src/tls/x509v3.c</a></div><div class='hunk'>@@ -1205,14 +1205,14 @@ static int x509_parse_ext_certificate_policies(struct x509_certificate *cert,</div><div class='ctx'> 		struct asn1_oid oid;</div><div class='ctx'> 		char buf[80];</div><div class='ctx'> </div><div class='del'>-		if (asn1_get_next(pos, len, &amp;hdr) &lt; 0 ||</div><div class='add'>+		if (asn1_get_next(pos, end - pos, &amp;hdr) &lt; 0 ||</div><div class='ctx'> 		    hdr.class != ASN1_CLASS_UNIVERSAL ||</div><div class='ctx'> 		    hdr.tag != ASN1_TAG_SEQUENCE) {</div><div class='ctx'> 			wpa_printf(MSG_DEBUG, "X509: Expected SEQUENCE (PolicyInformation) - found class %d tag 0x%x",</div><div class='ctx'> 				   hdr.class, hdr.tag);</div><div class='ctx'> 			return -1;</div><div class='ctx'> 		}</div><div class='del'>-		if (hdr.length &gt; pos + len - hdr.payload)</div><div class='add'>+		if (hdr.length &gt; end - hdr.payload)</div><div class='ctx'> 			return -1;</div><div class='ctx'> 		pos = hdr.payload;</div><div class='ctx'> 		pol_end = pos + hdr.length;</div></td></tr></table></div> <!-- class=content -->
