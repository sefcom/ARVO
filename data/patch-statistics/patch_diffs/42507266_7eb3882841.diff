From 726f5856df30ea84a3ffda707c18d2d6472f9730 Mon Sep 17 00:00:00 2001
From: Henrik Gramner <gramner@twoorioles.com>
Date: Wed, 12 Jan 2022 16:56:06 +0100
Subject: [PATCH] Silence false positive msan warnings in CPU detection code

---
 src/cpu.c | 9 ++-------
 1 file changed, 2 insertions(+), 7 deletions(-)

diff --git a/src/cpu.c b/src/cpu.c
index a8c0abb5..2e5e8d90 100644
--- a/src/cpu.c
+++ b/src/cpu.c
@@ -49,16 +49,11 @@
 #endif
 
 static unsigned flags = 0;
-
-#if __has_feature(memory_sanitizer)
-// memory sanitizer is inherently incompatible with asm
-static unsigned flags_mask = 0;
-#else
 static unsigned flags_mask = -1;
-#endif
 
 COLD void dav1d_init_cpu(void) {
-#if HAVE_ASM
+#if HAVE_ASM && !__has_feature(memory_sanitizer)
+// memory sanitizer is inherently incompatible with asm
 #if ARCH_AARCH64 || ARCH_ARM
     flags = dav1d_get_cpu_flags_arm();
 #elif ARCH_PPC64LE
