From 44c19086e8dbde76ab25bf1ca94f910c5d6f5a3c Mon Sep 17 00:00:00 2001
From: Arne Welzel <arne.welzel@corelight.com>
Date: Wed, 1 Feb 2023 11:41:50 +0100
Subject: [PATCH] cirrus: Add back testing of container images

---
 .cirrus.yml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/.cirrus.yml b/.cirrus.yml
index 9e4d40d3b6b..ef9209f5656 100644
--- a/.cirrus.yml
+++ b/.cirrus.yml
@@ -441,6 +441,9 @@ docker_build_template: &DOCKER_BUILD_TEMPLATE
   build_final_script:
     - cd docker && docker build --cache-from ${IMAGE_TAG} -t ${IMAGE_TAG} -f final.Dockerfile .
     - docker save ${IMAGE_TAG} | zstd > ${ZEEK_IMAGE_CACHE_DIR}/final.zst
+  test_script:
+    - docker tag ${IMAGE_TAG} zeek:latest
+    - make -C docker/btest
 
 arm64_container_image_docker_builder:
   env:
