From b28de684d9263ce61dcb2516e9ddbd9c7a59c39c Mon Sep 17 00:00:00 2001
From: "Victor M. Alvarez" <vmalvarez@virustotal.com>
Date: Fri, 15 Nov 2019 10:58:28 +0100
Subject: [PATCH] Fix bazel build and break line longer than 80 columns.

---
 libyara/modules/pe/pe.c | 3 ++-
 tests/BUILD.bazel       | 1 +
 2 files changed, 3 insertions(+), 1 deletion(-)

diff --git a/libyara/modules/pe/pe.c b/libyara/modules/pe/pe.c
index a270cb34b2..23659b93fe 100644
--- a/libyara/modules/pe/pe.c
+++ b/libyara/modules/pe/pe.c
@@ -240,7 +240,8 @@ static void pe_parse_rich_signature(
   memcpy(raw_data, rich_signature, rich_len);
 
   set_integer(
-      base_address + ((uint8_t*) rich_signature - pe->data), pe->object, "rich_signature.offset");
+      base_address + ((uint8_t*) rich_signature - pe->data),
+      pe->object, "rich_signature.offset");
 
   set_integer(rich_len, pe->object, "rich_signature.length");
 
diff --git a/tests/BUILD.bazel b/tests/BUILD.bazel
index 4f1a270300..310ed757a2 100644
--- a/tests/BUILD.bazel
+++ b/tests/BUILD.bazel
@@ -90,6 +90,7 @@ cc_test(
         "data/tiny-idata-51ff",
         "data/tiny-idata-5200",
         "data/tiny-overlay",
+        "data/weird_rich",
     ],
     deps = [
         ":util",
