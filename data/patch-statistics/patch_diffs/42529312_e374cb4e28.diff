From 8eb046dbf6bad8d2752a7465d17637ce68245712 Mon Sep 17 00:00:00 2001
From: Cristy <urban-warrior@imagemagick.org>
Date: Fri, 20 Oct 2023 17:28:57 -0400
Subject: [PATCH] off by one exception

---
 coders/bmp.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/coders/bmp.c b/coders/bmp.c
index af7538ad540..81c930bd83f 100644
--- a/coders/bmp.c
+++ b/coders/bmp.c
@@ -1112,7 +1112,7 @@ static Image *ReadBMPImage(const ImageInfo *image_info,ExceptionInfo *exception)
         (bmp_info.compression == BI_ALPHABITFIELDS))
       {
         pixel_info=AcquireVirtualMemory(image->rows,
-          MagickMax(bytes_per_line,image->columns+256UL)*sizeof(*pixels));
+          MagickMax(bytes_per_line,image->columns+512UL)*sizeof(*pixels));
         if (pixel_info == (MemoryInfo *) NULL)
           ThrowReaderException(ResourceLimitError,"MemoryAllocationFailed");
         pixels=(unsigned char *) GetVirtualMemoryBlob(pixel_info);
