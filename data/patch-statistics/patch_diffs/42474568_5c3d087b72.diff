From 67d531dce9df1630387a870833cfdb6cd707ee9c Mon Sep 17 00:00:00 2001
From: pancake <pancake@nopcode.org>
Date: Sat, 27 Apr 2019 11:26:45 +0200
Subject: [PATCH] Fix heap overflow in macho parser ##bin

Sample: clusterfuzz-testcase-minimized-ia_fuzz-5651817880354816.dms
---
 libr/bin/format/mach0/mach0.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libr/bin/format/mach0/mach0.c b/libr/bin/format/mach0/mach0.c
index da8db9ec28c1d..b423c9adcd9ef 100644
--- a/libr/bin/format/mach0/mach0.c
+++ b/libr/bin/format/mach0/mach0.c
@@ -2070,7 +2070,7 @@ RSkipList *MACH0_(get_relocs)(struct MACH0_(obj_t) *bin) {
 		if (bin->dyld_info->bind_off+bind_size+lazy_size > bin->size) {
 			return NULL;
 		}
-		int amount = bind_size + lazy_size + weak_size;
+		ut64 amount = bind_size + lazy_size + weak_size;
 		if (amount < 0) {
 			return NULL;
 		}
