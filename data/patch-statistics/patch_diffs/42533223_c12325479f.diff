From 5a83f50fe9a6cd513029e37cc723ae53c01807c3 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Fri, 23 Feb 2024 16:55:07 +0100
Subject: [PATCH] inspect: check size against nalu_size_length

ossfuzz 66931
---
 src/filters/inspect.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/filters/inspect.c b/src/filters/inspect.c
index 8304d6da80..e5594a0785 100644
--- a/src/filters/inspect.c
+++ b/src/filters/inspect.c
@@ -3217,6 +3217,10 @@ static void inspect_dump_packet(GF_InspectCtx *ctx, FILE *dump, GF_FilterPacket
 			}
 		}
 		while (size) {
+			if (size < pctx->nalu_size_length) {
+				inspect_printf(dump, "   <!-- NALU is corrupted: nalu_size_length is %u but only %d remains -->\n", pctx->nalu_size_length, size);
+				break;
+			}
 			u32 nal_size = inspect_get_nal_size((char*)data, pctx->nalu_size_length);
 			data += pctx->nalu_size_length;
 
