From 0823ba88a04c28cf531d36d253969d14099702bb Mon Sep 17 00:00:00 2001
From: Chris Liddell <chris.liddell@artifex.com>
Date: Mon, 26 Sep 2022 14:00:29 +0100
Subject: oss-fuzz 51473: pdfwrite - capture and act on error code

when setting up a flate compressed output stream.
---
 devices/vector/gdevpdfu.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/devices/vector/gdevpdfu.c b/devices/vector/gdevpdfu.c
index 9545bd583..89b837321 100644
--- a/devices/vector/gdevpdfu.c
+++ b/devices/vector/gdevpdfu.c
@@ -1080,7 +1080,11 @@ none_to_stream(gx_device_pdf * pdev)
             es->procs.process = templat->process;
             es->strm = s;
             (*templat->set_defaults) ((stream_state *) st);
-            (*templat->init) ((stream_state *) st);
+            code = (*templat->init) ((stream_state *) st);
+            if (code < 0) {
+                gs_free_object(pdev->pdf_memory, st, "none_to_stream");
+                return code;
+            }
             pdev->strm = s = es;
         }
     }
