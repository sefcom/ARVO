From b4da9cf1557c5034ddbebfb6cfc235b9a1c4dd5e Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sun, 4 Jun 2017 00:16:32 +0000
Subject: [PATCH] GRIB / degrib: avoid heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2070. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@38841 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/degrib18/g2clib-1.0.4/g2_getfld.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/gdal/frmts/grib/degrib18/g2clib-1.0.4/g2_getfld.c b/gdal/frmts/grib/degrib18/g2clib-1.0.4/g2_getfld.c
index ef6385c3d319..fd6aa51d200c 100644
--- a/gdal/frmts/grib/degrib18/g2clib-1.0.4/g2_getfld.c
+++ b/gdal/frmts/grib/degrib18/g2clib-1.0.4/g2_getfld.c
@@ -494,7 +494,15 @@ g2int g2_getfld(unsigned char *cgrib,g2int cgrib_length, g2int ifldnum,g2int unp
                }
             }
             else {
-               lgfld->expanded=1;
+               if( lgfld->ngrdpts != lgfld->ndpts )
+               {
+                   /* Added by E. Rouault to fix https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2070 */
+                   lgfld->expanded=0;
+               }
+               else 
+               {
+                    lgfld->expanded=1;
+               }
             }
           }
           else {
