From fb35bdcbea0d4d27adfedecc78f9c8e0b28187ec Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 13 Feb 2024 13:42:30 +0100
Subject: [PATCH] prevent str overflow in rtsp

ossfuzz issue 66637
---
 src/ietf/rtsp_session.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/ietf/rtsp_session.c b/src/ietf/rtsp_session.c
index 83f61da711..a07d0692b0 100644
--- a/src/ietf/rtsp_session.c
+++ b/src/ietf/rtsp_session.c
@@ -151,7 +151,7 @@ GF_Err RTSP_UnpackURL(char *sURL, char Server[1024], u16 *Port, char Service[102
 		text[i] = test[i];
 		i += 1;
 	}
-	text[i] = 0;
+	text[MIN(i, GF_ARRAY_LENGTH(text)-1)] = 0;
 	strncpy(Server, text, 1024);
 	Server[1023]=0;
 	if (sep) sep[0] = '?';
