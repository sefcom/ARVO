From 8315c5029f1b8bc855a2263b1986f22d24cd1a3b Mon Sep 17 00:00:00 2001
From: davkor <david@adalogics.com>
Date: Mon, 23 Nov 2020 14:56:01 +0000
Subject: [PATCH] pack gelf: fix stack buffer overflow on temp variable
 (oss-fuzz 26237)

Signed-off-by: davkor <david@adalogics.com>
---
 src/flb_pack_gelf.c | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/src/flb_pack_gelf.c b/src/flb_pack_gelf.c
index 1a4007232bc..98a25ece8b9 100644
--- a/src/flb_pack_gelf.c
+++ b/src/flb_pack_gelf.c
@@ -671,16 +671,37 @@ flb_sds_t flb_msgpack_to_gelf(flb_sds_t *s, msgpack_object *o,
                     val = temp;
                     val_len = snprintf(temp, sizeof(temp) - 1,
                                        "%" PRIu64, v->via.u64);
+                    /*
+                     * Check if the value length is larger than our string.
+                     * this is needed to avoid stack-based overflows.
+                     */
+                    if (val_len > sizeof(temp)) {
+                        return NULL;
+                    }
                 }
                 else if (v->type == MSGPACK_OBJECT_NEGATIVE_INTEGER) {
                     val = temp;
                     val_len = snprintf(temp, sizeof(temp) - 1,
                                        "%" PRId64, v->via.i64);
+                    /*
+                     * Check if the value length is larger than our string.
+                     * this is needed to avoid stack-based overflows.
+                     */
+                    if (val_len > sizeof(temp)) {
+                        return NULL;
+                    }
                 }
                 else if (v->type == MSGPACK_OBJECT_FLOAT) {
                     val = temp;
                     val_len = snprintf(temp, sizeof(temp) - 1,
                                        "%f", v->via.f64);
+                    /*
+                     * Check if the value length is larger than our string.
+                     * this is needed to avoid stack-based overflows.
+                     */
+                    if (val_len > sizeof(temp)) {
+                        return NULL;
+                    }
                 }
                 else if (v->type == MSGPACK_OBJECT_STR) {
                     /* String value */
@@ -715,6 +736,7 @@ flb_sds_t flb_msgpack_to_gelf(flb_sds_t *s, msgpack_object *o,
                 if (tmp == NULL) {
                     return NULL;
                 }
+
                 *s = tmp;
 
                 if (v->type == MSGPACK_OBJECT_EXT) {
