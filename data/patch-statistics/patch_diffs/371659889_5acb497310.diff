From 18ae55523a3b901081fa21cce7ca559ee81b7276 Mon Sep 17 00:00:00 2001
From: Cristy <urban-warrior@imagemagick.org>
Date: Sat, 5 Oct 2024 08:57:54 -0400
Subject: [PATCH] release

---
 configure     | 4 ++--
 m4/version.m4 | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/configure b/configure
index a7d2b541713..7e6ce0777c1 100755
--- a/configure
+++ b/configure
@@ -5198,7 +5198,7 @@ MAGICK_PATCHLEVEL_VERSION=39
 
 MAGICK_VERSION=7.1.1-39
 
-MAGICK_GIT_REVISION=d33ec12ca:20241002
+MAGICK_GIT_REVISION=e339a05ed:20241002
 
 
 # Substitute library versioning
@@ -5222,7 +5222,7 @@ PACKAGE_BASE_VERSION=7.1.1
 
 PACKAGE_PATCHLEVEL_VERSION=39
 
-if test "y" = 'y'; then
+if test "n" = 'y'; then
   PACKAGE_VERSION_ADDENDUM='-39 (Beta)'
 else
   PACKAGE_VERSION_ADDENDUM=-39
diff --git a/m4/version.m4 b/m4/version.m4
index 815e8e059d3..c8ff7b0999e 100644
--- a/m4/version.m4
+++ b/m4/version.m4
@@ -28,7 +28,7 @@ m4_define([magick_major_version], [7])
 m4_define([magick_minor_version], [1])
 m4_define([magick_micro_version], [1])
 m4_define([magick_patchlevel_version], [39])
-m4_define([magick_is_beta], [y])
+m4_define([magick_is_beta], [n])
 m4_define([magick_bugreport],
           [https://github.com/ImageMagick/ImageMagick/issues])
 m4_define([magick_url], [https://imagemagick.org])
