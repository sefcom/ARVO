From ca4aefc96a54df3cff761549ca730889967791f2 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Fri, 1 Dec 2023 16:47:48 +0100
Subject: [PATCH] Fix uninitialized use of viewBox attribute in SVG parser.

This fixes OSS-fuzz issue 64539.
---
 source/svg/svg-run.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/source/svg/svg-run.c b/source/svg/svg-run.c
index 70f6fb348a..1fed16391c 100644
--- a/source/svg/svg-run.c
+++ b/source/svg/svg-run.c
@@ -890,6 +890,7 @@ svg_parse_viewport(fz_context *ctx, svg_document *doc, fz_xml *node, svg_state *
 static void
 svg_lex_viewbox(const char *s, float *x, float *y, float *w, float *h)
 {
+	*x = *y = *w = *h = 0;
 	while (svg_is_whitespace_or_comma(*s)) ++s;
 	if (svg_is_digit(*s)) s = svg_lex_number(x, s);
 	while (svg_is_whitespace_or_comma(*s)) ++s;
