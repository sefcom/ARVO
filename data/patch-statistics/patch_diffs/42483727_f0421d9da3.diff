From 0116d4453b59a02a550db9dd074531eeafd6e4c4 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Wed, 14 Jun 2017 08:19:55 +0000
Subject: [PATCH] E00GRID: avoid index-out-of-bounds write access. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2237. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39107 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/e00grid/e00read.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/gdal/frmts/e00grid/e00read.c b/gdal/frmts/e00grid/e00read.c
index a52b50a0e81f..60d47998ccea 100644
--- a/gdal/frmts/e00grid/e00read.c
+++ b/gdal/frmts/e00grid/e00read.c
@@ -590,7 +590,20 @@ static const char *_UncompressNextLine(E00ReadPtr psInfo)
                 /* If odd number of digits, then flush the last one
                  */
                 if (bOddNumDigits)
+                {
+                    if( iOutBufPtr == 0 )
+                    {
+                        CPLError(CE_Failure, CPLE_FileIO,
+                                "Input file possibly corrupt around line %d.",
+                                psInfo->nInputLineNo);
+                        /* Force the program to abort by simulating a EOF
+                        */
+                        psInfo->bEOF = 1;
+                        bEOL = 1;
+                        break;
+                    }
                     iOutBufPtr--;
+                }
 
                 /* Insert the exponent string before the 2 last digits
                  * (we assume the exponent string is 2 chars. long)
