From 060080285a4fe81c9cb3a01381bbbd907c5dfea5 Mon Sep 17 00:00:00 2001
From: Eugene Kliuchnikov <eustas@google.com>
Date: Thu, 4 Jul 2024 15:40:17 +0200
Subject: [PATCH] Fix unsigned integer multiplication overflow on i386 build
 (#3695)

---
 lib/jxl/image.cc | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/lib/jxl/image.cc b/lib/jxl/image.cc
index 8f70659c00c..f7a05c82745 100644
--- a/lib/jxl/image.cc
+++ b/lib/jxl/image.cc
@@ -10,6 +10,7 @@
 #include <algorithm>  // fill, swap
 #include <cstddef>
 #include <cstdint>
+#include <limits>
 
 #include "lib/jxl/base/status.h"
 #include "lib/jxl/memory_manager_internal.h"
@@ -80,6 +81,11 @@ Status PlaneBase::Allocate(JxlMemoryManager* memory_manager,
     return true;
   }
 
+  size_t max_y_size = std::numeric_limits<size_t>::max() / bytes_per_row_;
+  if (ysize_ > max_y_size) {
+    return JXL_FAILURE("Image dimensions are too large");
+  }
+
   JXL_ASSIGN_OR_RETURN(
       bytes_, AlignedMemory::Create(memory_manager, bytes_per_row_ * ysize_,
                                     pre_padding * sizeof_t_));
