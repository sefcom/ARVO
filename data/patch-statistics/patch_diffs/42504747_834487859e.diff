From: Cliff Jansen <cliffjansen@apache.org>
Date: Sun, 21 Nov 2021 13:09:25 -0800
Subject: [PATCH] PROTON-2362: epoll proactor fix for tsan_tr3.txt. Use safe
 local variable not subject to deletion in another thread.

---
 c/src/proactor/epoll.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/c/src/proactor/epoll.c b/c/src/proactor/epoll.c
index c481274bf6..31edfbe7ee 100644
--- a/c/src/proactor/epoll.c
+++ b/c/src/proactor/epoll.c
@@ -1451,7 +1451,7 @@ void pn_proactor_connect2(pn_proactor_t *p, pn_connection_t *c, pn_transport_t *
   }
   /* We need to issue INACTIVE on immediate failure */
   unlock(&pc->task.mutex);
-  if (notify) notify_poller(pc->task.proactor);
+  if (notify) notify_poller(p);
 }
 
 static void pconnection_tick(pconnection_t *pc) {
