From 4c1de376612bb0665bc0c1e3c4b03790a949ac3f Mon Sep 17 00:00:00 2001
From: DavidKorczynski <david@adalogics.com>
Date: Tue, 2 Mar 2021 16:39:46 +0000
Subject: [PATCH] sds: fix off-by-one overflow. OSS-Fuzz 5647136884654080
 (#3136)

Signed-off-by: davkor <david@adalogics.com>
---
 src/flb_sds.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/flb_sds.c b/src/flb_sds.c
index a1c7c0e15e7..9561b5e0431 100644
--- a/src/flb_sds.c
+++ b/src/flb_sds.c
@@ -288,7 +288,7 @@ flb_sds_t flb_sds_cat_utf8 (flb_sds_t *sds, const char *str, int str_len)
             cp = 0;
             for (b = 0; b < hex_bytes; b++) {
                 p = (const unsigned char *) str + i + b;
-                if (p > (str + str_len)) {
+                if (p >= (str + str_len)) {
                     break;
                 }
                 ret = flb_utf8_decode(&state, &cp, *p);
