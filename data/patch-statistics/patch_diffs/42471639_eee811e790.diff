From f4f8cdc4c344ad75051f3785a53a956a644cba05 Mon Sep 17 00:00:00 2001
From: Stefan Profanter <git@s.profanter.me>
Date: Wed, 28 Nov 2018 14:24:40 +0100
Subject: [PATCH] Stack: Fix heap use after free

Fixes https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=11484

Credit to oss-fuzz
---
 src/ua_types.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ua_types.c b/src/ua_types.c
index 19b3ee9f822..641afa7781b 100644
--- a/src/ua_types.c
+++ b/src/ua_types.c
@@ -408,6 +408,7 @@ Variant_clear(UA_Variant *p, const UA_DataType *_) {
         if(p->arrayLength == 0)
             p->arrayLength = 1;
         UA_Array_delete(p->data, p->arrayLength, p->type);
+        p->data = NULL;
     }
     if((void*)p->arrayDimensions > UA_EMPTY_ARRAY_SENTINEL)
         UA_free(p->arrayDimensions);
