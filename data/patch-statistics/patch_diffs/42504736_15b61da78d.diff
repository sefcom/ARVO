From b28ee777ab3dcd6adefe673ca6144315e3934882 Mon Sep 17 00:00:00 2001
From: Lovell Fuller <lovell@users.noreply.github.com>
Date: Mon, 6 Dec 2021 13:52:02 +0000
Subject: [PATCH 1/2] Windows: don't set create time for invalid/stream fd
 (#2571)

---
 libvips/iofuncs/util.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/libvips/iofuncs/util.c b/libvips/iofuncs/util.c
index d445ff4e24..8c13597ef0 100644
--- a/libvips/iofuncs/util.c
+++ b/libvips/iofuncs/util.c
@@ -586,6 +586,12 @@ vips__set_create_time( int fd )
 	SYSTEMTIME st;
 	FILETIME ft;
 
+	/* Create time cannot be set on invalid or stream
+	 * (stdin, stdout, stderr) file descriptors.
+	 */
+	if( fd < 3 )
+		return;
+
 	if( (handle = (HANDLE) _get_osfhandle( fd )) == INVALID_HANDLE_VALUE )
 		return;
 	GetSystemTime( &st );
@@ -635,7 +641,7 @@ vips__fopen( const char *filename, const char *mode )
 	fp = g_fopen( filename, mode );
 
 #ifdef G_OS_WIN32
-	if( mode[0] == 'w' )
+	if( fp && mode[0] == 'w' )
 		vips__set_create_time( _fileno( fp ) ); 
 #endif /*G_OS_WIN32*/
 

From cd80b5ae94f61e9e5e790c63451d5e375925d380 Mon Sep 17 00:00:00 2001
From: John Cupitt <jcupitt@gmail.com>
Date: Mon, 6 Dec 2021 13:58:46 +0000
Subject: [PATCH 2/2] note win fd change in changelog

---
 ChangeLog              | 1 +
 libvips/iofuncs/util.c | 6 ++++--
 2 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/ChangeLog b/ChangeLog
index 4a21631d30..f85a91cfaa 100644
--- a/ChangeLog
+++ b/ChangeLog
@@ -1,5 +1,6 @@
 26/11/21 started 8.12.2
 - make exif resuint optional and default to inch
+- win: don't set create time on inappropriate file descriptors [lovell]
 
 21/11/21 started 8.12.1
 - fix insert [chregu]
diff --git a/libvips/iofuncs/util.c b/libvips/iofuncs/util.c
index 8c13597ef0..6e0fe6c00c 100644
--- a/libvips/iofuncs/util.c
+++ b/libvips/iofuncs/util.c
@@ -618,7 +618,8 @@ vips__open( const char *filename, int flags, int mode )
 	fd = g_open( filename, flags, mode );
 
 #ifdef G_OS_WIN32
-	if( mode & O_CREAT )
+	if( fd != -1 &&
+		(mode & O_CREAT) )
 		vips__set_create_time( fd ); 
 #endif /*G_OS_WIN32*/
 
@@ -641,7 +642,8 @@ vips__fopen( const char *filename, const char *mode )
 	fp = g_fopen( filename, mode );
 
 #ifdef G_OS_WIN32
-	if( fp && mode[0] == 'w' )
+	if( fp && 
+		mode[0] == 'w' )
 		vips__set_create_time( _fileno( fp ) ); 
 #endif /*G_OS_WIN32*/
 
