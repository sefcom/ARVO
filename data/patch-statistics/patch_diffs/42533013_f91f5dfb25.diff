From 6268329b7ce88f13cb092e9f3de86d3036dcff97 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Fri, 16 Feb 2024 09:53:26 +0100
Subject: [PATCH] check text size in rtsp unpack

ossfuzz issue 66742
---
 src/ietf/rtsp_session.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ietf/rtsp_session.c b/src/ietf/rtsp_session.c
index a07d0692b0..b0c9855bfe 100644
--- a/src/ietf/rtsp_session.c
+++ b/src/ietf/rtsp_session.c
@@ -148,6 +148,7 @@ GF_Err RTSP_UnpackURL(char *sURL, char Server[1024], u16 *Port, char Service[102
 		if (test[i]=='[') is_ipv6 = GF_TRUE;
 		else if (test[i]==']') is_ipv6 = GF_FALSE;
 		if ( (test[i] == '/') || (!is_ipv6 && (test[i] == ':')) ) break;
+		if (i>=GF_ARRAY_LENGTH(text)) break;
 		text[i] = test[i];
 		i += 1;
 	}
