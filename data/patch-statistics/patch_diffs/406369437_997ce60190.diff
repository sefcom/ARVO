                                 (word32)(rx_buf_len - (rx_payload - rx_buf)),
                                 props_len);
-                        if (tmp < 0)
-                            return tmp;
-                        rx_payload += tmp;
+                        if (props_tmp < 0)
+                            return props_tmp;
+                        rx_payload += props_tmp;
                     }
