     if (publish->qos > MQTT_QOS_0) {
+        int tmp;
         if (rx_payload - rx_buf + MQTT_DATA_LEN_SIZE > rx_buf_len) {
             return MQTT_TRACE_ERROR(MQTT_CODE_ERROR_OUT_OF_BUFFER);
         }
