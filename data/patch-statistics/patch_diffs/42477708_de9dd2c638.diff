+    SkPaint paint;
+    paint.setAntiAlias(true);
+
+    SkPath path;
+    path.moveTo(0, 0);
+    path.lineTo(50, 0);
+    path.lineTo(0, 50);
+    path.close();
+
+    SkMatrix m;
