From: Reini Urban <rurban@cpan.org>
Date: Tue, 12 Sep 2023 09:55:31 +0200
Subject: [PATCH] bits: fix double-free in Out of memory error

Fixes oss-fuzz 48236 crash
---
 src/bits.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/bits.c b/src/bits.c
index 0485b2feb8..41f0d2078e 100644
--- a/src/bits.c
+++ b/src/bits.c
@@ -3236,7 +3236,7 @@ bit_TV_to_utf8 (const char *restrict src, const BITCODE_RS codepage)
                     loglevel |= 1;
                     LOG_ERROR ("Out of memory");
                     iconv_close (cd);
-                    free (odest);
+                    //free (odest);
                     return NULL;
                   }
               }
