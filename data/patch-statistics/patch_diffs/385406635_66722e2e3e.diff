From 4e721231df51524110a5a6b68b1a0f1adc57a1da Mon Sep 17 00:00:00 2001
From: Daniel Lemire <daniel@lemire.me>
Date: Sun, 22 Dec 2024 19:51:50 -0500
Subject: [PATCH] fixing issue with utf-8 to latin1 transcoding for some
 kernels (#612)

* fixing issue with utf-8 to latin1 transcoding for some kernels

* lint
---
 src/generic/utf8_to_latin1/utf8_to_latin1.h   |   3 +
 tests/convert_utf8_to_latin1_tests.cpp        |   8 -
 ...nvert_utf8_to_latin1_with_errors_tests.cpp | 198 ++++++++++++++++++
 3 files changed, 201 insertions(+), 8 deletions(-)

diff --git a/src/generic/utf8_to_latin1/utf8_to_latin1.h b/src/generic/utf8_to_latin1/utf8_to_latin1.h
index 3af6b150d..43062bf3c 100644
--- a/src/generic/utf8_to_latin1/utf8_to_latin1.h
+++ b/src/generic/utf8_to_latin1/utf8_to_latin1.h
@@ -158,6 +158,9 @@ struct validating_transcoder {
         uint64_t utf8_continuation_mask =
             input.lt(-65 + 1); // -64 is 1100 0000 in twos complement. Note: in
                                // this case, we also have ASCII to account for.
+        if (utf8_continuation_mask & 1) {
+          return 0; // error
+        }
         uint64_t utf8_leading_mask = ~utf8_continuation_mask;
         uint64_t utf8_end_of_code_point_mask = utf8_leading_mask >> 1;
         // We process in blocks of up to 12 bytes except possibly
diff --git a/tests/convert_utf8_to_latin1_tests.cpp b/tests/convert_utf8_to_latin1_tests.cpp
index 71e5a86df..224370a0c 100644
--- a/tests/convert_utf8_to_latin1_tests.cpp
+++ b/tests/convert_utf8_to_latin1_tests.cpp
@@ -205,14 +205,6 @@ TEST(ossfuzz_385406635) {
   const auto outlen =
       implementation.latin1_length_from_utf8((const char *)data, data_len);
   ASSERT_EQUAL(outlen, 2005);
-
-  // to make this test pass under address sanitizer, uncomment the next:
-  /*
-  if (implementation.name() == "haswell")
-    return;
-  if (implementation.name() == "westmere")
-    return;
-  */
   std::vector<char> output(outlen);
   const auto r = implementation.convert_utf8_to_latin1((const char *)data,
                                                        data_len, output.data());
diff --git a/tests/convert_utf8_to_latin1_with_errors_tests.cpp b/tests/convert_utf8_to_latin1_with_errors_tests.cpp
index 02000f77a..b6bed0c1c 100644
--- a/tests/convert_utf8_to_latin1_with_errors_tests.cpp
+++ b/tests/convert_utf8_to_latin1_with_errors_tests.cpp
@@ -23,6 +23,202 @@ void printByteInBinary(const char &byte) {
   putchar('\n');
 }
 
