From 75b66c456a19527e322741326615d664de60789c Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Mon, 8 Jul 2024 21:54:16 +0200
Subject: [PATCH] Changed defines to use method instead of a define.

---
 MagickCore/blob-private.h    | 2 +-
 MagickCore/nt-base-private.h | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/MagickCore/blob-private.h b/MagickCore/blob-private.h
index 3f8482c3bac..b97716679ba 100644
--- a/MagickCore/blob-private.h
+++ b/MagickCore/blob-private.h
@@ -32,7 +32,7 @@ extern "C" {
 #endif
 #if defined(MAGICKCORE_WINDOWS_SUPPORT)
 #if !defined(__MINGW32__)
-#  define stat  _stati64
+#  define stat  _stat64
 #endif
 #endif
 
diff --git a/MagickCore/nt-base-private.h b/MagickCore/nt-base-private.h
index 6a49cb99c2e..ca25047abdc 100644
--- a/MagickCore/nt-base-private.h
+++ b/MagickCore/nt-base-private.h
@@ -67,8 +67,8 @@ extern "C" {
 #  define fseek  _fseeki64
 #  define ftell  _ftelli64
 #  define lseek  _lseeki64
-#  define fstat  _fstati64
-#  define stat  _stati64
+#  define fstat  _fstat64
+#  define stat  _stat64
 #  define tell  _telli64
 #endif
 
