From 538b229cab5e6317053c15c66417a9d053681ad0 Mon Sep 17 00:00:00 2001
From: jeanlf <jeanlf@gpac.io>
Date: Wed, 17 Jan 2024 11:39:55 +0100
Subject: [PATCH] fixed potential crash in ghi demux init

---
 src/filters/dmx_ghi.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/filters/dmx_ghi.c b/src/filters/dmx_ghi.c
index b6c6d245b3..d7b4950cc1 100644
--- a/src/filters/dmx_ghi.c
+++ b/src/filters/dmx_ghi.c
@@ -1000,8 +1000,10 @@ GF_Err ghi_dmx_init(GF_Filter *filter, GHIDmxCtx *ctx)
 		bs = gf_bs_new(data, size, GF_BITSTREAM_READ);
 		e = ghi_dmx_init_bin(filter, ctx, bs);
 		if (!e && gf_bs_is_overflow(bs)) e = GF_NON_COMPLIANT_BITSTREAM;
-	} else {
+	} else if (gf_utf8_is_legal(data, size))
 		e = ghi_dmx_init_xml(filter, ctx, data);
+	else {
+		e = GF_NON_COMPLIANT_BITSTREAM;
 	}
 	if (e) {
 		if (bs) gf_bs_del(bs);
