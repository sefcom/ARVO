From d376b0413acde04c2672fe0e0964effd0df86803 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 21 May 2024 12:08:12 +0200
Subject: [PATCH] swf_def_bits_jpeg: add size check to prevent heap overflow

ossfuzz issue 69136
---
 src/scene_manager/swf_parse.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/scene_manager/swf_parse.c b/src/scene_manager/swf_parse.c
index bf454f461f..4c3819e754 100644
--- a/src/scene_manager/swf_parse.c
+++ b/src/scene_manager/swf_parse.c
@@ -2119,7 +2119,7 @@ static GF_Err swf_def_bits_jpeg(SWFReader *read, u32 version)
 				break;
 			}
 		}
-		if ((buf[0]==0xFF) && (buf[1]==0xD8) && (buf[2]==0xFF) && (buf[3]==0xD8)) {
+		if ((size>3) && (buf[0]==0xFF) && (buf[1]==0xD8) && (buf[2]==0xFF) && (buf[3]==0xD8)) {
 			skip = 2;
 		}
 		if (version==2) {
