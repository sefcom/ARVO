From 7d5475916cdcf4c54952f7c695363f3d3c682ee9 Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Mon, 25 Jul 2022 14:10:31 +0900
Subject: [PATCH] bigint.c (udiv): avoid out of bound access in division.

---
 mrbgems/mruby-bigint/core/bigint.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mrbgems/mruby-bigint/core/bigint.c b/mrbgems/mruby-bigint/core/bigint.c
index aa7dee026d..545dd8325a 100644
--- a/mrbgems/mruby-bigint/core/bigint.c
+++ b/mrbgems/mruby-bigint/core/bigint.c
@@ -441,7 +441,7 @@ udiv(mrb_state *mrb, mpz_t *qq, mpz_t *rr, mpz_t *xx, mpz_t *yy)
   size_t xd = digits(&x);
   mpz_realloc(mrb, &q, xd);
   mp_limb2 z = y.p[yd-1];
-  for (size_t j=(xd-yd);; j--) {
+  for (size_t j=xd-yd-1;; j--) {
     mp_limb2 qhat = (((mp_limb2)x.p[j+yd] << DIG_SIZE) + x.p[j+yd-1]) / z;
     mp_limb2s b=0;
     if (qhat) {
