From 97a9bd19aac90b602d01f92508504a2ce6f28e48 Mon Sep 17 00:00:00 2001
From: Christian Egli <christian.egli@sbs.ch>
Date: Wed, 3 Apr 2024 13:56:00 +0200
Subject: [PATCH] Fix the display table for Lao braille yaml tests

The yaml tests for Lao braille use a plain
table (latinLetterDef6Dots.uti) in the display table. This is very
fishy and naturally fails in louis-rs.

So I converted the yaml test to use a "normal" display table using
only display opcodes.
---
 tests/braille-specs/lo.yaml | 27 ++++++++++++++++++++++++++-
 1 file changed, 26 insertions(+), 1 deletion(-)

diff --git a/tests/braille-specs/lo.yaml b/tests/braille-specs/lo.yaml
index 94259a6e15..55d99a5011 100644
--- a/tests/braille-specs/lo.yaml
+++ b/tests/braille-specs/lo.yaml
@@ -32,7 +32,32 @@
 # ----------------------------------------------------------------------------------------------
 
 display: |
-  include latinLetterDef6Dots.uti
+  display a 1
+  display b 12
+  display c 14
+  display d 145
+  display e 15
+  display f 124
+  display g 1245
+  display h 125
+  display i 24
+  display j 245
+  display k 13
+  display l 123
+  display m 134
+  display n 1345
+  display o 135
+  display p 1234
+  display q 12345
+  display r 1235
+  display s 234
+  display t 2345
+  display u 136
+  display v 1236
+  display w 2456
+  display x 1346
+  display y 13456
+  display z 1356
   include unicode.dis
 table:
   locale: lo
