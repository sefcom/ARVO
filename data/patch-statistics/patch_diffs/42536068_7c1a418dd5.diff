From a7a28e643cd0f84dcae785f93b72426d644c0619 Mon Sep 17 00:00:00 2001
From: Michael R Sweet <msweet@msweet.org>
Date: Fri, 14 Jun 2024 13:53:05 -0400
Subject: [PATCH] Error out if an attribute conversion is unsuccessful.

---
 cups/ipp.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/cups/ipp.c b/cups/ipp.c
index 12bdde2b6..993c9cf83 100644
--- a/cups/ipp.c
+++ b/cups/ipp.c
@@ -2683,7 +2683,8 @@ ippReadIO(void        *src,		// I - Data source
               if (value_tag != tag)
               {
                 DEBUG_printf("1ippReadIO: Converting %s attribute from %s to %s.", attr->name, ippTagString(value_tag), ippTagString(tag));
-		ippSetValueTag(ipp, &attr, tag);
+		if (!ippSetValueTag(ipp, &attr, tag))
+		  goto rollback;
 	      }
             }
 	    else if (value_tag == IPP_TAG_INTEGER || value_tag == IPP_TAG_RANGE)
