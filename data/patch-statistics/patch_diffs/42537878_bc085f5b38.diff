From 9d7b467d807844ab3d13e9d9f518bac58efc5620 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Mon, 26 Mar 2018 02:10:10 +0800
Subject: [PATCH] Fix 699142: Adaptive pixels can not be pixel to be predicted.

The fix for 699127 didn't account for the adaptive pixel location
being that of the pixel to be predicted. This is of course invalid,
and this is now recitified.
---
 jbig2_generic.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/jbig2_generic.c b/jbig2_generic.c
index 8d4a3c2..54002e8 100644
--- a/jbig2_generic.c
+++ b/jbig2_generic.c
@@ -112,7 +112,7 @@ jbig2_generic_stats_size(Jbig2Ctx *ctx, int template)
 }
 
 #define pixel_outside_field(x, y) \
-    ((y) < -128 || (y) > 0 || (x) < -128 || ((y) < 0 && (x) > 127) || ((y) == 0 && (x) > 0))
+    ((y) < -128 || (y) > 0 || (x) < -128 || ((y) < 0 && (x) > 127) || ((y) == 0 && (x) >= 0))
 
 static int
 jbig2_decode_generic_template0_unopt(Jbig2Ctx *ctx,
