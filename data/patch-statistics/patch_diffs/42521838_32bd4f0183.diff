diff --git a/src/catalog/dependency_list.cpp b/src/catalog/dependency_list.cpp
index 4edd7c419cc1..0aac67b022bf 100644
--- a/src/catalog/dependency_list.cpp
+++ b/src/catalog/dependency_list.cpp
@@ -11,7 +11,7 @@ void DependencyList::AddDependency(CatalogEntry *entry) {
 }
 
 void DependencyList::VerifyDependencies(Catalog *catalog, const string &name) {
-	for(auto &dep : set) {
+	for (auto &dep : set) {
 		if (dep->catalog != catalog) {
 			throw DependencyException(
 			    "Error adding dependency for object \"%s\" - dependency \"%s\" is in catalog "
@@ -21,5 +21,4 @@ void DependencyList::VerifyDependencies(Catalog *catalog, const string &name) {
 	}
 }
 
-
 } // namespace duckdb
diff --git a/src/common/string_util.cpp b/src/common/string_util.cpp
index ba7b26017272..a373ae65d583 100644
--- a/src/common/string_util.cpp
+++ b/src/common/string_util.cpp
@@ -191,11 +191,14 @@ vector<string> StringUtil::Split(const string &input, const string &split) {
 
 		// Push the substring [last, next) on to splits
 		string substr = input.substr(last, next - last);
-		if (substr.empty() == false) {
+		if (!substr.empty()) {
 			splits.push_back(substr);
 		}
 		last = next + split_len;
 	}
+	if (splits.empty()) {
+		splits.push_back(split);
+	}
 	return splits;
 }
 
diff --git a/src/function/aggregate/holistic/approximate_quantile.cpp b/src/function/aggregate/holistic/approximate_quantile.cpp
index 22e84727a4c1..ad93125b6523 100644
--- a/src/function/aggregate/holistic/approximate_quantile.cpp
+++ b/src/function/aggregate/holistic/approximate_quantile.cpp
@@ -70,11 +70,14 @@ struct ApproxQuantileOperation {
 
 	template <class INPUT_TYPE, class STATE, class OP>
 	static void Operation(STATE *state, AggregateInputData &, INPUT_TYPE *data, ValidityMask &mask, idx_t idx) {
+		auto val = Cast::template Operation<INPUT_TYPE, SAVE_TYPE>(data[idx]);
+		if (!Value::DoubleIsFinite(val)) {
+			return;
+		}
 		if (!state->h) {
 			state->h = new duckdb_tdigest::TDigest(100);
 		}
-
-		state->h->add(Cast::template Operation<INPUT_TYPE, SAVE_TYPE>(data[idx]));
+		state->h->add(val);
 		state->pos++;
 	}
 
diff --git a/src/function/table/checkpoint.cpp b/src/function/table/checkpoint.cpp
index 2fba07534405..2fb71f8fea38 100644
--- a/src/function/table/checkpoint.cpp
+++ b/src/function/table/checkpoint.cpp
@@ -32,7 +32,11 @@ static unique_ptr<FunctionData> CheckpointBind(ClientContext &context, TableFunc
 	AttachedDatabase *db;
 	auto &db_manager = DatabaseManager::Get(context);
 	if (!input.inputs.empty()) {
-		db = db_manager.GetDatabase(context, StringValue::Get(input.inputs[0]));
+		auto &db_name = StringValue::Get(input.inputs[0]);
+		db = db_manager.GetDatabase(context, db_name);
+		if (!db) {
+			throw BinderException("Database \"%s\" not found", db_name);
+		}
 	} else {
 		db = db_manager.GetDatabase(context, DatabaseManager::GetDefaultDatabase(context));
 	}
