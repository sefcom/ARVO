From 7b316c11395677b34ee5a83bde374ef90ab963ba Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Fri, 22 Mar 2024 12:15:23 +0100
Subject: [PATCH] tree: Fix uninitialized value in xmlSearchNsByHrefSafe

Short-lived regression.
---
 tree.c | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/tree.c b/tree.c
index 7ffdebf27..b28f224fd 100644
--- a/tree.c
+++ b/tree.c
@@ -6093,10 +6093,11 @@ xmlSearchNsByHrefSafe(xmlNodePtr node, const xmlChar *href,
     xmlNodePtr parent;
     int is_attr;
 
-    if ((out == NULL) ||
-        (node == NULL) || (node->type == XML_NAMESPACE_DECL))
+    if (out == NULL)
         return(1);
     *out = NULL;
+    if ((node == NULL) || (node->type == XML_NAMESPACE_DECL))
+        return(1);
 
     doc = node->doc;
 
