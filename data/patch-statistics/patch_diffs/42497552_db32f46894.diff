From 3870baef334fc957f51e1df97af412366dd8e386 Mon Sep 17 00:00:00 2001
From: John Cupitt <jcupitt@gmail.com>
Date: Tue, 1 Jun 2021 19:02:41 +0100
Subject: [PATCH] free argv0 a little later

---
 libvips/iofuncs/init.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/libvips/iofuncs/init.c b/libvips/iofuncs/init.c
index 35b485070a..74f9cdd93c 100644
--- a/libvips/iofuncs/init.c
+++ b/libvips/iofuncs/init.c
@@ -739,8 +739,6 @@ vips_shutdown( void )
 	gsf_shutdown(); 
 #endif /*HAVE_GSF*/
 
-       VIPS_FREE(vips__argv0);
-
 	/* In dev releases, always show leaks. But not more than once, it's
 	 * annoying.
 	 */
@@ -757,8 +755,10 @@ vips_shutdown( void )
 		done = TRUE;
 	}
 
-       VIPS_FREEF( vips_g_mutex_free, vips__global_lock );
-       VIPS_FREEF( g_timer_destroy, vips__global_timer );
+	VIPS_FREE( vips__argv0 );
+	VIPS_FREE( vips__prgname );
+	VIPS_FREEF( vips_g_mutex_free, vips__global_lock );
+	VIPS_FREEF( g_timer_destroy, vips__global_timer );
 }
 
 const char *
