From 9ba5f8faeacc35ea41033a4e384bef9cc18e9f5c Mon Sep 17 00:00:00 2001
From: Shen-Ta Hsieh <beststeve@secondstate.io>
Date: Fri, 17 Nov 2023 13:47:33 +0800
Subject: [PATCH] [Fuzz] Force loader in interpreter mode to skip AOT sections

Signed-off-by: Shen-Ta Hsieh <beststeve@secondstate.io>
---
 lib/driver/fuzzTool.cpp | 1 +
 1 file changed, 1 insertion(+)

diff --git a/lib/driver/fuzzTool.cpp b/lib/driver/fuzzTool.cpp
index bb385c369b49..83ffcc8bcc89 100644
--- a/lib/driver/fuzzTool.cpp
+++ b/lib/driver/fuzzTool.cpp
@@ -17,6 +17,7 @@ int FuzzTool(const uint8_t *Data, size_t Size) noexcept {
   spdlog::set_level(spdlog::level::critical);
 
   Configure Conf;
+  Conf.getRuntimeConfigure().setForceInterpreter(true);
   Loader::Loader Loader(Conf);
 
   std::unique_ptr<AST::Module> Module;
