+Result BinaryReaderObjdump::OnRefNullExpr(Type type) {
+  if (ReadingInitExpr()) {
+    current_init_expr_.type = InitExprType::NullRef;
+    current_init_expr_.insts.back().imm.type = type;
+  }
+  return Result::Ok;
+}
