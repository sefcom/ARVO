+Result BinaryReaderObjdump::OnRefFuncExpr(Index func_index) {
+  if (ReadingInitExpr()) {
+    current_init_expr_.type = InitExprType::FuncRef;
+    current_init_expr_.insts.back().imm.index = func_index;
+  }
+  return Result::Ok;
+}
