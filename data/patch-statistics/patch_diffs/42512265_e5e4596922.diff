+	if (divisor == 0) {
+		GOOGLE_LOG(FATAL) << "Division or mod by zero: dividend.hi=" << dividend.hi_ << ", lo=" << dividend.lo_;
+	} else if (dividend < divisor) {
+		*quotient_ret = 0;
+		*remainder_ret = dividend;
