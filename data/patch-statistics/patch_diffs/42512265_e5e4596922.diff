+	// messages present.
+	std::vector<const FieldDescriptor *> fields;
+	reflection->ListFields(*message, &fields);
+	for (const FieldDescriptor *field : fields) {
+		// Skip over non-message fields.
+		if (field->cpp_type() != FieldDescriptor::CPPTYPE_MESSAGE) {
+			continue;
