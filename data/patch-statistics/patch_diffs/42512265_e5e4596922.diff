+	case FieldDescriptor::CPPTYPE_UINT64:
+		reflection->SetUInt64(message, field_desc, key.GetUInt64Value());
+		return;
+	case FieldDescriptor::CPPTYPE_UINT32:
+		reflection->SetUInt32(message, field_desc, key.GetUInt32Value());
