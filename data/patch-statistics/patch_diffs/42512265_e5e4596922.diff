+bool ParseEndsInSlopRegion(const char *begin, int overrun, int depth) {
+	constexpr int kSlopBytes = EpsCopyInputStream::kSlopBytes;
+	GOOGLE_DCHECK(overrun >= 0);
+	GOOGLE_DCHECK(overrun <= kSlopBytes);
+	auto ptr = begin + overrun;
+	auto end = begin + kSlopBytes;
+	while (ptr < end) {
+		uint32_t tag;
+		ptr = ReadTag(ptr, &tag);
+		if (ptr == nullptr || ptr > end)
+			return false;
+		// ending on 0 tag is allowed and is the major reason for the necessity of
+		// this function.
+		if (tag == 0)
+			return true;
+		switch (tag & 7) {
+		case 0: { // Varint
+			uint64_t val;
+			ptr = VarintParse(ptr, &val);
+			if (ptr == nullptr)
+				return false;
+			break;
+		}
+		case 1: { // fixed64
+			ptr += 8;
+			break;
+		}
+		case 2: { // len delim
+			int32_t size = ReadSize(&ptr);
+			if (ptr == nullptr || size > end - ptr)
+				return false;
+			ptr += size;
+			break;
+		}
+		case 3: { // start group
+			depth++;
+			break;
+		}
+		case 4: { // end group
+			if (--depth < 0)
+				return true; // We exit early
+			break;
+		}
+		case 5: { // fixed32
+			ptr += 4;
+			break;
+		}
+		default:
+			return false; // Unknown wireformat
+		}
+	}
+	return false;
