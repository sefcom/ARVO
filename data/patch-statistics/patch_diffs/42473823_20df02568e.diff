From 68dd2c1dac7c7bda908a3277a036ad1947348055 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Thu, 28 Feb 2019 13:02:12 +0100
Subject: [PATCH] XPM: fix read heap buffer overflow on corrupted image. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=13455. Credit to OSS
 Fuzz

---
 gdal/frmts/xpm/xpmdataset.cpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gdal/frmts/xpm/xpmdataset.cpp b/gdal/frmts/xpm/xpmdataset.cpp
index 8efaa98965da..ce5b0630803f 100644
--- a/gdal/frmts/xpm/xpmdataset.cpp
+++ b/gdal/frmts/xpm/xpmdataset.cpp
@@ -567,7 +567,8 @@ ParseXPM( const char *pszInput,
 
     for( int iColor = 0; iColor < nColorCount; iColor++ )
     {
-        if( papszXPMList[iColor+1] == nullptr )
+        if( papszXPMList[iColor+1] == nullptr ||
+            papszXPMList[iColor+1][0] == '\0' )
         {
             CPLError( CE_Failure, CPLE_AppDefined,
                       "Missing color definition for %d in XPM header.",
