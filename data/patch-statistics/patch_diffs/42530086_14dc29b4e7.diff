From 22c6a8f0d47e7458a405415d4672a13891d9989a Mon Sep 17 00:00:00 2001
From: Pascal Quantin <pascal@wireshark.org>
Date: Sun, 12 Nov 2023 19:51:15 +0100
Subject: [PATCH] RF4CE: protect against an out of bounds copy

Fixes #19479
---
 epan/dissectors/packet-rf4ce-nwk.c | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/epan/dissectors/packet-rf4ce-nwk.c b/epan/dissectors/packet-rf4ce-nwk.c
index 5aab977cd86..b926b641c76 100644
--- a/epan/dissectors/packet-rf4ce-nwk.c
+++ b/epan/dissectors/packet-rf4ce-nwk.c
@@ -780,7 +780,7 @@ static int dissect_rf4ce_nwk_common(tvbuff_t *tvb, packet_info *pinfo, proto_tre
     rf4ce_addr_table_get_ieee_addr(src_addr, pinfo, TRUE);
     rf4ce_addr_table_get_ieee_addr(dst_addr, pinfo, FALSE);
 
-    size = tvb_reported_length_remaining(tvb, 0);
+    size = tvb_captured_length_remaining(tvb, 0);
 
     if (fcf & RF4CE_NWK_FCF_SECURITY_MASK)
     {
@@ -792,12 +792,16 @@ static int dissect_rf4ce_nwk_common(tvbuff_t *tvb, packet_info *pinfo, proto_tre
             src_addr,
             dst_addr);
     }
-    else
+    else if (size > offset)
     {
         size -= offset;
-        memcpy(decrypted, tvb_get_ptr(tvb, 0, size) + offset, size);
+        tvb_memcpy(tvb, decrypted, offset, size);
         success = TRUE;
     }
+    else
+    {
+        success = FALSE;
+    }
 
     if (success)
     {
