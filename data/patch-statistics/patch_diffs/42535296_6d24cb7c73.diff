From 96031f61b333e48bbcb86d308a4f9c27eedab498 Mon Sep 17 00:00:00 2001
From: Patrick Soquet <ps@moddable.tech>
Date: Thu, 9 May 2024 17:32:08 +0200
Subject: [PATCH] xst: -lc fix

---
 xs/sources/xsRun.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/xs/sources/xsRun.c b/xs/sources/xsRun.c
index f353090a21..dd5f063ed1 100644
--- a/xs/sources/xsRun.c
+++ b/xs/sources/xsRun.c
@@ -4149,7 +4149,7 @@ void fxRunID(txMachine* the, txSlot* generator, txInteger count)
 		mxCase(XS_CODE_EVAL)
 			offset = mxStack->value.integer;
 			slot = mxStack + 1 + offset + 4;
-			if (mxIsFunction(slot->value.reference) && (mxFunctionInstanceCode(slot->value.reference)->value.callback.address == mxFunctionInstanceCode(mxEvalFunction.value.reference)->value.callback.address)) {
+			if (mxIsReference(slot) && mxIsFunction(slot->value.reference) && (mxFunctionInstanceCode(slot->value.reference)->value.callback.address == mxFunctionInstanceCode(mxEvalFunction.value.reference)->value.callback.address)) {
 				mxSaveState;
 				gxDefaults.runEval(the);
 				mxRestoreState;
@@ -4162,7 +4162,7 @@ void fxRunID(txMachine* the, txSlot* generator, txInteger count)
 		mxCase(XS_CODE_EVAL_TAIL)
 			offset = mxStack->value.integer;
 			slot = mxStack + 1 + offset + 4;
-			if (mxIsFunction(slot->value.reference) && (mxFunctionInstanceCode(slot->value.reference)->value.callback.address == mxFunctionInstanceCode(mxEvalFunction.value.reference)->value.callback.address)) {
+			if (mxIsReference(slot) && mxIsFunction(slot->value.reference) && (mxFunctionInstanceCode(slot->value.reference)->value.callback.address == mxFunctionInstanceCode(mxEvalFunction.value.reference)->value.callback.address)) {
 				mxSaveState;
 				gxDefaults.runEval(the);
 				mxRestoreState;
