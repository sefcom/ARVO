From 25c2f47d444f60e7aeadd3a6dacd2ace82f22fb4 Mon Sep 17 00:00:00 2001
From: Stefan Profanter <git@s.profanter.me>
Date: Wed, 16 Oct 2019 12:44:49 +0200
Subject: [PATCH] fix: stack-buffer-overflow

Fixes: https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=18261
Credit to oss-fuzz
---
 libmdnsd/1035.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/libmdnsd/1035.c b/libmdnsd/1035.c
index 5fb5b43..667af0b 100644
--- a/libmdnsd/1035.c
+++ b/libmdnsd/1035.c
@@ -174,6 +174,10 @@ static bool _label(struct message *m, const unsigned char **bufp, const unsigned
 
 	} while (*bufp <= bufEnd);
 
+    if ((unsigned char*)name >= m->_packet + MAX_PACKET_LEN) {
+        return false;
+    }
+
 	/* Terminate name and check for cache or cache it */
 	*name = '\0';
 	for (x = 0; x < MAX_NUM_LABELS && m->_labels[x]; x++) {
