          std::size_t device_begin_byte_offset,
          std::size_t num_bytes);
 
@@ -128,7 +128,7 @@ class PCL_EXPORTS DeviceMemory {
    * \param num_bytes number of bytes to download
    * */
   bool
-  download(void* host_ptr,
+  download(void* host_ptr_arg,
