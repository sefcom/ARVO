From: Alex Tutubalin <lexa@lexa.ru>
Date: Sun, 31 Mar 2024 20:44:17 +0300
Subject: [PATCH] Check for negatife offset checked_buffer_t

---
 src/utils/utils_libraw.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/utils/utils_libraw.cpp b/src/utils/utils_libraw.cpp
index dc81d0dd3..7c6e57d85 100644
--- a/src/utils/utils_libraw.cpp
+++ b/src/utils/utils_libraw.cpp
@@ -690,7 +690,7 @@ ushort checked_buffer_t::sget2(int offset)
 }
 void checked_buffer_t::checkoffset(int off)
 {
-  if (off >= _len)
+  if (off >= _len || off < 0)
     throw LIBRAW_EXCEPTION_IO_EOF;
 }
 unsigned char checked_buffer_t::operator[](int idx)
