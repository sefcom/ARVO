+static void js_dump_char(JSPrintValueState *s, int c, int sep)
+{
+    if (c == sep || c == '\\') {
+        js_putc(s, '\\');
+        js_putc(s, c);
+    } else if (c >= ' ' && c <= 126) {
+        js_putc(s, c);
+    } else if (c == '\n') {
+        js_putc(s, '\\');
+        js_putc(s, 'n');
+    } else {
+        js_printf(s, "\\u%04x", c);
+    }
+}
