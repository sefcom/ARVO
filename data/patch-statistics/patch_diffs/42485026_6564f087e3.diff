From 783166046299490f1ebd9bdb3d277d06a5b04839 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Fri, 23 Jun 2017 02:10:39 +0000
Subject: [PATCH] BLX: fix heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2354. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39235 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/blx/blx.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/gdal/frmts/blx/blx.c b/gdal/frmts/blx/blx.c
index 2187a6ba1c15..877cf223e686 100644
--- a/gdal/frmts/blx/blx.c
+++ b/gdal/frmts/blx/blx.c
@@ -759,6 +759,12 @@ STATIC blxdata *decode_celldata(blxcontext_t *ctx, unsigned char *inbuf, int len
 		for(i=0; i<n-1; i++)
 		    linfo[level][c].lut[i] = (blxdata)get_short_le(&inptr);
 		linfo[level][c].dlen = get_short_le(&inptr);
+                if( linfo[level][c].dlen < 0 )
+                {
+                    BLXerror0("Cell corrupt");
+                    outbuf = NULL;
+                    goto error;
+                }
                 len -= sizeof(short) * n;
 	    } else {
 		linfo[level][c].dlen = 0;
