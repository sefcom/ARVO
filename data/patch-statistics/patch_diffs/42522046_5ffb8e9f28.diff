From bacfaf34ce3140124da5a6172d2103fe0475437c Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Thu, 25 Jan 2018 21:20:59 +0000
Subject: [PATCH] grib / g2clib: fix heap buffer read overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=5687. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41335 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/degrib/g2clib/dec_png.c | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/gdal/frmts/grib/degrib/g2clib/dec_png.c b/gdal/frmts/grib/degrib/g2clib/dec_png.c
index e74d92b56220..da6f218a4908 100644
--- a/gdal/frmts/grib/degrib/g2clib/dec_png.c
+++ b/gdal/frmts/grib/degrib/g2clib/dec_png.c
@@ -35,12 +35,14 @@ void user_read_data(png_structp png_ptr,png_bytep data, png_uint_32 length)
         if (psSetJmpContext)
             longjmp( *psSetJmpContext, 1 );
      }
-
-     ptr=(void *)mem->stream_ptr;
-     offset=mem->stream_len;
-/*     printf("SAGrd %ld %ld %x\n",offset,length,ptr);  */
-     memcpy(data,ptr+offset,length);
-     mem->stream_len += length;
+     else
+     {
+        ptr=(void *)mem->stream_ptr;
+        offset=mem->stream_len;
+    /*     printf("SAGrd %ld %ld %x\n",offset,length,ptr);  */
+        memcpy(data,ptr+offset,length);
+        mem->stream_len += length;
+     }
 }
 
 
