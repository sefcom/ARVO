From 11c16327b1200815413f65533a879f63feeab81c Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Tue, 6 Feb 2018 12:11:09 +0000
Subject: [PATCH] Internal libgeotiff: resync with SVN upstream. reject files
 where the GTIFF_DOUBLEPARAMS tags has more than MAX_VALUES=1000 values to
 avoid potential out-of-bounds read overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=6035. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41417 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/gtiff/libgeotiff/geo_new.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/frmts/gtiff/libgeotiff/geo_new.c b/gdal/frmts/gtiff/libgeotiff/geo_new.c
index a7d4e629ef9f..3183f7e1c74f 100644
--- a/gdal/frmts/gtiff/libgeotiff/geo_new.c
+++ b/gdal/frmts/gtiff/libgeotiff/geo_new.c
@@ -178,6 +178,8 @@ GTIF* GTIFNewWithMethodsEx(void *tif, TIFFMethod* methods,
     }
     else
     {
+        if( gt->gt_ndoubles > MAX_VALUES )
+            goto failure;
         /* resize data array so it can be extended if needed */
         gt->gt_double = (double*) _GTIFrealloc(gt->gt_double,
                                                (MAX_VALUES)*sizeof(double));
