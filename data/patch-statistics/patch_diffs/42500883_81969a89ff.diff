From 30897e8e3614ba8a7f2cd1d79a7020ba50a9a463 Mon Sep 17 00:00:00 2001
From: Lovell Fuller <lovell@users.noreply.github.com>
Date: Sun, 29 Aug 2021 20:15:24 +0100
Subject: [PATCH] Handle error values when guessing interpretation (#2421)

---
 libvips/iofuncs/header.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/libvips/iofuncs/header.c b/libvips/iofuncs/header.c
index 73246b69ab..97d3f9e677 100644
--- a/libvips/iofuncs/header.c
+++ b/libvips/iofuncs/header.c
@@ -578,6 +578,10 @@ vips_image_guess_interpretation( const VipsImage *image )
 	/* Coding overrides interpretation.
 	 */
 	switch( image->Coding ) {
+	case VIPS_CODING_ERROR:
+		sane = FALSE;
+		break;
+
 	case VIPS_CODING_LABQ:
 		if( image->Type != VIPS_INTERPRETATION_LABQ )
 			sane = FALSE;
@@ -593,6 +597,10 @@ vips_image_guess_interpretation( const VipsImage *image )
 	}
 
 	switch( image->Type ) {
+	case VIPS_INTERPRETATION_ERROR:
+		sane = FALSE;
+		break;
+
 	case VIPS_INTERPRETATION_MULTIBAND: 
 		/* This is a pretty useless generic tag. Always reset it.
 		 */
