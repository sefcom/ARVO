From 6fd0c14775db5d10563f8b0401ee9f3f6bd29310 Mon Sep 17 00:00:00 2001
From: Chris Liddell <chris.liddell@artifex.com>
Date: Tue, 5 Jul 2022 12:56:22 +0100
Subject: oss-fuzz 48745: Don't free font data unless FAPI owns it.

---
 base/fapi_ft.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/base/fapi_ft.c b/base/fapi_ft.c
index 1d04bb309..267d57df4 100644
--- a/base/fapi_ft.c
+++ b/base/fapi_ft.c
@@ -1332,7 +1332,8 @@ gs_fapi_ft_get_scaled_font(gs_fapi_server * a_server, gs_fapi_font * a_font,
                              &ft_face);
             if (ft_error) {
                 delete_inc_int (a_server, ft_inc_int);
-                FF_free(s->ftmemory, own_font_data);
+                if (data_owned)
+                    FF_free(s->ftmemory, own_font_data);
                 return ft_to_gs_error(ft_error);
             }
         }
