diff --git a/src/core/SkSafeRange.h b/src/core/SkSafeRange.h
index c640ffd..ef068c2 100644
--- a/src/core/SkSafeRange.h
+++ b/src/core/SkSafeRange.h
@@ -30,6 +30,14 @@
         return static_cast<T>(value);
     }
 
+    int checkGE(int value, int min) {
+        if (value < min) {
+            fOK = false;
+            value = min;
+        }
+        return value;
+    }
+
 private:
     bool fOK = true;
 };
