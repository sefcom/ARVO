 {
@@ -5944,6 +6002,11 @@ encode_preR13_header_variables (Bit_Chain *dat, Dwg_Data *restrict dwg)
   Bit_Chain *hdl_dat = dat;
   int error = 0;
 
+  // PRE (R_13b1)
