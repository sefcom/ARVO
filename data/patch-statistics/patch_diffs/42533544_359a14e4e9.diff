From ef235a4f081aeecfcba63a2a458b7730fc2c9ba7 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sun, 4 Mar 2018 09:40:44 +0000
Subject: [PATCH] AVC00: fix read heap buffer overflow. Fixes
 https://oss-fuzz.com/v2/testcase-detail/4813217936179200. Credit to OSS Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41625 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/ogr/ogrsf_frmts/avc/avc_e00parse.cpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gdal/ogr/ogrsf_frmts/avc/avc_e00parse.cpp b/gdal/ogr/ogrsf_frmts/avc/avc_e00parse.cpp
index e4bc3c115dd8..74c830d8867f 100644
--- a/gdal/ogr/ogrsf_frmts/avc/avc_e00parse.cpp
+++ b/gdal/ogr/ogrsf_frmts/avc/avc_e00parse.cpp
@@ -1469,7 +1469,8 @@ AVCTxt   *AVCE00ParseNextTxtLine(AVCE00ParseInfo *psInfo, const char *pszLine)
         }
         iCurCoord = psInfo->iCurItem * numCoordPerLine;
 
-        for(i=0; i<numCoordPerLine; i++, iCurCoord++)
+        for(i=0; i<numCoordPerLine &&
+                 nLen > static_cast<size_t>(i) * nItemSize; i++, iCurCoord++)
         {
             if (iCurCoord < 4 &&
                 (iVertex = iCurCoord % 4) < psTxt->numVerticesLine-1)
