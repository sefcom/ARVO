 #define public MagickPackageVersion "1.4"
-#define public MagickPackageVersionAddendum ".020201127"
-#define public MagickPackageReleaseDate "snapshot-20201127"
+#define public MagickPackageVersionAddendum ".020201128"
+#define public MagickPackageReleaseDate "snapshot-20201128"
diff --git a/magick/version.h b/magick/version.h
--- a/magick/version.h
+++ b/magick/version.h
@@ -38,8 +38,8 @@
 #define MagickLibVersion  0x242100
 #define MagickLibVersionText  "1.4"
 #define MagickLibVersionNumber 24,21,0
-#define MagickChangeDate   "20201127"
-#define MagickReleaseDate  "snapshot-20201127"
