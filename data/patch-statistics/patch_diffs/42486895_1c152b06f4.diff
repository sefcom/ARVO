From 55eb5c73e5fb609ba56dee28f74e53b2be28fbb7 Mon Sep 17 00:00:00 2001
From: Albert Astals Cid <aacid@kde.org>
Date: Wed, 26 Aug 2020 22:37:31 +0200
Subject: [PATCH] BaseMemStream::getChars: If we're past the end do nothing

---
 poppler/Stream.h | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/poppler/Stream.h b/poppler/Stream.h
index 245f0ab70..5d9ad0c9c 100644
--- a/poppler/Stream.h
+++ b/poppler/Stream.h
@@ -694,7 +694,10 @@ private:
     {
         int n;
 
-        if (nChars <= 0) {
+        if (unlikely(nChars <= 0)) {
+            return 0;
+        }
+        if (unlikely(bufPtr >= bufEnd)) {
             return 0;
         }
         if (bufEnd - bufPtr < nChars) {
