From 6c581e1a63084b13ba0c00a7e985390b15428a38 Mon Sep 17 00:00:00 2001
From: Ivan Nardi <nardi.ivan@gmail.com>
Date: Sat, 19 Jul 2025 16:16:22 +0200
Subject: [PATCH] Fix heap-buffer-overflow

```
ivan@ivan-Precision-3591:~/svnrepos/nDPI(dev)$ ./example/ndpiReader -t -i ./tests/pcap/http_origin_different_than_host.pcap
[...]
=================================================================
==37613==ERROR: AddressSanitizer: heap-buffer-overflow on address 0x7ca7205f02cd at pc 0x5f5ea6d8f68c bp 0x7b371e2f2fc0 sp 0x7b371e2f2748
READ of size 258 at 0x7ca7205f02cd thread T1
    #0 0x5f5ea6d8f68b in printf_common(void*, char const*, __va_list_tag*) build-llvm/tools/clang/stage2-bins/runtimes/runtimes-bins/compiler-rt/lib/asan/../sanitizer_common/sanitizer_common_interceptors_format.inc:563:9
    #1 0x5f5ea6d8fa05 in vsnprintf build-llvm/tools/clang/stage2-bins/runtimes/runtimes-bins/compiler-rt/lib/asan/../sanitizer_common/sanitizer_common_interceptors.inc:1707:1
    #2 0x5f5ea6d914e1 in snprintf build-llvm/tools/clang/stage2-bins/runtimes/runtimes-bins/compiler-rt/lib/asan/../sanitizer_common/sanitizer_common_interceptors.inc:1778:1
    #3 0x5f5ea71edb95 in ndpi_match_host_subprotocol /home/ivan/svnrepos/nDPI/src/lib/ndpi_main.c:11450:3
    #4 0x5f5ea734e964 in ndpi_http_parse_subprotocol /home/ivan/svnrepos/nDPI/src/lib/protocols/http.c:574:9
    #5 0x5f5ea7340013 in check_content_type_and_change_protocol /home/ivan/svnrepos/nDPI/src/lib/protocols/http.c:1226:3
    #6 0x5f5ea7335f8b in process_request /home/ivan/svnrepos/nDPI/src/lib/protocols/http.c:1584:3
    #7 0x5f5ea73311cd in ndpi_check_http_tcp /home/ivan/svnrepos/nDPI/src/lib/protocols/http.c:1718:5
```
---
 src/lib/ndpi_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/lib/ndpi_main.c b/src/lib/ndpi_main.c
index 0c0ab0599e4..49df7e174e2 100644
--- a/src/lib/ndpi_main.c
+++ b/src/lib/ndpi_main.c
@@ -11447,7 +11447,7 @@ u_int16_t ndpi_match_host_subprotocol(struct ndpi_detection_module_struct *ndpi_
 
   if(!ndpi_str) return(-1);
 
-  snprintf(buf, sizeof(buf), "%*s", _string_to_match_len, _string_to_match);
+  snprintf(buf, sizeof(buf), "%.*s", _string_to_match_len, _string_to_match);
   string_to_match = (char*)ndpi_get_host_domain(ndpi_str, buf);
   string_to_match_len = strlen(string_to_match);
 
