From 7e2bd95fa5fb903bc0e125f4bbb21b93f3de2398 Mon Sep 17 00:00:00 2001
From: Remi Collet <remi@php.net>
Date: Wed, 22 Jan 2020 09:17:00 +0100
Subject: [PATCH] next will be 7.2.28

---
 NEWS               | 5 ++++-
 configure.ac       | 2 +-
 main/php_version.h | 6 +++---
 3 files changed, 8 insertions(+), 5 deletions(-)

diff --git a/NEWS b/NEWS
index 2d9703be3099c..a38b23225d1f1 100644
--- a/NEWS
+++ b/NEWS
@@ -1,6 +1,9 @@
 PHP                                                                        NEWS
 |||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||
-?? ??? 2019, PHP 7.2.27
+?? ??? 2020, PHP 7.2.28
+
+
+23 Jan 2020, PHP 7.2.27
 
 - Mbstring:
   . Fixed bug #79037 (global buffer-overflow in `mbfl_filt_conv_big5_wchar`). 
diff --git a/configure.ac b/configure.ac
index 5ac924e484ff0..478a4cbf3b0f4 100644
--- a/configure.ac
+++ b/configure.ac
@@ -107,7 +107,7 @@ int zend_sprintf(char *buffer, const char *format, ...);
 
 PHP_MAJOR_VERSION=7
 PHP_MINOR_VERSION=2
-PHP_RELEASE_VERSION=27
+PHP_RELEASE_VERSION=28
 PHP_EXTRA_VERSION="-dev"
 PHP_VERSION="$PHP_MAJOR_VERSION.$PHP_MINOR_VERSION.$PHP_RELEASE_VERSION$PHP_EXTRA_VERSION"
 PHP_VERSION_ID=`expr [$]PHP_MAJOR_VERSION \* 10000 + [$]PHP_MINOR_VERSION \* 100 + [$]PHP_RELEASE_VERSION`
diff --git a/main/php_version.h b/main/php_version.h
index fde315fa5c380..e10723c26059e 100644
--- a/main/php_version.h
+++ b/main/php_version.h
@@ -2,7 +2,7 @@
 /* edit configure.ac to change version number */
 #define PHP_MAJOR_VERSION 7
 #define PHP_MINOR_VERSION 2
-#define PHP_RELEASE_VERSION 27
+#define PHP_RELEASE_VERSION 28
 #define PHP_EXTRA_VERSION "-dev"
-#define PHP_VERSION "7.2.27-dev"
-#define PHP_VERSION_ID 70227
+#define PHP_VERSION "7.2.28-dev"
+#define PHP_VERSION_ID 70228
