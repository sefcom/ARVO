From c10df533f658e068cfcadbf400c65b9dd579040a Mon Sep 17 00:00:00 2001
From: pancake <pancake@nopcode.org>
Date: Thu, 9 May 2019 11:51:50 +0200
Subject: [PATCH] Fix ASAN crash (1byte oobread in dex)

---
 libr/bin/p/bin_dex.c | 1 +
 libr/core/cmd.c      | 5 ++---
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/libr/bin/p/bin_dex.c b/libr/bin/p/bin_dex.c
index 6b1521e90d71c..715d42f2818cc 100644
--- a/libr/bin/p/bin_dex.c
+++ b/libr/bin/p/bin_dex.c
@@ -65,6 +65,7 @@ static char *getstr(RBinDexObj *bin, int idx) {
 		return NULL;
 	}
 	r_buf_read_at (bin->b, bin->strings[idx] + uleblen, ptr, len + 1);
+	ptr[len] = 0;
 	if (len != r_utf8_strlen (ptr)) {
 		// eprintf ("WARNING: Invalid string for index %d\n", idx);
 		return NULL;
diff --git a/libr/core/cmd.c b/libr/core/cmd.c
index 92e675129b72c..d61b15c3c7b2f 100644
--- a/libr/core/cmd.c
+++ b/libr/core/cmd.c
@@ -1275,9 +1275,8 @@ static int cmd_kuery(void *data, const char *input) {
 			eprintf ("Usage: kd [file] [namespace]\n");
 		}
 		break;
-	case '?': {
-			r_core_cmd_help (core, help_msg_k);
-		}
+	case '?':
+		r_core_cmd_help (core, help_msg_k);
 		break;
 	}
 
