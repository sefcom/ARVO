From 4605fef51a235baf940ea56db71c60e0389fe01e Mon Sep 17 00:00:00 2001
From: Daniel Lemire <dlemire@lemire.me>
Date: Fri, 16 Aug 2024 16:38:05 -0400
Subject: [PATCH] fix issue issue_ossfuzz_71218

---
 src/haswell/avx2_convert_utf8_to_utf16.cpp | 6 +++---
 src/westmere/sse_convert_utf8_to_utf16.cpp | 9 +++++----
 2 files changed, 8 insertions(+), 7 deletions(-)

diff --git a/src/haswell/avx2_convert_utf8_to_utf16.cpp b/src/haswell/avx2_convert_utf8_to_utf16.cpp
index 72704536d..e7edcffc4 100644
--- a/src/haswell/avx2_convert_utf8_to_utf16.cpp
+++ b/src/haswell/avx2_convert_utf8_to_utf16.cpp
@@ -23,7 +23,7 @@ size_t convert_masked_utf8_to_utf16(const char *input,
   const __m128i in = _mm_loadu_si128((__m128i *)input);
   const uint16_t input_utf8_end_of_code_point_mask =
       utf8_end_of_code_point_mask & 0xfff;
-  if(((utf8_end_of_code_point_mask & 0xffff) == 0xffff)) {
+  if((utf8_end_of_code_point_mask  == 0xfff)) {
     // We process the data in chunks of 16 bytes.
     __m256i ascii = _mm256_cvtepu8_epi16(in);
     if (big_endian) {
@@ -32,8 +32,8 @@ size_t convert_masked_utf8_to_utf16(const char *input,
       ascii = _mm256_shuffle_epi8(ascii, swap256);
     }
     _mm256_storeu_si256(reinterpret_cast<__m256i *>(utf16_output), ascii);
-    utf16_output += 16; // We wrote 16 16-bit characters.
-    return 16; // We consumed 16 bytes.
+    utf16_output += 12; // We wrote 16 16-bit characters.
+    return 12; // We consumed 16 bytes.
   }
   if(((utf8_end_of_code_point_mask & 0xffff) == 0xaaaa)) {
     // We want to take 8 2-byte UTF-8 code units and turn them into 8 2-byte UTF-16 code units.
diff --git a/src/westmere/sse_convert_utf8_to_utf16.cpp b/src/westmere/sse_convert_utf8_to_utf16.cpp
index 7fe81f32f..848eae766 100644
--- a/src/westmere/sse_convert_utf8_to_utf16.cpp
+++ b/src/westmere/sse_convert_utf8_to_utf16.cpp
@@ -23,8 +23,9 @@ size_t convert_masked_utf8_to_utf16(const char *input,
   const __m128i in = _mm_loadu_si128((__m128i *)input);
   const uint16_t input_utf8_end_of_code_point_mask =
       utf8_end_of_code_point_mask & 0xfff;
-  if(((utf8_end_of_code_point_mask & 0xffff) == 0xffff)) {
-    // We process the data in chunks of 16 bytes.
+  if((utf8_end_of_code_point_mask == 0xfff)) {
+    // We process the data in chunks of 12 bytes.
+    // Note: using 16 bytes is unsafe, see issue_ossfuzz_71218
     __m128i ascii_first = _mm_cvtepu8_epi16(in);
     __m128i ascii_second = _mm_cvtepu8_epi16(_mm_srli_si128(in,8));
     if (big_endian) {
@@ -33,8 +34,8 @@ size_t convert_masked_utf8_to_utf16(const char *input,
     }
     _mm_storeu_si128(reinterpret_cast<__m128i *>(utf16_output), ascii_first);
     _mm_storeu_si128(reinterpret_cast<__m128i *>(utf16_output + 8), ascii_second);
-    utf16_output += 16; // We wrote 16 16-bit characters.
-    return 16; // We consumed 16 bytes.
+    utf16_output += 12; // We wrote 12 16-bit characters.
+    return 12; // We consumed 12 bytes.
   }
   if(((utf8_end_of_code_point_mask & 0xFFFF) == 0xaaaa)) {
     // We want to take 8 2-byte UTF-8 code units and turn them into 8 2-byte UTF-16 code units.
