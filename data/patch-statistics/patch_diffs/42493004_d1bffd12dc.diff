From 4a47e20ed5cb1165810df1d0230687d11663aa4a Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Thu, 17 Aug 2017 08:38:54 +0000
Subject: [PATCH] GRIB / degrib: fix read heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=3072. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39844 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/degrib18/degrib/degrib1.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gdal/frmts/grib/degrib18/degrib/degrib1.cpp b/gdal/frmts/grib/degrib18/degrib/degrib1.cpp
index 9791b9ac3d4d..ffe0bd212d78 100644
--- a/gdal/frmts/grib/degrib18/degrib/degrib1.cpp
+++ b/gdal/frmts/grib/degrib18/degrib/degrib1.cpp
@@ -813,7 +813,7 @@ static int ReadGrib1Sect2 (uChar *gds, uInt4 gribLen, uInt4 *curLoc,
    int f_allOne;        /* Used to find out if the "lat/lon" extension part
                          * is all 1 hence missing. */
 
-   if( gribLen - *curLoc < 3 ) {
+   if( gribLen - *curLoc < 6 ) {
       errSprintf ("Ran out of data in GDS (GRIB 1 Section 2)\n");
       return -1;
    }
