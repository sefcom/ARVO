From c680daae6ad6bdcaf5b868a48e3f1ecaeb6b5cd2 Mon Sep 17 00:00:00 2001
From: Douglas Bagnall <douglas.bagnall@catalyst.net.nz>
Date: Tue, 10 Mar 2020 11:31:12 +1300
Subject: [PATCH] idl/drsblobs: do not overwrite number of schedules == 1

If the struct has zero or two schedules, that is what it has, and we
should let that be.

Signed-off-by: Douglas Bagnall <douglas.bagnall@catalyst.net.nz>
Reviewed-by: Andrew Bartlett <abartlet@samba.org>

Autobuild-User(master): Andrew Bartlett <abartlet@samba.org>
Autobuild-Date(master): Sun Mar 22 06:19:51 UTC 2020 on sn-devel-184
---
 librpc/idl/drsblobs.idl | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/librpc/idl/drsblobs.idl b/librpc/idl/drsblobs.idl
index b096b671c80..8e66042c407 100644
--- a/librpc/idl/drsblobs.idl
+++ b/librpc/idl/drsblobs.idl
@@ -157,7 +157,7 @@ interface drsblobs {
         typedef [public] struct {
 		uint32             size;
 		[value(0)] uint32  bandwidth;         /* ignored */
-		[value(1)] uint32  numberOfSchedules; /* always 1 */
+		uint32             numberOfSchedules; /* typically 1 */
 		scheduleHeader     headerArray[numberOfSchedules];
 		scheduleSlots      dataArray[numberOfSchedules];
 	} schedule;
