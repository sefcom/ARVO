From e95b4f1815c6e70a92953d464eab30c8457a9ad8 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Mon, 12 Feb 2024 11:50:17 +0100
Subject: [PATCH] fix string reading overflow in mpgviddmx

ossfuzz issue 66359
---
 src/filters/reframe_mpgvid.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/filters/reframe_mpgvid.c b/src/filters/reframe_mpgvid.c
index 246ca8abf8..59a8097cc7 100644
--- a/src/filters/reframe_mpgvid.c
+++ b/src/filters/reframe_mpgvid.c
@@ -427,7 +427,7 @@ static void mpgviddmx_check_pid(GF_Filter *filter, GF_MPGVidDmxCtx *ctx, u32 vos
 			char *frame = dcfg;
 			while ((i+3<vosh_size)  && ((frame[i]!=0) || (frame[i+1]!=0) || (frame[i+2]!=1))) i++;
 			if (i+4>=vosh_size) break;
-			if (strncmp(frame+i+4, "DivX", 4)) {
+			if (i+8 < vosh_size && strncmp(frame+i+4, "DivX", 4)) {
 				i += 4;
 				continue;
 			}
