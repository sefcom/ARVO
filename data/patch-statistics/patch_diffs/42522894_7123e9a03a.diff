From: Daniel Lemire <daniel@lemire.me>
Date: Sun, 2 Apr 2023 19:34:19 -0400
Subject: [PATCH] Adding some tests + marking impossible inputs in UTF-8 cases
 with error code 209 (for safety)

---
 scripts/sse_utf8_utf16_decode.py  |    2 +-
 src/tables/utf8_to_utf16_tables.h | 1442 ++++++++++++++---------------
 tests/special_tests.cpp           |   81 +-
 3 files changed, 794 insertions(+), 731 deletions(-)

diff --git a/scripts/sse_utf8_utf16_decode.py b/scripts/sse_utf8_utf16_decode.py
index 7d7f64921..531603c9e 100644
--- a/scripts/sse_utf8_utf16_decode.py
+++ b/scripts/sse_utf8_utf16_decode.py
@@ -177,7 +177,7 @@ def main():
         arrg.append((idx,s))
     else:
         # we are in error, use a bogus index
-        arrg.append((0,12))
+        arrg.append((209,12))
   print("const uint8_t utf8bigindex["+str(len(arrg))+"][2] = ")
   print(cpp_arrayarray_initializer(arrg), end=";\n")
 
