From ff4109735fb20754a91e07fe2fbaac59a764697b Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Mon, 19 May 2025 17:17:24 +0900
Subject: [PATCH] range.c (range_num_to_a): improved float support

---
 src/range.c | 16 ++++------------
 1 file changed, 4 insertions(+), 12 deletions(-)

diff --git a/src/range.c b/src/range.c
index 5473227944..b18ec47d1e 100644
--- a/src/range.c
+++ b/src/range.c
@@ -388,20 +388,12 @@ range_num_to_a(mrb_state *mrb, mrb_value range)
       if (a > b) {
         return mrb_ary_new_capa(mrb, 0);
       }
-      mrb_int alen = (mrb_int)(b - a) + 1;
+      mrb_int alen = (mrb_int)(b - a) + RANGE_EXCL(r);
       ary = mrb_ary_new_capa(mrb, alen);
       mrb_value *ptr = RARRAY_PTR(ary);
-      if (RANGE_EXCL(r)) {
-        for (mrb_int i=0; a<b; a++) {
-          ptr[i++] = mrb_int_value(mrb, a);
-          ARY_SET_LEN(RARRAY(ary), i);
-        }
-      }
-      else {
-        for (mrb_int i=0; a<=b; a++) {
-          ptr[i++] = mrb_int_value(mrb, a);
-          ARY_SET_LEN(RARRAY(ary), i);
-        }
+      for (mrb_int i=0; i<alen; i++) {
+        ptr[i] = mrb_int_value(mrb, a+i);
+        ARY_SET_LEN(RARRAY(ary), i);
       }
       return ary;
     }
