From e8892c59a4d413d747644cec8f1e6d29ec22f733 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Tim=20R=C3=BChsen?= <tim.ruehsen@gmx.de>
Date: Tue, 31 Oct 2017 18:33:40 +0100
Subject: [PATCH] Fix buffer overflow in option parser

* src/options.c (_parse_option): Add end-of-string check

Found by oss-fuzz (issue 3950).
Bug existed since a long time.
---
 src/options.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/options.c b/src/options.c
index 8595bac2b..7066096df 100644
--- a/src/options.c
+++ b/src/options.c
@@ -2030,7 +2030,7 @@ static int _parse_option(char *linep, char **name, char **val)
 			char *src = linep + 1, *dst = linep, c;
 
 			while ((c = *src) != quote && c) {
-				if (c == '\\') {
+				if (c == '\\' && src[1]) {
 					// we could extend \r, \n etc to control codes here
 					// but it is not needed so far
 					*dst++ = src[1];
