From 919122e86f9568b98f360b93a176733629efad5a Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Mon, 2 Apr 2018 11:58:36 +0200
Subject: [PATCH] CPLUnescapeString(,,CPLES_BackslashQuotable): fix index out
 of bound read. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=7283. Credit to OSS
 Fuzz

---
 gdal/port/cpl_string.cpp | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/port/cpl_string.cpp b/gdal/port/cpl_string.cpp
index e10f667e5d99..f09358355f15 100644
--- a/gdal/port/cpl_string.cpp
+++ b/gdal/port/cpl_string.cpp
@@ -2253,6 +2253,8 @@ char *CPLUnescapeString( const char *pszInput, int *pnLength, int nScheme )
             if( pszInput[iIn] == '\\' )
             {
                 ++iIn;
+                if( pszInput[iIn] == '\0' )
+                    break;
                 if( pszInput[iIn] == 'n' )
                     pszOutput[iOut++] = '\n';
                 else if( pszInput[iIn] == '0' )
