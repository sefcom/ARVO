From 4706a732b50e9d2095bf6bc03331719f358c2cc9 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Tue, 28 Nov 2017 09:40:19 +0000
Subject: [PATCH] DXF: fix out-of-bounds read in ACTextUnescape(). Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=4466 (and a similar
 issue at another location). Credit to OSS Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@40867 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/ogr/ogrsf_frmts/dxf/ogr_autocad_services.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/gdal/ogr/ogrsf_frmts/dxf/ogr_autocad_services.cpp b/gdal/ogr/ogrsf_frmts/dxf/ogr_autocad_services.cpp
index 5bbfd2b73c5f..d27284536d8d 100644
--- a/gdal/ogr/ogrsf_frmts/dxf/ogr_autocad_services.cpp
+++ b/gdal/ogr/ogrsf_frmts/dxf/ogr_autocad_services.cpp
@@ -191,6 +191,8 @@ CPLString ACTextUnescape( const char *pszRawInput, const char *pszEncoding,
                 {
                     osMtextResult += pszInput[1];
                     pszInput++;
+                    if( pszInput[0] == '\0' )
+                        break;
                 }
                 else if( strchr( "^/#~", pszInput[0] ) == NULL )
                 {
@@ -210,6 +212,8 @@ CPLString ACTextUnescape( const char *pszRawInput, const char *pszEncoding,
 
             osMtextResult += pszInput[1];
             pszInput++;
+            if( pszInput[0] == '\0' )
+                break;
         }
         else
         {
