From 28eed15348e2e57cbd3d94afc35ad5c6d12efc7e Mon Sep 17 00:00:00 2001
From: Stefan Profanter <git@s.profanter.me>
Date: Thu, 26 Oct 2017 09:21:43 +0200
Subject: [PATCH] Add six dependency

---
 Dockerfile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Dockerfile b/Dockerfile
index f2a2d0f03aa..bb1f5e364bd 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,5 +1,5 @@
 FROM alpine:3.5
-RUN apk add --no-cache cmake gcc g++ musl-dev python py-pip make && rm -rf /var/cache/apk/*
+RUN apk add --no-cache cmake gcc g++ musl-dev python py-pip python-six make && rm -rf /var/cache/apk/*
 ADD . /tmp/open62541
 WORKDIR /tmp/open62541/build
 RUN pip install six
