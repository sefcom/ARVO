From 0eaeabba5aa7df2e85692ae914c7b1d9379496d9 Mon Sep 17 00:00:00 2001
From: Alfredo Cardigliano <cardigliano@ntop.org>
Date: Thu, 31 Aug 2023 16:58:57 +0200
Subject: [PATCH] Add post_params parameter to get_component_data to support
 POST requests. Pass csrf to components.

---
 http_src/vue/page-dashboard.vue | 14 ++++++++++----
 http_src/vue/timeseries.vue     |  3 ++-
 2 files changed, 12 insertions(+), 5 deletions(-)

diff --git a/http_src/vue/page-dashboard.vue b/http_src/vue/page-dashboard.vue
index 4fbd97fa4932..f456c896027e 100644
--- a/http_src/vue/page-dashboard.vue
+++ b/http_src/vue/page-dashboard.vue
@@ -77,7 +77,8 @@
                      :max_width="c.width"
                      :max_height="c.height"
                      :params="c.params"
-                     :get_component_data="get_component_data_func(c)">
+                     :get_component_data="get_component_data_func(c)"
+                     :csrf="context.csrf">
           </component>
         </template>
         <template v-slot:box_footer>
@@ -390,7 +391,7 @@ function print_report() {
 
 /* Callback to request REST data from components */
 function get_component_data_func(component) {
-    const get_component_data = async (url, url_params) => {
+    const get_component_data = async (url, url_params, post_params) => {
         
         let info = {};
 
@@ -407,7 +408,6 @@ function get_component_data_func(component) {
                 // console.log("-------------------------");
             }
         } else {
-            const data_url = `${url}?${url_params}`;
 
             /* Check if there is already a promise for the same request */
             if (components_info[component.component_id]) {
@@ -417,7 +417,13 @@ function get_component_data_func(component) {
                 }
             }
 
-            info.data = ntopng_utility.http_request(`${data_url}`);
+            const data_url = `${url}?${url_params}`;
+
+            if (post_params) {
+                info.data = ntopng_utility.http_post_request(data_url, post_params);
+            } else {
+                info.data = ntopng_utility.http_request(data_url);
+            }
         
             components_info[component.component_id] = info;
         }
diff --git a/http_src/vue/timeseries.vue b/http_src/vue/timeseries.vue
index 49756910ba9f..01852c484ce8 100644
--- a/http_src/vue/timeseries.vue
+++ b/http_src/vue/timeseries.vue
@@ -45,7 +45,8 @@ const props = defineProps({
   max_width: Number,   /* Component Width (4, 8, 12) */
   max_height: Number,  /* Component Hehght (4, 8, 12)*/
   params: Object,      /* Component-specific parameters from the JSON template definition */
-  get_component_data: Function /* TODO use thsi callback to request data (REST) */
+  get_component_data: Function, /* Callback to request data (REST) */
+  csrf: String
 });
 
 /* Return the base url of the REST API */
