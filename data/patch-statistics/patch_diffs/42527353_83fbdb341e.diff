From 1b58d00fecf24f42ec6e771496076ac1d752baaa Mon Sep 17 00:00:00 2001
From: Luca <deri@ntop.org>
Date: Mon, 21 Aug 2023 23:22:56 +0200
Subject: [PATCH] Boundary fix

---
 src/Flow.cpp | 4 ++--
 tests/e2e    | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/Flow.cpp b/src/Flow.cpp
index 5879ef37249d..968a1452cc83 100644
--- a/src/Flow.cpp
+++ b/src/Flow.cpp
@@ -6258,9 +6258,9 @@ void Flow::dissectNetBIOS(u_int8_t *payload, u_int16_t payload_len) {
   /* Already dissected ? */
   if (protos.netbios.name) return;
 
-  if (((payload[2] & 0x80) /* NetBIOS Response */ ||
+  if ((payload_len >= 12) &&
+      ((payload[2] & 0x80) /* NetBIOS Response */ ||
        ((payload[2] & 0x78) == 0x28 /* NetBIOS Registration */)) &&
-      (payload_len >= 12) &&
       (ndpi_netbios_name_interpret((u_char *)&payload[12], payload_len - 12,
                                    (u_char *)name, sizeof(name)) > 0) &&
       (!strstr(name, "__MSBROWSE__"))) {
diff --git a/tests/e2e b/tests/e2e
index 65356c07f394..3e0adfc90563 160000
--- a/tests/e2e
+++ b/tests/e2e
@@ -1 +1 @@
-Subproject commit 65356c07f394bbcbc4263b68e1f17377413de8bf
+Subproject commit 3e0adfc905634ae51d96cc0665c8641fdf67388d
