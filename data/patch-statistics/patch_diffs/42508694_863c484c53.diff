From 5e02a73b8b251d69e073c8c43f8fa50cff2beb84 Mon Sep 17 00:00:00 2001
From: Xiaotian Shi <38150686+xiaotiansf@users.noreply.github.com>
Date: Sun, 13 Mar 2022 23:02:21 -0700
Subject: [PATCH] fix Issue 44848 in oss-fuzz: openh264:decoder_fuzzer:
 Index-out-of-bounds in WelsDec::WelsInitRefList (#3499)

---
 codec/decoder/core/src/manage_dec_ref.cpp | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/codec/decoder/core/src/manage_dec_ref.cpp b/codec/decoder/core/src/manage_dec_ref.cpp
index 993c85cc80..7b50fe059d 100644
--- a/codec/decoder/core/src/manage_dec_ref.cpp
+++ b/codec/decoder/core/src/manage_dec_ref.cpp
@@ -886,7 +886,9 @@ static int32_t AddLongTermToList (PRefPic pRefPic, PPicture pPic, int32_t iLongT
     pRefPic->pLongRefList[LIST_0][i] = pPic;
   }
 
-  pRefPic->uiLongRefCount[LIST_0]++;
+  if (pRefPic->uiLongRefCount[LIST_0] < MAX_REF_PIC_COUNT) {
+    pRefPic->uiLongRefCount[LIST_0]++;
+  }
   return ERR_NONE;
 }
 
