From f6e762181df35bb081d8e776df6cbb6af4bd5939 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Tim=20R=C3=BChsen?= <tim.ruehsen@gmx.de>
Date: Sat, 1 Sep 2018 13:29:16 +0200
Subject: [PATCH] Fix buffer overflow in -X/-I parsing

* src/options.c (set_char_prefix): Fix scratch buffer size
* fuzz/wget_options_fuzzer.in/: Add reproducer

This bug was introduced yesterday by commit
756e470de942ec830a9a424a2340b7e986e9fe7c

Found by oss-fuzz (issue 10159).
---
 ...fuzz-testcase-minimized-wget_options_fuzzer-5704034783068160 | 1 +
 src/options.c                                                   | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)
 create mode 100644 fuzz/wget_options_fuzzer.in/clusterfuzz-testcase-minimized-wget_options_fuzzer-5704034783068160

diff --git a/fuzz/wget_options_fuzzer.in/clusterfuzz-testcase-minimized-wget_options_fuzzer-5704034783068160 b/fuzz/wget_options_fuzzer.in/clusterfuzz-testcase-minimized-wget_options_fuzzer-5704034783068160
new file mode 100644
index 000000000..a0bf0e5fb
--- /dev/null
+++ b/fuzz/wget_options_fuzzer.in/clusterfuzz-testcase-minimized-wget_options_fuzzer-5704034783068160
@@ -0,0 +1 @@
+includedirectories=,
\ No newline at end of file
diff --git a/src/options.c b/src/options.c
index 755e6a439..2b1fe3e08 100644
--- a/src/options.c
+++ b/src/options.c
@@ -469,7 +469,7 @@ static char *set_char_prefix(const char *val, char prefix)
 {
 	if (val && *val) {
 		// we just need a scratch buffer, no need for optimal size calculation
-		char *prefixed_val = wget_malloc(strlen(val) * 2 + 1), *dst = prefixed_val;
+		char *prefixed_val = wget_malloc(strlen(val) * 3 + 1), *dst = prefixed_val;
 
 		*dst++ = prefix;
 		for (const char *src = val; *src; src++) {
-- 
