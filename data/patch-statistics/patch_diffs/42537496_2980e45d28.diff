From 22c4e067973bd9fa63f9d6ffebe4be16b0cc34c0 Mon Sep 17 00:00:00 2001
From: Robin Watts <Robin.Watts@artifex.com>
Date: Mon, 21 Oct 2024 18:43:56 +0100
Subject: Bug 707914: Add some sanity checking for insane ctms to clist
 playback.

If the CTM is stupid, then reduce it to 0 size.
---
 base/gdevp14.c | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/base/gdevp14.c b/base/gdevp14.c
index cca0b7d0b..2ae843dc1 100644
--- a/base/gdevp14.c
+++ b/base/gdevp14.c
@@ -7024,6 +7024,15 @@ pdf14_compute_group_device_int_rect(const gs_matrix *ctm,
     rect->p.y = (int)floor(dev_bbox.p.y);
     rect->q.x = (int)ceil(dev_bbox.q.x);
     rect->q.y = (int)ceil(dev_bbox.q.y);
+    /* Sanity check rect for insane ctms */
+    if (rect->p.x < 0)
+        rect->p.x = 0;
+    if (rect->q.x < rect->p.x)
+        rect->q.x = rect->p.x;
+    if (rect->p.y < 0)
+        rect->p.y = 0;
+    if (rect->q.y < rect->p.y)
+        rect->q.y = rect->p.y;
     return 0;
 }
 
