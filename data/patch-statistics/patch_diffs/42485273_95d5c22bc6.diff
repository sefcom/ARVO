From 3a2a6a5edf61df4cb64f0180146f8ab9c5380999 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Tue, 11 Feb 2020 21:23:22 +0800
Subject: [PATCH] jbig2dec: Use silent rules when building as a separate
 project.

---
 configure.ac.in | 1 +
 1 file changed, 1 insertion(+)

diff --git a/configure.ac.in b/configure.ac.in
index 95dbf63..cf3022f 100644
--- a/configure.ac.in
+++ b/configure.ac.in
@@ -4,6 +4,7 @@ AC_INIT([jbig2dec], [unknown-version], [gs-devel@ghostscript.com])
 AC_PREREQ(2.53)
 AC_CONFIG_SRCDIR([jbig2dec.c])
 
+AM_SILENT_RULES([yes])
 AM_INIT_AUTOMAKE([-Wall])
 AM_CONFIG_HEADER(config.h)
 
