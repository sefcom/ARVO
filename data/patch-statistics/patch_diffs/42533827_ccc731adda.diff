From dcece81c15ddb0131e32389a7137df869a400397 Mon Sep 17 00:00:00 2001
From: Philip Hazel <Philip.Hazel@gmail.com>
Date: Sun, 17 Mar 2024 15:05:22 +0000
Subject: [PATCH] Fix yet another buffer issue in fuzzsupport

---
 src/pcre2_fuzzsupport.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/pcre2_fuzzsupport.c b/src/pcre2_fuzzsupport.c
index 7219ffa96..62aac5acd 100644
--- a/src/pcre2_fuzzsupport.c
+++ b/src/pcre2_fuzzsupport.c
@@ -317,6 +317,8 @@ if (size > 3)
       {
       int q = 0;
 
+      if (i >= size - 1) goto END_QSCAN;  /* Can happen for , */
+
       /* Ignore leading spaces */
 
       while (wdata[i+1] == ' ' || wdata[i+1] == '\t')
