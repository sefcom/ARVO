From bcc12d905673533457a897d6362a816d1dbd366d Mon Sep 17 00:00:00 2001
From: Zoltan Herczeg <zherczeg7@gmail.com>
Date: Mon, 12 May 2025 18:43:08 +0200
Subject: [PATCH] Fix heapsort in capture list construction (#748)

---
 src/pcre2_compile_cgroup.c |  1 +
 testdata/testinput2        |  3 +++
 testdata/testoutput2       | 21 +++++++++++++++++++++
 3 files changed, 25 insertions(+)

diff --git a/src/pcre2_compile_cgroup.c b/src/pcre2_compile_cgroup.c
index d6e4368c3..5c6bea822 100644
--- a/src/pcre2_compile_cgroup.c
+++ b/src/pcre2_compile_cgroup.c
@@ -479,6 +479,7 @@ while (TRUE)
   tmp = captures[i];
   captures[i] = captures[max];
   captures[max] = tmp;
+  i = max;
   }
 }
 
diff --git a/testdata/testinput2 b/testdata/testinput2
index 72a4864a6..9d9394044 100644
--- a/testdata/testinput2
+++ b/testdata/testinput2
@@ -7961,6 +7961,9 @@ a)"xI
 \= Expect no match
   Saturday,Sun
 
+/()()()(?2(2,3,2,3,2))/B
+  abc
+
 # Test each syntax used for recursion
 
 /(?(R)(Sat)urday|(?R(1)),\1)/
diff --git a/testdata/testoutput2 b/testdata/testoutput2
index c92ae3285..9a4695632 100644
--- a/testdata/testoutput2
+++ b/testdata/testoutput2
@@ -22408,6 +22408,27 @@ No match
   Saturday,Sun
 No match
 
+/()()()(?2(2,3,2,3,2))/B
+------------------------------------------------------------------
+        Bra
+        CBra 1
+        Ket
+        CBra 2
+        Ket
+        CBra 3
+        Ket
+        Recurse
+      2 Capture ref
+      3 Capture ref
+        Ket
+        End
+------------------------------------------------------------------
+  abc
+ 0: 
+ 1: 
+ 2: 
+ 3: 
+
 # Test each syntax used for recursion
 
 /(?(R)(Sat)urday|(?R(1)),\1)/
