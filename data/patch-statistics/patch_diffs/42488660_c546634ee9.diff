From 255eb9eec922467a279a0fd6ba81dba488fe84dd Mon Sep 17 00:00:00 2001
From: Tor Andersson <tor.andersson@artifex.com>
Date: Tue, 1 Dec 2020 16:10:20 +0100
Subject: [PATCH] Bug 703211: Converting an empty rect to an irect should
 preserve the coordinates.

---
 source/fitz/geometry.c | 2 --
 source/fitz/pixmap.c   | 2 +-
 2 files changed, 1 insertion(+), 3 deletions(-)

diff --git a/source/fitz/geometry.c b/source/fitz/geometry.c
index 36f50c6ae4..dfa31011c2 100644
--- a/source/fitz/geometry.c
+++ b/source/fitz/geometry.c
@@ -371,8 +371,6 @@ fz_irect_from_rect(fz_rect r)
 	fz_irect b;
 	if (fz_is_infinite_rect(r))
 		return fz_infinite_irect;
-	if (fz_is_empty_rect(r))
-		return fz_empty_irect;
 	if (!fz_is_valid_rect(r))
 		return fz_invalid_irect;
 
diff --git a/source/fitz/pixmap.c b/source/fitz/pixmap.c
index d5c741534f..166bad8e98 100644
--- a/source/fitz/pixmap.c
+++ b/source/fitz/pixmap.c
@@ -649,7 +649,7 @@ fz_copy_pixmap_rect(fz_context *ctx, fz_pixmap *dest, fz_pixmap *src, fz_irect b
 
 	b = fz_intersect_irect(b, fz_pixmap_bbox(ctx, dest));
 	b = fz_intersect_irect(b, fz_pixmap_bbox(ctx, src));
-	if (b.x1 <= b.x0 || b.y1 <= b.y0)
+	if (fz_is_empty_irect(b))
 		return;
 	w = (unsigned int)(b.x1 - b.x0);
 	y = (unsigned int)(b.y1 - b.y0);
