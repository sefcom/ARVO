From a147b834d49e656f6216701b8769b4b6261e72d5 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Mon, 24 Feb 2025 12:12:08 -0800
Subject: [PATCH] libsnmp: Fix a heap buffer overflow in se_find_list()

Fixes: https://issues.oss-fuzz.com/issues/398356443
Fixes: d7e6be1d59f7 ("generic snmp enum list support")
---
 snmplib/snmp_enum.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/snmplib/snmp_enum.c b/snmplib/snmp_enum.c
index b85d776306..33665885a1 100644
--- a/snmplib/snmp_enum.c
+++ b/snmplib/snmp_enum.c
@@ -182,7 +182,7 @@ se_store_list(unsigned int major, unsigned int minor, const char *type)
 static struct snmp_enum_list **
 se_find_list_ptr(unsigned int major, unsigned int minor)
 {
-    if (major > current_maj_num || minor > current_min_num)
+    if (major >= current_maj_num || minor >= current_min_num)
         return NULL;
     netsnmp_assert(NULL != snmp_enum_lists);
 
