From c109ef629deb714cec09e6d23fb71dc6bc29521b Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Fri, 13 Oct 2017 19:20:30 +0000
Subject: [PATCH] /vsitar/: error out on invalid file size, so as to avoid
 potenial int overflow later in the chain. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=3636. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@40426 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/port/cpl_vsil_tar.cpp | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/gdal/port/cpl_vsil_tar.cpp b/gdal/port/cpl_vsil_tar.cpp
index c7cd805df016..856b2ab604a3 100644
--- a/gdal/port/cpl_vsil_tar.cpp
+++ b/gdal/port/cpl_vsil_tar.cpp
@@ -311,6 +311,12 @@ int VSITarReader::GotoNextFile()
     nNextFileSize = 0;
     for(int i=0;i<11;i++)
         nNextFileSize = nNextFileSize * 8 + (abyHeader[124+i] - '0');
+    if( nNextFileSize > GINTBIG_MAX )
+    {
+        CPLError(CE_Failure, CPLE_AppDefined,
+                 "Invalid file size for %s", osNextFileName.c_str());
+        return FALSE;
+    }
 
     nModifiedTime = 0;
     for(int i=0;i<11;i++)
