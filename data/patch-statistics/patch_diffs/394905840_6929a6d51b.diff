From a2b2c6a8aeb67b7d943eb54072762259c79edab2 Mon Sep 17 00:00:00 2001
From: Milan Broz <gmazyland@gmail.com>
Date: Sat, 8 Feb 2025 14:41:33 +0100
Subject: [PATCH] Add workaround for memory sanitizer that cannot recognize
 explicit_bzero.

Otherwise it produces a lot of false positives in OSS-Fuzz.
---
 lib/crypto_backend/memutils.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/lib/crypto_backend/memutils.c b/lib/crypto_backend/memutils.c
index 382f7f93..4e440136 100644
--- a/lib/crypto_backend/memutils.c
+++ b/lib/crypto_backend/memutils.c
@@ -16,6 +16,13 @@
 #  endif
 #endif
 
+/* Workaround for https://github.com/google/sanitizers/issues/1507 */
+#if defined __has_feature
+# if __has_feature (memory_sanitizer)
+#   undef HAVE_EXPLICIT_BZERO
+# endif
+#endif
+
 /* Memzero helper (memset on stack can be optimized out) */
 ATTR_NOINLINE ATTR_ZERO_REGS
 void crypt_backend_memzero(void *s, size_t n)
