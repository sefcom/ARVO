Subject: [PATCH] Consider SIP content type to determine if the next layer is
 SDP (fix #1309) (#1311)

---
 Packet++/src/SipLayer.cpp                     |   8 ++++++++
 .../PacketExamples/sip_not_sdp.dat            |   1 +
 .../PacketExamples/sip_not_sdp.pcap           | Bin 0 -> 1077 bytes
 Tests/Packet++Test/TestDefinition.h           |   1 +
 Tests/Packet++Test/Tests/SipSdpTests.cpp      |  18 ++++++++++++++++++
 Tests/Packet++Test/main.cpp                   |   1 +
 6 files changed, 29 insertions(+)
 create mode 100644 Tests/Packet++Test/PacketExamples/sip_not_sdp.dat
 create mode 100644 Tests/Packet++Test/PacketExamples/sip_not_sdp.pcap

diff --git a/Packet++/src/SipLayer.cpp b/Packet++/src/SipLayer.cpp
index 7ba815755d..daa5e8cde3 100644
--- a/Packet++/src/SipLayer.cpp
+++ b/Packet++/src/SipLayer.cpp
@@ -87,7 +87,15 @@ void SipLayer::parseNextLayer()
 		return;
 
 	size_t headerLen = getHeaderLen();
+	std::string contentType;
 	if (getContentLength() > 0)
+	{
+		HeaderField *contentTypeField = getFieldByName(PCPP_SIP_CONTENT_TYPE_FIELD);
+		if (contentTypeField != nullptr)
+			contentType = contentTypeField->getFieldValue();
+	}
+
+	if (contentType.find("application/sdp") != std::string::npos)
 	{
 		m_NextLayer = new SdpLayer(m_Data + headerLen, m_DataLen - headerLen, this, m_Packet);
 	}
