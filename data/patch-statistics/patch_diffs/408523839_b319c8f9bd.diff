From e61de0bfb8148b295d27da0d47333281d19ef606 Mon Sep 17 00:00:00 2001
From: Anthony Tibbs <anthony@tibbs.ca>
Date: Sun, 6 Jul 2025 23:05:23 -0400
Subject: [PATCH] Ensure string buffer pools exist before use

The structure for the string buffer pool is setup in initStringBufferPool(). If
getStringBuffer() or releaseStringBuffer() are called prior to the pool being
initialized, a segfault occurs.

Fixes:

- getStringBuffer() will initialize the pool if necessary
- releaseStringBuffer() will do nothing (log error only) if there is an attempt
  to 'release' a string buffer that clearly has never been allocated

Fixes #1766.
---
 liblouis/lou_backTranslateString.c | 8 ++++++++
 liblouis/lou_translateString.c     | 8 ++++++++
 2 files changed, 16 insertions(+)

diff --git a/liblouis/lou_backTranslateString.c b/liblouis/lou_backTranslateString.c
index ce835ad2e0..d2d917e19e 100644
--- a/liblouis/lou_backTranslateString.c
+++ b/liblouis/lou_backTranslateString.c
@@ -74,6 +74,9 @@ initStringBufferPool() {
 static int
 getStringBuffer(int length) {
 	int i;
+
+	if (!stringBufferPool) initStringBufferPool();
+
 	for (i = 0; i < stringBufferPool->size; i++) {
 		if (!stringBufferPool->inUse[i]) {
 			stringBufferPool->buffers[i] = stringBufferPool->alloc(i, length);
@@ -87,6 +90,11 @@ getStringBuffer(int length) {
 
 static int
 releaseStringBuffer(int idx) {
+	if (!stringBufferPool) {
+		_lou_logMessage(LOU_LOG_ERROR, "Attempt to free string buffer prior to initialization of pool");
+		return 0;
+	}
+
 	if (idx >= 0 && idx < stringBufferPool->size) {
 		int inUse = stringBufferPool->inUse[idx];
 		if (inUse && stringBufferPool->free)
diff --git a/liblouis/lou_translateString.c b/liblouis/lou_translateString.c
index 87efb627d5..67103e7d2e 100644
--- a/liblouis/lou_translateString.c
+++ b/liblouis/lou_translateString.c
@@ -80,6 +80,9 @@ initStringBufferPool() {
 static int
 getStringBuffer(int length) {
 	int i;
+
+	if (!stringBufferPool) initStringBufferPool();
+
 	for (i = 0; i < stringBufferPool->size; i++) {
 		if (!stringBufferPool->inUse[i]) {
 			stringBufferPool->buffers[i] = stringBufferPool->alloc(i, length);
@@ -93,6 +96,11 @@ getStringBuffer(int length) {
 
 static int
 releaseStringBuffer(int idx) {
+	if (!stringBufferPool) {
+		_lou_logMessage(LOU_LOG_ERROR, "Attempt to free string buffer prior to initialization of pool");
+		return 0;
+	}
+
 	if (idx >= 0 && idx < stringBufferPool->size) {
 		int inUse = stringBufferPool->inUse[idx];
 		if (inUse && stringBufferPool->free)
