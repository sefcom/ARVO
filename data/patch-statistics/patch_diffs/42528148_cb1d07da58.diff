From b0287a6d29e0c09eaffe29121bbc34c471feb87a Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Mon, 2 Oct 2023 10:49:46 +0200
Subject: [PATCH] bits: more iconv fuzzing fixes

check now also errno and the full dest range.
Fixes again ossfuzz 62363
---
 src/bits.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/bits.c b/src/bits.c
index 2d7f249ab9..6b140e3b95 100644
--- a/src/bits.c
+++ b/src/bits.c
@@ -3256,7 +3256,7 @@ bit_TV_to_utf8 (const char *restrict src, const BITCODE_RS codepage)
       }
     // flush the remains
     iconv (cd, NULL, (size_t *)&srclen, (char **)&dest, (size_t *)&destlen);
-    if (dest && dest <= &odest[odestlen])
+    if (errno == 0 && dest >= odest && dest <= &odest[odestlen])
       {
         *dest = '\0';
         iconv_close (cd);
