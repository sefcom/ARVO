From 968495442964f3ea72499dfbdba9e2fa9d77f9b7 Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Tue, 22 Mar 2022 19:10:51 +0100
Subject: [PATCH] Revert "Continue to parse entity refs in recovery mode"

This reverts commit 84823b86344fb530790a8787b80abf62715ea885 which
exposed several other, potentially serious bugs.

Fixes #356.
---
 parser.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/parser.c b/parser.c
index c3068cad1..6531c9f88 100644
--- a/parser.c
+++ b/parser.c
@@ -7126,6 +7126,8 @@ xmlParseReference(xmlParserCtxtPtr ctxt) {
      */
     ent = xmlParseEntityRef(ctxt);
     if (ent == NULL) return;
+    if (!ctxt->wellFormed)
+	return;
     was_checked = ent->checked;
 
     /* special case of predefined entities */
