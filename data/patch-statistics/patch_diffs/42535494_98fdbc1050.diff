From 2e0d1b8da0dbc2d85d6226b878a06a0b7a371596 Mon Sep 17 00:00:00 2001
From: Rubin Gerritsen <rubin.gerritsen@nordicsemi.no>
Date: Tue, 14 May 2024 21:52:20 +0200
Subject: [PATCH] btle: Fix usage of periodic_adv_info_tree to avoid memory
 corruption

We should only insert connection info into the periodic adv
info tree.

411babf0832e7a2138418f82a5842a459d481d9b introduced a bug
that inserted two different types in the same tree.

Signed-off-by: Rubin Gerritsen <rubin.gerritsen@nordicsemi.no>
---
 epan/dissectors/packet-btle.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/epan/dissectors/packet-btle.c b/epan/dissectors/packet-btle.c
index 61ce8417cee..ee6490d16fb 100644
--- a/epan/dissectors/packet-btle.c
+++ b/epan/dissectors/packet-btle.c
@@ -2516,7 +2516,7 @@ dissect_btle(tvbuff_t *tvb, packet_info *pinfo, proto_tree *tree, void *data)
 
                     key[3].length = 1;
                     key[3].key = &pinfo->num;
-                    wmem_tree_insert32_array(periodic_adv_info_tree, key, connection_parameter_info);
+                    wmem_tree_insert32_array(connection_parameter_info_tree, key, connection_parameter_info);
                 }
 
                 sf = tvb_get_guint16(tvb, offset, ENC_LITTLE_ENDIAN);
