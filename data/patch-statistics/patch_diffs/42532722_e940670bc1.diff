From dbac50e667c70419625ce52eebb8b928f1ee6dfa Mon Sep 17 00:00:00 2001
From: "Alan T. DeKok" <aland@freeradius.org>
Date: Fri, 9 Feb 2024 09:49:50 -0500
Subject: [PATCH] check for fragment with insufficient room for header

---
 src/protocols/radius/decode.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/protocols/radius/decode.c b/src/protocols/radius/decode.c
index 8ef039f38675..d7faf796573b 100644
--- a/src/protocols/radius/decode.c
+++ b/src/protocols/radius/decode.c
@@ -887,7 +887,7 @@ static ssize_t decode_extended_fragments(TALLOC_CTX *ctx, fr_pair_list_t *out,
 	last_frag = false;
 
 	while (frag < end) {
-		if (last_frag ||
+		if (last_frag || ((end - frag) < 2) ||
 		    (frag[0] != attr[0]) ||
 		    (frag[1] < 4) ||		       /* too short for long-extended */
 		    (frag[2] != attr[2]) ||
