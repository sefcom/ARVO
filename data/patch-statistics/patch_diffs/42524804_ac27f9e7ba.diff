         if (!tx_direction) {
           /* Counters are swapped */
@@ -232,7 +228,7 @@ void IEC104Stats::processPacket(Flow *f, bool tx_direction,
 
         /* Skip magic(1), len(1), type/TX(2), RX(2) = 6 */
         len -= 6 /* Skip magic and len */,
-            offset += 5 /* magic already skept */;
