From b676eae90fc9c620a214889ed040d356638a18f6 Mon Sep 17 00:00:00 2001
From: Varun Khaneja <ca.aawc@yahoo.com>
Date: Mon, 12 Feb 2018 10:57:52 -0800
Subject: [PATCH] 5.6.1.8: Fixes fuzzing bugs. Additional changes.

---
 archive.cpp |  6 ++++--
 archive.hpp |  3 ---
 arcread.cpp | 31 +++++++------------------------
 dll.rc      |  6 +++---
 extract.cpp | 38 ++++++++++++++------------------------
 headers.hpp | 31 ++-----------------------------
 loclang.hpp |  2 --
 version.hpp |  6 +++---
 8 files changed, 33 insertions(+), 90 deletions(-)

diff --git a/archive.cpp b/archive.cpp
index 1f3c3af..6532869 100644
--- a/archive.cpp
+++ b/archive.cpp
@@ -194,6 +194,7 @@ bool Archive::IsArchive(bool EnableBroken)
 #endif
 
   bool HeadersLeft; // Any headers left to read.
+  bool StartFound=false; // Main or encryption headers found.
   // Skip the archive encryption header if any and read the main header.
   while ((HeadersLeft=(ReadHeader()!=0))==true) // Additional parentheses to silence Clang.
   {
@@ -202,7 +203,8 @@ bool Archive::IsArchive(bool EnableBroken)
     HEADER_TYPE Type=GetHeaderType();
     // In RAR 5.0 we need to quit after reading HEAD_CRYPT if we wish to
     // avoid the password prompt.
-    if (Type==HEAD_MAIN || SilentOpen && Type==HEAD_CRYPT)
+    StartFound=Type==HEAD_MAIN || SilentOpen && Type==HEAD_CRYPT;
+    if (StartFound)
       break;
   }
 
@@ -212,7 +214,7 @@ bool Archive::IsArchive(bool EnableBroken)
   if (FailedHeaderDecryption && !EnableBroken)
     return false;
 
-  if (BrokenHeader) // Main archive header is corrupt.
+  if (BrokenHeader || !StartFound) // Main archive header is corrupt or missing.
   {
     uiMsg(UIERROR_MHEADERBROKEN,FileName);
     if (!EnableBroken)
diff --git a/archive.hpp b/archive.hpp
index b68e435..da59973 100644
--- a/archive.hpp
+++ b/archive.hpp
@@ -107,10 +107,7 @@ class Archive:public File
     FileHeader SubHead;
     CommentHeader CommHead;
     ProtectHeader ProtectHead;
-    AVHeader AVHead;
