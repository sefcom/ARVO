From 6342496773e5824fb5bf51a871fa7384930da0ad Mon Sep 17 00:00:00 2001
From: Ken Sharp <Ken.Sharp@artifex.com>
Date: Wed, 22 May 2024 10:46:06 +0100
Subject: OSS-fuzz #69157 - check viewer depth before restoring

Sensible code would have the restore do the check on the depth before
using it, but that's not how pdfwrite works. Instead we must check the
depth is at least 1 before trying to restore.
---
 devices/vector/gdevpdfi.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/devices/vector/gdevpdfi.c b/devices/vector/gdevpdfi.c
index 0a09390f7..9448d259d 100644
--- a/devices/vector/gdevpdfi.c
+++ b/devices/vector/gdevpdfi.c
@@ -3026,7 +3026,8 @@ gdev_pdf_dev_spec_op(gx_device *pdev1, int dev_spec_op, void *data, int size)
                     /* Reset the pending state */
                     pdev->clipped_text_pending = 0;
                     /* Restore to our saved state */
-                    code = pdf_restore_viewer_state(pdev, pdev->strm);
+                    if (pdev->vgstack_depth)
+                        code = pdf_restore_viewer_state(pdev, pdev->strm);
                     if (code < 0)
                         return code;
                     pdf_reset_text(pdev);	/* because of Q */
-- 
