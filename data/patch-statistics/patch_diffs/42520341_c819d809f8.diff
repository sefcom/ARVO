 coders/wpg.c | 44 +++++++++++++++-----------------------------
 1 file changed, 15 insertions(+), 29 deletions(-)

diff --git a/coders/wpg.c b/coders/wpg.c
index f9ef6f85bbd..f3f593b23e8 100644
--- a/coders/wpg.c
+++ b/coders/wpg.c
