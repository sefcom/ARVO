From 4d7b55ab7b05b95c4fbc15e1465a09f6dc0805cb Mon Sep 17 00:00:00 2001
From: Luca Versari <veluca@google.com>
Date: Mon, 29 Nov 2021 23:39:41 +0100
Subject: [PATCH] Use FUZZING_BUILD_MODE_UNSAFE_FOR_PRODUCTION to disable ANS
 checksums.

Note that this does not enable the flag yet.
---
 lib/jxl/dec_ans.h | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/lib/jxl/dec_ans.h b/lib/jxl/dec_ans.h
index 8919e32a9cd..b5de8c12bc9 100644
--- a/lib/jxl/dec_ans.h
+++ b/lib/jxl/dec_ans.h
@@ -235,7 +235,11 @@ class ANSSymbolReader {
     return ReadSymbolWithoutRefill(histo_idx, br);
   }
 
-  bool CheckANSFinalState() { return state_ == (ANS_SIGNATURE << 16u); }
+#ifdef FUZZING_BUILD_MODE_UNSAFE_FOR_PRODUCTION
+  bool CheckANSFinalState() const { return true; }
+#else
+  bool CheckANSFinalState() const { return state_ == (ANS_SIGNATURE << 16u); }
+#endif
 
   template <typename BitReader>
   static JXL_INLINE uint32_t ReadHybridUintConfig(
