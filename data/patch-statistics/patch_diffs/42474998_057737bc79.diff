From 35ed8bbe865ddbc6868a52789235cb2d2caab7ce Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Tue, 30 Apr 2019 18:05:40 +0200
Subject: [PATCH] OGR_PDS: fix heap-buffer-overflow in error code path. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=14512. Credit to OSS
 Fuzz

---
 gdal/ogr/ogrsf_frmts/pds/ogrpdslayer.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/gdal/ogr/ogrsf_frmts/pds/ogrpdslayer.cpp b/gdal/ogr/ogrsf_frmts/pds/ogrpdslayer.cpp
index 6813ef77381d..abbbd6faf1a8 100644
--- a/gdal/ogr/ogrsf_frmts/pds/ogrpdslayer.cpp
+++ b/gdal/ogr/ogrsf_frmts/pds/ogrpdslayer.cpp
@@ -310,6 +310,11 @@ void OGRPDSLayer::ReadStructure(CPLString osStructureFilename)
                     CPLError(CE_Failure, CPLE_AppDefined,
                                 "Field %d out of record extents", nFields);
                     CSLDestroy(papszTokens);
+                    if( nFields == 0 )
+                    {
+                        CPLFree(pasFieldDesc);
+                        pasFieldDesc = nullptr;
+                    }
                     break;
                 }
             }
