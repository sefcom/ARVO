From df9e141e9a5e82b61123e1aebebc10f7a14d5a5d Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Sat, 4 Jan 2020 15:50:00 +0100
Subject: [PATCH] Added extra check to make sure that the type of the first
 channel is always zero for an image with a color map.

---
 coders/psd.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/coders/psd.c b/coders/psd.c
index 0e683903f66..bb48e9bdbee 100644
--- a/coders/psd.c
+++ b/coders/psd.c
@@ -1572,6 +1572,8 @@ static MagickBooleanType CheckPSDChannels(const PSDInfo *psd_info,
       type;
 
     type=layer_info->channel_info[i].type;
+    if ((i == 0) && (psd_info->mode == IndexedMode) && (type != 0))
+      return(MagickFalse);
     if (type == -1)
       {
         channel_type|=AlphaChannel;
