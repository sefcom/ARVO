From 2aa2b4362e44aa4bcbd1e2086aab6d2aa82df506 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 13 Feb 2024 13:27:23 +0100
Subject: [PATCH] check str len in sdp parse args

ossfuzz issue 66591
---
 src/ietf/sdp.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/src/ietf/sdp.c b/src/ietf/sdp.c
index c54c30c9b0..009e577842 100644
--- a/src/ietf/sdp.c
+++ b/src/ietf/sdp.c
@@ -226,8 +226,12 @@ void SDP_ParseAttribute(GF_SDPInfo *sdp, char *buffer, GF_SDPMedia *media)
 	att = (GF_X_Attribute*)gf_malloc(sizeof(GF_X_Attribute));
 	att->Name = gf_strdup(comp);
 	att->Value = NULL;
-	pos += 1;
-	if (buffer[pos] == ' ') pos += 1;
+
+	if (pos+1 < (s32)strlen(buffer)) {
+		pos += 1;
+		if (buffer[pos] == ' ') pos += 1;
+	}
+
 	pos = gf_token_get(buffer, pos, "\r\n", comp, 3000);
 	if (pos > 0) att->Value = gf_strdup(comp);
 
