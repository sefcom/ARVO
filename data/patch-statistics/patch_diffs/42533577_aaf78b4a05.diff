From ae88980c45691aeaa6ad0a63b6281470dfb311d9 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sat, 3 Mar 2018 12:09:51 +0000
Subject: [PATCH] ogr2ogr: preserve source geometry field name for output
 drivers that support GEOMETRY_NAME layer creation option (such as GPKG)

git-svn-id: https://svn.osgeo.org/gdal/trunk@41604 f0d54148-0727-0410-94bb-9a71ac55c965
---
 autotest/ogr/ogr_sqlite.py             |  2 +-
 autotest/utilities/test_ogr2ogr.py     | 10 ++--
 autotest/utilities/test_ogr2ogr_lib.py | 40 +++++++++++++
 gdal/apps/ogr2ogr_lib.cpp              | 83 +++++++++++++++++---------
 4 files changed, 102 insertions(+), 33 deletions(-)

diff --git a/autotest/ogr/ogr_sqlite.py b/autotest/ogr/ogr_sqlite.py
index a719d7a14120..8d51dc5c02fe 100755
--- a/autotest/ogr/ogr_sqlite.py
+++ b/autotest/ogr/ogr_sqlite.py
@@ -3442,7 +3442,7 @@ def ogr_sqlite_44():
     if gdaltest.sl_ds is None:
