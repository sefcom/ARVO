From 2f106146a2744b77d8676a5d635b11b6077b9364 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Sun, 31 Mar 2024 10:39:57 +0200
Subject: [PATCH] Updated daily build due to changes in the ImageMagick-Windows
 repository.

---
 .github/workflows/daily.yml | 38 ++++++++++++++++---------------------
 1 file changed, 16 insertions(+), 22 deletions(-)

diff --git a/.github/workflows/daily.yml b/.github/workflows/daily.yml
index 0953f131d60..f0be7203d65 100644
--- a/.github/workflows/daily.yml
+++ b/.github/workflows/daily.yml
@@ -144,9 +144,8 @@ jobs:
     - name: Clone repositories
       shell: cmd
       run: |
-        cd ImageMagick
-        for /f "tokens=* USEBACKQ" %%F IN (`git rev-parse HEAD`) do set COMMIT_SHA=%%F
-        cd ..\ImageMagick-Windows
+        for /f "tokens=* USEBACKQ" %%F IN (`git -C ImageMagick rev-parse HEAD`) do set COMMIT_SHA=%%F
+        cd ImageMagick-Windows
         CloneRepositories.cmd %COMMIT_SHA%
 
     - name: Download ChangeLog.md
@@ -159,23 +158,21 @@ jobs:
       shell: cmd
       run: |
         call "C:\Program Files\Microsoft Visual Studio\2022\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd ImageMagick-Windows\VisualMagick\configure
-        msbuild configure.2022.sln /m /t:Rebuild /p:Configuration=Release,Platform=x64
+        cd ImageMagick-Windows\Configure
+        msbuild Configure.2022.sln /m /t:Rebuild /p:Configuration=Release,Platform=x64
 
     - name: Configure ImageMagick
       shell: cmd
       run: |
-        cd ImageMagick-Windows\VisualMagick\configure
-        configure.exe /noWizard /VS2022 /includeOptional /incompatibleLicense /deprecated /${{matrix.platform}} /${{matrix.buildType}}
+        cd ImageMagick-Windows\Configure
+        Configure.exe /noWizard /VS2022 /includeOptional /incompatibleLicense /deprecated /${{matrix.platform}} /${{matrix.buildType}}
 
     - name: Build ImageMagick
       shell: cmd
       run: |
         call "C:\Program Files\Microsoft Visual Studio\2022\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd ImageMagick-Windows\VisualMagick
-        dir /B *.sln > solution
-        set /p solution=<solution
-        msbuild %solution% /m /t:Rebuild /p:Configuration=Release,Platform=${{matrix.platform}}
+        cd ImageMagick-Windows
+        msbuild /m /t:Rebuild /p:Configuration=Release,Platform=${{matrix.platform}}
 
   build_windows_zero_configuration:
     name: 'Windows Q16-x64 hdri=yes (zero configuration ${{matrix.buildType}})'
@@ -202,32 +199,29 @@ jobs:
     - name: Clone repositories
       shell: cmd
       run: |
-        cd ImageMagick
-        for /f "tokens=* USEBACKQ" %%F IN (`git rev-parse HEAD`) do set COMMIT_SHA=%%F
-        cd ..\ImageMagick-Windows
+        for /f "tokens=* USEBACKQ" %%F IN (`git -C ImageMagick rev-parse HEAD`) do set COMMIT_SHA=%%F
+        cd ImageMagick-Windows
         CloneRepositories.cmd %COMMIT_SHA%
 
     - name: Build configure
       shell: cmd
       run: |
         call "C:\Program Files\Microsoft Visual Studio\2022\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd ImageMagick-Windows\VisualMagick\configure
-        msbuild configure.2022.sln /m /t:Rebuild /p:Configuration=Release,Platform=x64
+        cd ImageMagick-Windows\Configure
+        msbuild Configure.2022.sln /m /t:Rebuild /p:Configuration=Release,Platform=x64
 
     - name: Configure ImageMagick
       shell: cmd
       run: |
-        cd ImageMagick-Windows\VisualMagick\configure
-        configure.exe /noWizard /VS2022 /x64 /${{matrix.buildType}} /zeroConfigurationSupport
+        cd ImageMagick-Windows\Configure
+        Configure.exe /noWizard /VS2022 /x64 /${{matrix.buildType}} /zeroConfigurationSupport
 
     - name: Build ImageMagick
       shell: cmd
       run: |
         call "C:\Program Files\Microsoft Visual Studio\2022\Enterprise\Common7\Tools\VsDevCmd.bat"
-        cd ImageMagick-Windows\VisualMagick
-        dir /B *.sln > solution
-        set /p solution=<solution
-        msbuild %solution% /m /t:Rebuild /p:Configuration=Release,Platform=x64
+        cd ImageMagick-Windows
+        msbuild /m /t:Rebuild /p:Configuration=Release,Platform=x64
 
   build_msys2:
     name: 'Windows Q16-${{matrix.toolchain}} hdri=yes (MSYS2)'
