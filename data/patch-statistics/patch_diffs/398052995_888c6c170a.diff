From b4d94476f02769a92be7d2122bc8926f39aa6980 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Fri, 21 Feb 2025 15:04:30 -0800
Subject: [PATCH] libsnmp: Fix another stack buffer overflow in se_read_conf()

Additionally, make some recently modified code easier to read.

Fixes: https://oss-fuzz.com/issue/6271135411142656
---
 snmplib/snmp_enum.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/snmplib/snmp_enum.c b/snmplib/snmp_enum.c
index 93fa1626bd..58a854bdcb 100644
--- a/snmplib/snmp_enum.c
+++ b/snmplib/snmp_enum.c
@@ -134,7 +134,7 @@ se_read_conf(const char *word, const char *cptr)
                 break;
             }
             cp2 = e_enum;
-            while (*(cp2++) != ':')
+            while (*cp2 != 0 && *cp2++ != ':')
                 ;
             se_add_pair(major, minor, strdup(cp2), value);
             if (!cp)
@@ -150,7 +150,7 @@ se_read_conf(const char *word, const char *cptr)
                 break;
             }
             cp2 = e_enum;
-            while (*cp2 && *(cp2++) != ':')
+            while (*cp2 != 0 && *cp2++ != ':')
                 ;
             se_add_pair_to_slist(e_name, strdup(cp2), value);
             if (!cp)
