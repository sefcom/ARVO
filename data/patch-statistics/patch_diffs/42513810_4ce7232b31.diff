From 26ce85bd5de515906e01fdeeac774316628ad599 Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Tue, 26 Jul 2022 00:13:15 +0900
Subject: [PATCH] bigint.c (ucmp): fixed error with zero length zero value.

Big integers have two kind of zero values:

- digits in `p` array are all zeros
- length `sn` is zero

The old code crashed with the latter zero.
---
 mrbgems/mruby-bigint/core/bigint.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/mrbgems/mruby-bigint/core/bigint.c b/mrbgems/mruby-bigint/core/bigint.c
index 33167610fe..a2a0e1d6ca 100644
--- a/mrbgems/mruby-bigint/core/bigint.c
+++ b/mrbgems/mruby-bigint/core/bigint.c
@@ -186,6 +186,7 @@ ucmp(mpz_t *y, mpz_t *x)
 {
   if (y->sz < x->sz) return -1;
   if (y->sz > x->sz) return 1;
+  if (x->sz == 0) return 0;
   for (size_t i=x->sz-1;; i--) {
     mp_limb a = y->p[i];
     mp_limb b = x->p[i];
