From ca6d4e3119f080f0f5b90e3b037f9f4aac5726bd Mon Sep 17 00:00:00 2001
From: Alex Hultman <alexhultman@gmail.com>
Date: Mon, 1 Mar 2021 12:46:12 +0100
Subject: [PATCH] Never return more than maxPayloadLength in PMD mock

---
 src/PerMessageDeflate.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/PerMessageDeflate.h b/src/PerMessageDeflate.h
index ff1d078ff..b6ee0bedd 100644
--- a/src/PerMessageDeflate.h
+++ b/src/PerMessageDeflate.h
@@ -58,7 +58,7 @@ namespace uWS {
 struct ZlibContext {};
 struct InflationStream {
     std::optional<std::string_view> inflate(ZlibContext *zlibContext, std::string_view compressed, size_t maxPayloadLength) {
-        return compressed;
+        return compressed.substr(0, std::min(maxPayloadLength, compressed.length()));
     }
 };
 struct DeflationStream {
