From e001c6e03f2fd04d13376f5fbaa69b1ec02cd4f5 Mon Sep 17 00:00:00 2001
From: Maksym Sobolyev <sobomax@sippysoft.com>
Date: Mon, 12 Aug 2024 10:35:05 -0700
Subject: [PATCH] Make sure we don't overflow RTP buffer.

OSS-Fuzz issue 71123
---
 scripts/fuzz/fuzz_rtp_session.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/scripts/fuzz/fuzz_rtp_session.c b/scripts/fuzz/fuzz_rtp_session.c
index ffdea962d..cc30fe41d 100644
--- a/scripts/fuzz/fuzz_rtp_session.c
+++ b/scripts/fuzz/fuzz_rtp_session.c
@@ -78,6 +78,8 @@ LLVMFuzzerTestOneInput(const char *data, size_t size)
 
     if (size <= sizeof(struct sockaddr_in))
         return (0);
+    if (size > sizeof(struct sockaddr_in) + MAX_RPKT_LEN)
+        return (0);
 
     fa.pktp = rtp_packet_alloc();
     fa.rsp = &rs;
