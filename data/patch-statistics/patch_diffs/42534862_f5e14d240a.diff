From 52406402ed1f8ff246b18ddcfced9d2f4e98ccc9 Mon Sep 17 00:00:00 2001
From: Daniel Lemire <daniel@lemire.me>
Date: Wed, 1 May 2024 14:53:48 -0400
Subject: [PATCH] fix: replace vm*vq_u8 by vm*vq_u32 for better performance
 under some systems.

---
 include/simdjson/arm64/simd.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/simdjson/arm64/simd.h b/include/simdjson/arm64/simd.h
index e728aab4a0..3b0fa844f4 100644
--- a/include/simdjson/arm64/simd.h
+++ b/include/simdjson/arm64/simd.h
@@ -134,7 +134,7 @@ namespace {
       tmp = vpaddq_u8(tmp, tmp);
       return vgetq_lane_u16(vreinterpretq_u16_u8(tmp), 0);
     }
-    simdjson_inline bool any() const { return vmaxvq_u8(*this) != 0; }
+    simdjson_inline bool any() const { return vmaxvq_u32(vreinterpretq_u32_u8(*this)) != 0; }
   };
 
   // Unsigned bytes
