diff --git a/src/vm.c b/src/vm.c
index c7e4cc8f20..974a718579 100644
--- a/src/vm.c
+++ b/src/vm.c
@@ -812,10 +812,13 @@ exec_irep(mrb_state *mrb, mrb_value self, const struct RProc *p)
