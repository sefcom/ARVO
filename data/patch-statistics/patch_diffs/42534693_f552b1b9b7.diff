 mrb_value
-mrb_exec_irep(mrb_state *mrb, mrb_value self, const struct RProc *p)
+mrb_exec_irep(mrb_state *mrb, mrb_value self, const struct RProc *p, mrb_bool separate_module)
 {
   mrb_callinfo *ci = mrb->c->ci;
   if (ci->cci == CINFO_NONE) {
+    if (separate_module) {
