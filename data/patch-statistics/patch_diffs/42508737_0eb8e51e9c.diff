From a880e1faee1df2b23054de13689de97b2ec08f28 Mon Sep 17 00:00:00 2001
From: Liviu Chircu <liviu@opensips.org>
Date: Sun, 20 Feb 2022 19:32:20 +0200
Subject: [PATCH] parse_msg: Fix possible buffer read overflow with whitespace
 input

Fixes OSS-Fuzz#44887
---
 parser/msg_parser.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/parser/msg_parser.c b/parser/msg_parser.c
index ff935281498..adf08e697d0 100644
--- a/parser/msg_parser.c
+++ b/parser/msg_parser.c
@@ -724,8 +724,8 @@ int parse_msg(char* buf, unsigned int len, struct sip_msg* msg)
 	hdr_flags_t flags;
 
 	/* eat crlf from the beginning */
-	for (tmp=buf; (*tmp=='\n' || *tmp=='\r')&&
-			(unsigned int)(tmp-buf) < len ; tmp++);
+	for (tmp=buf; (unsigned int)(tmp-buf) < len
+	        && (*tmp=='\n' || *tmp=='\r'); tmp++);
 	offset=tmp-buf;
 	fl=&(msg->first_line);
 	rest=parse_first_line(tmp, len-offset, fl);
