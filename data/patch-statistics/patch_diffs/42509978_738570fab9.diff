From 089cedc7520fbb9e0e4a912c4c3866a1aa429de6 Mon Sep 17 00:00:00 2001
From: Veronika Hanulikova <vhanulik@redhat.com>
Date: Mon, 28 Mar 2022 16:56:17 +0200
Subject: [PATCH] Check file value length

Thank oss-fuzz
https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=46002
---
 src/pkcs15init/pkcs15-epass2003.c | 11 ++++++++---
 1 file changed, 8 insertions(+), 3 deletions(-)

diff --git a/src/pkcs15init/pkcs15-epass2003.c b/src/pkcs15init/pkcs15-epass2003.c
index 74d8ba2639..b845b95a05 100644
--- a/src/pkcs15init/pkcs15-epass2003.c
+++ b/src/pkcs15init/pkcs15-epass2003.c
@@ -307,7 +307,7 @@ static int
 cosm_new_file(struct sc_profile *profile, struct sc_card *card,
 	      unsigned int type, unsigned int num, struct sc_file **out)
 {
-	struct sc_file *file;
+	struct sc_file *file = NULL;
 	const char *_template = NULL, *desc = NULL;
 	unsigned int structure = 0xFFFFFFFF;
 
@@ -317,12 +317,12 @@ cosm_new_file(struct sc_profile *profile, struct sc_card *card,
 	while (1) {
 		switch (type) {
 		case SC_PKCS15_TYPE_PRKEY_EC:
-			desc = "RSA private key";
+			desc = "EC private key";
 			_template = "private-key";
 			structure = SC_CARDCTL_OBERTHUR_KEY_EC_CRT;
 			break;
 		case SC_PKCS15_TYPE_PUBKEY_EC:
-			desc = "RSA public key";
+			desc = "EC public key";
 			_template = "public-key";
 			structure = SC_CARDCTL_OBERTHUR_KEY_EC_PUBLIC;
 			break;
@@ -373,6 +373,11 @@ cosm_new_file(struct sc_profile *profile, struct sc_card *card,
 		return SC_ERROR_NOT_SUPPORTED;
 	}
 
+	if (file->path.len < 1) {
+		sc_file_free(file);
+		return SC_ERROR_INTERNAL;
+	}
+
 	file->id &= 0xFF00;
 	file->id |= (num & 0x00FF);
 
