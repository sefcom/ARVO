From dfb225942449dc39069d76ffb4b051011385d35e Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sun, 13 Aug 2017 13:45:45 +0000
Subject: [PATCH] RPFTOC: avoid potential heap buffer overflow. (should: I
 couldn't reproduce locally) fix
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=3027. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39811 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/nitf/rpftocfile.cpp | 13 ++++++++-----
 1 file changed, 8 insertions(+), 5 deletions(-)

diff --git a/gdal/frmts/nitf/rpftocfile.cpp b/gdal/frmts/nitf/rpftocfile.cpp
index ee7600f6fecc..0e68b87433a8 100644
--- a/gdal/frmts/nitf/rpftocfile.cpp
+++ b/gdal/frmts/nitf/rpftocfile.cpp
@@ -621,12 +621,15 @@ RPFToc* RPFTOCReadFromBuffer(const char* pszFilename, VSILFILE* fp, const char*
             if( VSIStatL( frameEntry->fullFilePath, &sStatBuf ) != 0 )
             {
 #if !defined(_WIN32) && !defined(_WIN32_CE)
-                char* c = frameEntry->fullFilePath + strlen(subdir)+1;
-                while(*c)
+                if( strlen(frameEntry->fullFilePath) > strlen(subdir) )
                 {
-                    if (*c >= 'A' && *c <= 'Z')
-                        *c += 'a' - 'A';
-                    c++;
+                    char* c = frameEntry->fullFilePath + strlen(subdir)+1;
+                    while(*c)
+                    {
+                        if (*c >= 'A' && *c <= 'Z')
+                            *c += 'a' - 'A';
+                        c++;
+                    }
                 }
                 if( VSIStatL( frameEntry->fullFilePath, &sStatBuf ) != 0 )
 #endif
