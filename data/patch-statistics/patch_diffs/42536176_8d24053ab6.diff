From e1b11da3b0bce8a2126af8146bd6000cea25edea Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Fri, 16 Mar 2018 11:58:57 +0000
Subject: [PATCH] RIK: fix read heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=6959. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@41819 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/rik/rikdataset.cpp | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/gdal/frmts/rik/rikdataset.cpp b/gdal/frmts/rik/rikdataset.cpp
index 922a810b4c0f..0ee0f4e0ba06 100644
--- a/gdal/frmts/rik/rikdataset.cpp
+++ b/gdal/frmts/rik/rikdataset.cpp
@@ -355,6 +355,15 @@ CPLErr RIKRasterBand::IReadBlock( int nBlockXOff, int nBlockYOff,
 
     else if( poRDS->options == 0x0b )
     {
+        if( nBlockSize < 5 )
+        {
+            CPLFree( blockData );
+            CPLError( CE_Failure, CPLE_AppDefined,
+                      "RIK decompression failed. "
+                      "Not enough bytes." );
+            return CE_Failure;
+        }
+
         const bool LZW_HAS_CLEAR_CODE = !!(blockData[4] & 0x80);
         const int LZW_MAX_BITS = blockData[4] & 0x1f; // Max 13
         if( LZW_MAX_BITS > 13 )
