From 70090dc32140a39236d24cce525c2c50d9b5bd2a Mon Sep 17 00:00:00 2001
From: Stephen Berry <stephenberry.developer@gmail.com>
Date: Wed, 18 Jun 2025 11:05:44 -0500
Subject: [PATCH] Fix atoi for integers with exponents (#1826)

---
 include/glaze/util/atoi.hpp |  3 ++-
 tests/csv_test/csv_test.cpp | 25 ++++++++++++++++++++++++-
 2 files changed, 26 insertions(+), 2 deletions(-)

diff --git a/include/glaze/util/atoi.hpp b/include/glaze/util/atoi.hpp
index 550aa3fc2e..6277884fd7 100644
--- a/include/glaze/util/atoi.hpp
+++ b/include/glaze/util/atoi.hpp
@@ -772,7 +772,8 @@ namespace glz
       return false;
    }
 
-   inline constexpr std::array<size_t, 4> int_buffer_lengths{8, 8, 16, 24};
+   // Increase by 8 to support exponentials
+   inline constexpr std::array<size_t, 4> int_buffer_lengths{16, 16, 24, 32};
 
    template <std::integral T, class Char>
    GLZ_ALWAYS_INLINE constexpr bool atoi(T& v, const Char*& it, const Char* end) noexcept
diff --git a/tests/csv_test/csv_test.cpp b/tests/csv_test/csv_test.cpp
index 6f7163129f..87d5fea710 100644
--- a/tests/csv_test/csv_test.cpp
+++ b/tests/csv_test/csv_test.cpp
@@ -5,6 +5,7 @@
 #include "glaze/csv/read.hpp"
 #include "glaze/csv/write.hpp"
 #include "glaze/record/recorder.hpp"
+#include "glaze/base64/base64.hpp"
 #include "ut/ut.hpp"
 
 // Specification: https://datatracker.ietf.org/doc/html/rfc4180
@@ -1362,12 +1363,34 @@ struct overflow_struct
 };
 
 suite fuzzfailures = [] {
-   "colwise_write_overflow"_test = [] {
+   "fuzz1"_test = [] {
       std::string_view csv_data{"6  [5\n0"};
 
       overflow_struct obj{};
       [[maybe_unused]] auto parsed = glz::read_csv<glz::colwise>(obj, csv_data);
    };
+   
+   "fuzz2"_test = [] {
+      std::string_view b64 = "IBCPAAoxMDY3ODg4NDUyMTMyMTA4Njk5NmUrMTEzNzI0NzEyMDQ5NDIzLjE0NTIxNTJCMzIxMDg2OTk2ZS05MTEKMzIANLaztqfgDQ==";
+      
+      auto input = glz::read_base64(b64);
+      std::vector<uint8_t> s;
+      s.resize(input.size());
+      std::memcpy(s.data(), input.data(), s.size());
+      my_struct obj;
+      expect(glz::read_csv<glz::colwise>(obj, s));
+   };
+   
+   "fuzz3"_test = [] {
+      std::string_view b64 = "/BAACjY0OQo0OTk5OTk5MjkwMDAwODQ4MzY1M0UrMDAyNDk5OTk5OTk5Nwo5NAo5NDQ0NDQ0NDQ0NDQ0Cjk0CjkyCjYyAAAAAAA4OA==";
+      
+      auto input = glz::read_base64(b64);
+      std::vector<uint8_t> s;
+      s.resize(input.size());
+      std::memcpy(s.data(), input.data(), s.size());
+      my_struct obj;
+      expect(glz::read_csv<glz::colwise>(obj, s));
+   };
 };
 
 int main() { return 0; }
