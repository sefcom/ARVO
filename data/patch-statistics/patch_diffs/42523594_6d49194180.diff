From 72ef3b6a17a65d656321ac1a7fcecf6293c9c758 Mon Sep 17 00:00:00 2001
From: Alex <aleksandrosansan@gmail.com>
Date: Sat, 12 Aug 2023 19:03:29 +0200
Subject: [PATCH] Fix Heap-buffer-overflow WRITE in H5MM_memcpy (#210)

---
 src/mat73.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/mat73.c b/src/mat73.c
index c1baa0a9..17dd2377 100644
--- a/src/mat73.c
+++ b/src/mat73.c
@@ -644,6 +644,9 @@ Mat_H5ReadFieldNames(matvar_t *matvar, hid_t dset_id, hsize_t *nfields)
         H5Aclose(attr_id);
         return MATIO_E_GENERIC_READ_ERROR;
     } else {
+        if ( err == 0 ) {
+            *nfields = 1;
+        }
         err = MATIO_E_NO_ERROR;
     }
     fieldnames_vl = (hvl_t *)calloc((size_t)(*nfields), sizeof(*fieldnames_vl));
