From ddfd3a99268136d4c321fa9e2fc38c2d2b8e329d Mon Sep 17 00:00:00 2001
From: Arran Cudbard-Bell <a.cudbardb@freeradius.org>
Date: Thu, 16 Jun 2022 08:54:45 -0500
Subject: [PATCH] Fix fuzzer crash

---
 src/lib/util/size.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/lib/util/size.c b/src/lib/util/size.c
index f4fed21499dc..bc4c82a70acd 100644
--- a/src/lib/util/size.c
+++ b/src/lib/util/size.c
@@ -66,6 +66,8 @@ fr_slen_t fr_size_from_str(size_t *out, fr_sbuff_t *in)
 	*out = 0;
 
 	if (fr_sbuff_out(NULL, &size, &our_in) < 0) return fr_sbuff_error(&our_in);
+	if (!fr_sbuff_extend(&our_in)) goto done;
+
 	c = tolower(*fr_sbuff_current(&our_in));
 
 	/*
@@ -129,6 +131,7 @@ fr_slen_t fr_size_from_str(size_t *out, fr_sbuff_t *in)
 		goto overflow;
 	}
 
+done:
 	*out = (size_t)size;
 
 	return fr_sbuff_set(in, &our_in);
