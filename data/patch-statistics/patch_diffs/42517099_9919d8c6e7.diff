From 5949473d5ce9e3d56ae2e248cc3a82a13474aabd Mon Sep 17 00:00:00 2001
From: David Korczynski <david@adalogics.com>
Date: Mon, 28 Nov 2022 02:55:11 -0800
Subject: [PATCH] parser: fix overflow

Fixes: https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=52414

Signed-off-by: David Korczynski <david@adalogics.com>
---
 src/flb_parser.c | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/src/flb_parser.c b/src/flb_parser.c
index 77f0dbf1b82..4b5a348cc88 100644
--- a/src/flb_parser.c
+++ b/src/flb_parser.c
@@ -973,6 +973,12 @@ int flb_parser_tzone_offset(const char *str, int len, int *tmdiff)
         return -1;
     }
 
+    /* Ensure there is enough data */
+    if (len < 4) {
+        *tmdiff = 0;
+        return -1;
+    }
+
     /* Negative value ? */
     neg = (*p++ == '-');
 
@@ -982,6 +988,11 @@ int flb_parser_tzone_offset(const char *str, int len, int *tmdiff)
     /* Gather hours and minutes */
     hour = ((p[0] - '0') * 10) + (p[1] - '0');
     if (end - p == 5 && p[2] == ':') {
+        /* Ensure there is enough data */
+        if (len < 5) {
+            *tmdiff = 0;
+            return -1;
+        }
         min = ((p[3] - '0') * 10) + (p[4] - '0');
     }
     else {
