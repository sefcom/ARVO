From 75c4e7fca9f5b2bbd25e42ec7aa56468a75f98a5 Mon Sep 17 00:00:00 2001
From: Cristy <urban-warrior@imagemagick.org>
Date: Wed, 20 Jul 2022 19:06:13 -0400
Subject: [PATCH] check primitive boundaries to avoid overflow

---
 MagickCore/draw.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/MagickCore/draw.c b/MagickCore/draw.c
index bc2a0f3de9f..d5b7607691b 100644
--- a/MagickCore/draw.c
+++ b/MagickCore/draw.c
@@ -3414,7 +3414,8 @@ static MagickBooleanType RenderMVGContent(Image *image,
                     continue;
                   break;
                 }
-                if ((q == (char *) NULL) || (p == (char *) NULL) || ((q-4) < p))
+                if ((q == (char *) NULL) || (*q == '\0') || 
+                    (p == (char *) NULL) || ((q-4) < p))
                   {
                     status=MagickFalse;
                     break;
