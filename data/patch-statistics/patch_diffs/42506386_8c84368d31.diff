+void removeSpacesAround(std::string &text, size_t pos) {
+  auto nextp = pos + 1;
+  while (nextp < text.size() && (text[nextp] == ' ' || text[nextp] == '\t')) {
+    text.erase(nextp, 1);
+  }
+  if (pos > 0) {
+    nextp = pos - 1;
+    while (text[nextp] == ' ' || text[nextp] == '\t') {
+      text.erase(nextp, 1);
+      if (nextp > 0) {
+        --nextp;
+      } else {
+        break;
+      }
+    }
+  }
+}
