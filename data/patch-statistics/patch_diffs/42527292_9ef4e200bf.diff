From 97cc629fbea0d8d81b33ce382214578f3379de09 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Tue, 28 Nov 2023 17:54:20 +0100
Subject: [PATCH] bits: fix bit_TV_to_utf8_codepage heap-buffer-overflow

Fixes GH #881
---
 src/bits.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/bits.c b/src/bits.c
index 00df607896..390be13b13 100644
--- a/src/bits.c
+++ b/src/bits.c
@@ -3202,7 +3202,7 @@ bit_TV_to_utf8_codepage (const char *restrict src, const BITCODE_RS codepage)
   if (!codepage)
     return (char *)src;
   //  UTF8 encode
-  while ((c = *tmp) && i < destlen)
+  while (i < destlen && (char*)tmp < &src[srclen] && (c = *tmp))
     {
       wchar_t wc;
       tmp++;
