From fc8eb6b044d59b69ed40dbf6743f0e5dfa76ca1c Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Wed, 25 Sep 2024 12:56:21 +0200
Subject: [PATCH] prevent double free in gsf

ossfuzz issue 368076877
---
 src/filters/dmx_gsf.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/filters/dmx_gsf.c b/src/filters/dmx_gsf.c
index 850d16cbb0..3593ec4bf8 100644
--- a/src/filters/dmx_gsf.c
+++ b/src/filters/dmx_gsf.c
@@ -1412,6 +1412,7 @@ static void gsfdmx_finalize(GF_Filter *filter)
 
 	while (gf_list_count(ctx->pck_res)) {
 		GSF_Packet *gsp = gf_list_pop_back(ctx->pck_res);
+		gf_list_del_item(ctx->pck_res, gsp);
 		if (gsp->frags) gf_free(gsp->frags);
 		gf_free(gsp);
 	}
