From 7ae2523c90152d3e3ca2f86a3a470f436b208d7f Mon Sep 17 00:00:00 2001
From: Carlos Garnacho <carlosg@gnome.org>
Date: Thu, 13 Feb 2025 11:43:41 +0100
Subject: [PATCH] core: Check better for out of bounds reads in terminal
 parsing

Avoid reading past the extents, in case we were given incomplete input.

oss-fuzz#395921923
oss-fuzz#395921924
oss-fuzz#395969083
---
 .../core/tracker-sparql-grammar.h              | 18 +++++++++---------
 1 file changed, 9 insertions(+), 9 deletions(-)

diff --git a/src/libtinysparql/core/tracker-sparql-grammar.h b/src/libtinysparql/core/tracker-sparql-grammar.h
index 3c6db4b23..7749f891b 100644
--- a/src/libtinysparql/core/tracker-sparql-grammar.h
+++ b/src/libtinysparql/core/tracker-sparql-grammar.h
@@ -1561,19 +1561,19 @@ static const TrackerGrammarRule rule_Query[] = { R(Prologue), OR(helper_Query_or
 static const TrackerGrammarRule rule_QueryUnit[] = { R(Query), NIL };
 
 /* Inline funcs for terminal parsers */
-#define READ_CHAR(set, _C_)			\
-	G_STMT_START {				\
-		gchar ch = *str;		\
-		if ((set)) {			\
-			str++;			\
-		} else {			\
-			_C_;			\
-		}				\
+#define READ_CHAR(set, _C_)				\
+	G_STMT_START {					\
+		gchar ch = (str < end) ? *str : 0;	\
+		if ((set)) {				\
+			str++;				\
+		} else {				\
+			_C_;				\
+		}					\
 	} G_STMT_END
 
 #define READ_UNICHAR(set, _C_)				\
 	G_STMT_START {					\
-		gunichar ch = g_utf8_get_char (str);	\
+		gunichar ch = g_utf8_get_char_validated (str, end - str); \
 		if ((set)) {				\
 			str = g_utf8_next_char (str);	\
 		} else {				\
