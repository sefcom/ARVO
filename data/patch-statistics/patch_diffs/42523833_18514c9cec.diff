@@ -150,6 +150,7 @@ class MDLImporter : public BaseImporter
     */
     void SizeCheck(const void* szPos);
     void SizeCheck(const void* szPos, const char* szFile, unsigned int iLine);
+    bool IsPosValid(const void* szPos);
 
