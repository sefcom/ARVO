From dc8f364a1289bb8235afec4dae78a08e5d6d6155 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Fri, 3 Aug 2018 19:10:09 +0800
Subject: [PATCH] jbig2dec: When reading past the end of a word stream, return
 0.

Previously the returned value would be uninitialized, leading
to issues detected by valgrind later on in the parsing.
---
 jbig2.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/jbig2.c b/jbig2.c
index ab507a7..0768536 100644
--- a/jbig2.c
+++ b/jbig2.c
@@ -451,8 +451,10 @@ jbig2_word_stream_buf_get_next_word(Jbig2WordStream *self, size_t offset, uint32
 
     if (self == NULL || word == NULL)
         return -1;
-    if (offset >= z->size)
+    if (offset >= z->size) {
+        *word = 0;
         return 0;
+    }
 
     if (offset < z->size) {
         val |= data[offset] << 24;
