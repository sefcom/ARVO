From fb02f76da911581ad728cb830f5ebb1660692879 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Sun, 5 Nov 2023 11:27:08 +0100
Subject: [PATCH] Increase timeout for signing because we sign a lot of files.

---
 .github/workflows/release.yml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
index 415c5035081..bc9672caa22 100644
--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@ -164,6 +164,7 @@ jobs:
         file-digest: SHA256
         timestamp-rfc3161: http://timestamp.acs.microsoft.com
         timestamp-digest: SHA256
+        timeout: 600
 
     - name: Create installer
       shell: cmd
@@ -185,6 +186,7 @@ jobs:
         file-digest: SHA256
         timestamp-rfc3161: http://timestamp.acs.microsoft.com
         timestamp-digest: SHA256
+        timeout: 600
 
     - uses: actions/upload-artifact@v3
       with:
@@ -312,6 +314,7 @@ jobs:
         file-digest: SHA256
         timestamp-rfc3161: http://timestamp.acs.microsoft.com
         timestamp-digest: SHA256
+        timeout: 600
 
     - name: Copy Files
       id: package
