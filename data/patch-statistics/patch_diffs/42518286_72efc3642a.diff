From 795fccd75b2af90f402d9f903346414a1db193a1 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Wed, 14 Dec 2022 10:16:55 +0100
Subject: [PATCH] decode: fix assert with fuzzed illegal HEADER

No Section Locator Records at 0x15
Fixes oss-fuzz #47319
---
 src/decode.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/decode.c b/src/decode.c
index 7849b8f53d..6ddb6b7e91 100644
--- a/src/decode.c
+++ b/src/decode.c
@@ -290,6 +290,11 @@ decode_R13_R2000 (Bit_Chain *restrict dat, Dwg_Data *restrict dwg)
   }
 
   /* Section Locator Records 0x15 */
+  if (dat->byte != 0x15)
+    {
+      LOG_ERROR ("Wrong HEADER Section Locator Records at %lu", dat->byte)
+      return DWG_ERR_INVALIDDWG;
+    }
   assert (dat->byte == 0x15);
   dwg->header.numsections = bit_read_RL (dat);
   LOG_TRACE ("\nnum_sections: " FORMAT_RL " [RL]\n", dwg->header.numsections)
