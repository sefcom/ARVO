-        if (ResourceType == BZ3937_EFI_RESOURCE_MEMORY_UNACCEPTED) {
+        if (ResourceType == EFI_RESOURCE_MEMORY_UNACCEPTED) {
           BuildResourceDescriptorHobForUnacceptedMemory (Hob.ResourceDescriptor);
