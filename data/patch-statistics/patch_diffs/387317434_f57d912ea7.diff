From b54cba45fad29398097857b5971eae349b93a19b Mon Sep 17 00:00:00 2001
From: Lovell Fuller <lovell@users.noreply.github.com>
Date: Sat, 11 Jan 2025 15:43:16 +0000
Subject: [PATCH] tiffload: respect TIFFReadRawTile return code (#4340)

Partially reverts commit 7b47b07
---
 libvips/foreign/tiff2vips.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libvips/foreign/tiff2vips.c b/libvips/foreign/tiff2vips.c
index 450a2adf04..a3ecdcbb45 100644
--- a/libvips/foreign/tiff2vips.c
+++ b/libvips/foreign/tiff2vips.c
@@ -2316,7 +2316,7 @@ rtiff_read_tile(RtiffSeq *seq, tdata_t *buf, int page, int x, int y)
 
 		size = TIFFReadRawTile(rtiff->tiff, tile_no,
 			seq->compressed_buf, seq->compressed_buf_length);
-		if (size <= 0 && rtiff->fail_on >= VIPS_FAIL_ON_WARNING) {
+		if (size <= 0) {
 			vips_foreign_load_invalidate(rtiff->out);
 			g_rec_mutex_unlock(&rtiff->lock);
 			return -1;
