From 6787a2ce9a7507b2108e5432064a48cc5acf2151 Mon Sep 17 00:00:00 2001
From: Jonathan Kew <jfkthame@gmail.com>
Date: Mon, 22 Jul 2024 18:31:42 +0100
Subject: [PATCH] [Graphite] Ensure OpenTypeGLAT_*::Serialize methods are not
 called for a dropped table.

This ensures that we won't try to serialize a Glat table that was
supposed to be dropped, and is potentially in an invalid or not-
fully-initialized state.
---
 src/glat.h | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/glat.h b/src/glat.h
index f06ca161..163e4d5d 100644
--- a/src/glat.h
+++ b/src/glat.h
@@ -161,6 +161,10 @@ class OpenTypeGLAT : public Table {
   bool Parse(const uint8_t* data, size_t length);
   bool Serialize(OTSStream* out);
 
+  virtual bool ShouldSerialize() {
+    return handler && handler->ShouldSerialize();
+  }
+
  private:
   Font* font;
   uint32_t tag;
