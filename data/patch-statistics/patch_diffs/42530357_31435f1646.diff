From e5d60f0c46c58b99130e8ae8098dc5b192091ef6 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Thu, 23 Nov 2023 14:12:28 -0800
Subject: [PATCH] DISMAN-EVENT-MIB: Initialize 'name' and 'name_buf'

This patch suppresses the following two Coverity reports:

CID 407579:  Uninitialized variables  (UNINIT)
Using uninitialized value "*name_buf" when calling "memcpy". [Note: The source code implementation of the function has been overridden by a builtin model.]

CID 407578:  Uninitialized variables  (UNINIT)
Using uninitialized value "name_buf_len".
---
 agent/mibgroup/disman/event/mteTriggerConf.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/agent/mibgroup/disman/event/mteTriggerConf.c b/agent/mibgroup/disman/event/mteTriggerConf.c
index ff710c65e6..05852f35b9 100644
--- a/agent/mibgroup/disman/event/mteTriggerConf.c
+++ b/agent/mibgroup/disman/event/mteTriggerConf.c
@@ -166,8 +166,8 @@ parse_mteMonitor(const char *token, const char *line)
 
     int    seen_name = 0;
     char   oid_name_buf[SPRINT_MAX_LEN];
-    oid    name_buf[MAX_OID_LEN];
-    size_t name_buf_len;
+    oid    name_buf[MAX_OID_LEN] = { };
+    size_t name_buf_len = 0;
     u_char op    = 0;
     long   value = 0;
 
