From d8741b8196a84ac0a85d55c246752acf544e4664 Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Fri, 22 Mar 2024 14:46:36 +0100
Subject: [PATCH] fuzz: Fix namespaces after xmlDOMWrapRemoveNode

---
 fuzz/api.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/fuzz/api.c b/fuzz/api.c
index 9de577d0f..345f6b5bb 100644
--- a/fuzz/api.c
+++ b/fuzz/api.c
@@ -806,6 +806,11 @@ checkCopy(xmlNodePtr copy) {
     return copy;
 }
 
+/*
+ * Fix namespaces, for example after unlinking a node. This makes
+ * sure that the node only references namespaces declared in ancestor
+ * nodes.
+ */
 static int
 fixNs(xmlNodePtr node) {
     if (node == NULL)
@@ -3373,8 +3378,11 @@ LLVMFuzzerTestOneInput(const char *data, size_t size) {
                      doc != NULL &&
                      node->doc == doc &&
                      res < 0);
-                if (node && node->parent != oldParent)
+                if (node != NULL && node->parent != oldParent) {
+                    if (fixNs(node) < 0)
+                        oomReport = 1;
                     dropNode(oldParent);
+                }
                 endOp();
                 break;
             }
