From 4ea7ac960d9ecb6a407d0e660312f5701d3dcd49 Mon Sep 17 00:00:00 2001
From: Albert Astals Cid <aacid@kde.org>
Date: Fri, 25 May 2018 16:35:49 +0200
Subject: [PATCH] SplashFTFont::getGlyphPath: early return if textScale == 0

fixes oss-fuzz/8529
---
 splash/SplashFTFont.cc | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/splash/SplashFTFont.cc b/splash/SplashFTFont.cc
index 0b2b6afe1..1f1c6ada9 100644
--- a/splash/SplashFTFont.cc
+++ b/splash/SplashFTFont.cc
@@ -415,6 +415,10 @@ SplashPath *SplashFTFont::getGlyphPath(int c) {
   FT_UInt gid;
   FT_Glyph glyph;
 
+  if (unlikely(textScale == 0)) {
+    return nullptr;
+  }
+
   ff = (SplashFTFontFile *)fontFile;
   ff->face->size = sizeObj;
   FT_Set_Transform(ff->face, &textMatrix, nullptr);
