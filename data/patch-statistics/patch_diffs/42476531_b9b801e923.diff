Subject: [PATCH] Fix attribute selector equality (include modifier)

---
 src/ast_sel_cmp.cpp | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ast_sel_cmp.cpp b/src/ast_sel_cmp.cpp
index a865b05d0b..61615d39d6 100644
--- a/src/ast_sel_cmp.cpp
+++ b/src/ast_sel_cmp.cpp
@@ -367,6 +367,7 @@ namespace Sass {
     if (is_ns_eq(rhs)) {
       if (name() != rhs.name()) return false;
       if (matcher() != rhs.matcher()) return false;
+      if (modifier() != rhs.modifier()) return false;
       const String* lhs_val = value();
       const String* rhs_val = rhs.value();
       return PtrObjEquality()(lhs_val, rhs_val);
