From c683f5aa156a233f832a73b37d4fff4aed7a7e03 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Mon, 24 Jul 2017 13:45:32 +0000
Subject: [PATCH] CPLKeywordParser: avoid potential heap buffer overflow read.
 Fixes https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2706. Credit to
 OSS Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39638 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/port/cplkeywordparser.cpp | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/port/cplkeywordparser.cpp b/gdal/port/cplkeywordparser.cpp
index 837dfd3e130d..5148d9d27b55 100644
--- a/gdal/port/cplkeywordparser.cpp
+++ b/gdal/port/cplkeywordparser.cpp
@@ -330,6 +330,8 @@ void CPLKeywordParser::SkipWhite()
             {
                 pszHeaderNext++;
             }
+            if( *pszHeaderNext == '\0' )
+                break;
 
             pszHeaderNext += 2;
             continue;
