From 7e2d00903eb2c484abfc7e1e3547be6a0e5bd3df Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Mon, 18 Nov 2024 12:26:59 +0100
Subject: [PATCH] dmx_gsf: avoid double adding to pck_res list to prevent
 double free

ossfuzz issue 378985224
---
 src/filters/dmx_gsf.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/filters/dmx_gsf.c b/src/filters/dmx_gsf.c
index 22c40807dc..1bd8b32fe1 100644
--- a/src/filters/dmx_gsf.c
+++ b/src/filters/dmx_gsf.c
@@ -1017,7 +1017,9 @@ static void gsfdmx_stream_del(GSF_DemuxCtx *ctx, GSF_Stream *gst, Bool is_flush)
 			}
 		}
 		gsfdmx_pck_reset(gpck);
-		gf_list_add(ctx->pck_res, gpck);
+		if (gf_list_find(ctx->pck_res, gpck) == -1)
+			gf_list_add(ctx->pck_res, gpck);
+
 	}
 	if (is_flush && gst->opid)
 		gf_filter_pid_remove(gst->opid);
