From 428d1ed6a874d11b39a34f779140755f087fc9e2 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Wed, 14 Dec 2022 15:25:32 +0100
Subject: [PATCH] dynapi: protect fixed TFv strings

eg. from fuzzed illegal input.
Fixes oss-fuzz #49928
---
 src/dynapi.c      | 2 +-
 src/gen-dynapi.pl | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/dynapi.c b/src/dynapi.c
index 9be9ca4fb4..9f2aec1acb 100644
--- a/src/dynapi.c
+++ b/src/dynapi.c
@@ -14273,7 +14273,7 @@ dynapi_set_helper (void *restrict old, const Dwg_DYNAPI_field *restrict f,
       else if (strEQc (f->type, "TFv"))
         {
           char *str = (char *)calloc (f->size, 1);
-          strcpy (str, *(char**)value);
+          strncpy (str, *(char**)value, f->size);
           memcpy (old, &str, sizeof (char*)); // size of ptr
         }
       // ascii
diff --git a/src/gen-dynapi.pl b/src/gen-dynapi.pl
index c4eb5ac9b1..429457cd6c 100755
--- a/src/gen-dynapi.pl
+++ b/src/gen-dynapi.pl
@@ -3111,7 +3111,7 @@ sub out_classes {
       else if (strEQc (f->type, "TFv"))
         {
           char *str = (char *)calloc (f->size, 1);
-          strcpy (str, *(char**)value);
+          strncpy (str, *(char**)value, f->size);
           memcpy (old, &str, sizeof (char*)); // size of ptr
         }
       // ascii
