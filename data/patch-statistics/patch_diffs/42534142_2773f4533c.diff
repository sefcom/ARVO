From 52e5665ea40e84984a944f3dbe37c3ee06bf9cac Mon Sep 17 00:00:00 2001
From: Xiao <hanx.xiao@intel.com>
Date: Mon, 1 Apr 2024 14:26:54 +0800
Subject: [PATCH] Fix heap buffer overflow in
 libspdm_test_responder_chunk_send_ack_case1

Signed-off-by: Xiao <hanx.xiao@intel.com>
---
 .../chunk_send_ack.c                                | 13 -------------
 1 file changed, 13 deletions(-)

diff --git a/unit_test/fuzzing/test_responder/test_spdm_responder_chunk_send_ack/chunk_send_ack.c b/unit_test/fuzzing/test_responder/test_spdm_responder_chunk_send_ack/chunk_send_ack.c
index 2be1d4bc5d6..7612fcd16c0 100644
--- a/unit_test/fuzzing/test_responder/test_spdm_responder_chunk_send_ack/chunk_send_ack.c
+++ b/unit_test/fuzzing/test_responder/test_spdm_responder_chunk_send_ack/chunk_send_ack.c
@@ -97,7 +97,6 @@ void libspdm_test_responder_chunk_send_ack_case1(void **State)
                 break;
             }
             chunk_send_request = (spdm_chunk_send_request_t *)request;
-            spdm_message_header_t *test_spdm_message_header_t;
 
             request_size = sizeof(spdm_chunk_send_request_t) + sizeof(uint32_t) +
                            chunk_send_request->chunk_size;
@@ -108,11 +107,6 @@ void libspdm_test_responder_chunk_send_ack_case1(void **State)
                 break;
             }
 
-            test_spdm_message_header_t =
-                (spdm_message_header_t *)(((uint8_t*) (chunk_send_request + 1)) + sizeof(uint32_t));
-            if (test_spdm_message_header_t->request_response_code == SPDM_RESPOND_IF_READY) {
-                break;
-            }
             spdm_context->local_context.capability.data_transfer_size =
                 chunk_send_request->chunk_size + sizeof(spdm_chunk_send_request_t) +
                 sizeof(uint32_t);
@@ -122,7 +116,6 @@ void libspdm_test_responder_chunk_send_ack_case1(void **State)
                 break;
             }
             chunk_send_request = (spdm_chunk_send_request_t *)request;
-            spdm_message_header_t *test_spdm_message_header_t;
 
             request_size = sizeof(spdm_chunk_send_request_t) + chunk_send_request->chunk_size;
 
@@ -132,12 +125,6 @@ void libspdm_test_responder_chunk_send_ack_case1(void **State)
                 break;
             }
 
-            test_spdm_message_header_t =
-                (spdm_message_header_t *)(((uint8_t*) (chunk_send_request + 1)));
-            if (test_spdm_message_header_t->request_response_code == SPDM_RESPOND_IF_READY) {
-                break;
-            }
-
             spdm_context->local_context.capability.data_transfer_size =
                 chunk_send_request->chunk_size + sizeof(spdm_chunk_send_request_t);
 
