From a61aed8956f8bc5b32b70f1db3a149d62a8ddb2b Mon Sep 17 00:00:00 2001
From: Cristy <urban-warrior@imagemagick.org>
Date: Mon, 18 Jul 2022 07:05:16 -0400
Subject: [PATCH] make GRAY explicit to force the GRAY coder

---
 coders/bayer.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/coders/bayer.c b/coders/bayer.c
index 2e70f97ad92..09c36f90c97 100644
--- a/coders/bayer.c
+++ b/coders/bayer.c
@@ -152,6 +152,8 @@ static Image *ReadBAYERImage(const ImageInfo *image_info,
     (void) LogMagickEvent(TraceEvent,GetMagickModule(),"%s",
       image_info->filename);
   read_info=CloneImageInfo(image_info);
+  (void) FormatLocaleString(read_info->filename,MagickPathExtent,"gray:%.1024s",
+    image_info->filename);
   (void) CopyMagickString(read_info->magick,"GRAY",MagickPathExtent);
   read_info->verbose=MagickFalse;
   image=ReadImage(read_info,exception);
