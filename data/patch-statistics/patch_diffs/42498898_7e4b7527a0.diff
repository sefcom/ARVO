From fd66f3a635ae17b9db44739e6725de41c44e19c7 Mon Sep 17 00:00:00 2001
From: msuhanov <fuf@localhost>
Date: Sat, 22 Jan 2022 00:13:04 +0300
Subject: [PATCH] Fix the issue #2663.

---
 tsk/fs/fatfs_utils.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tsk/fs/fatfs_utils.c b/tsk/fs/fatfs_utils.c
index 42e7fe57dc..9495ac923e 100755
--- a/tsk/fs/fatfs_utils.c
+++ b/tsk/fs/fatfs_utils.c
@@ -149,7 +149,7 @@ fatfs_dos_2_unix_time(uint16_t date, uint16_t time, uint8_t timetens)
         tm1.tm_sec = 0;
 
     /* The ctimetens value has a range of 0 to 199 */
-    if (timetens > 100)
+    if (timetens >= 100)
         tm1.tm_sec++;
 
     tm1.tm_min = ((time & FATFS_MIN_MASK) >> FATFS_MIN_SHIFT);
