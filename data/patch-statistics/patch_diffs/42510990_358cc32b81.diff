From a3bd8dfcb42a1ba7e77868ea626c07095ac7dc3e Mon Sep 17 00:00:00 2001
From: Zoltan Szabadka <szabadka@google.com>
Date: Thu, 7 Jul 2022 11:39:15 +0200
Subject: [PATCH] Fixes for fuzzer bugs.

* Initialize full image area with RenderPadding if frame is outside image
* Use unaligned store/load in all stages
* Only run per-group render pipeline if modular could decode something
---
 lib/jxl/dec_frame.cc                          | 18 +++--
 lib/jxl/dec_group.cc                          |  6 +-
 lib/jxl/dec_modular.cc                        | 53 +++++++++++++-
 lib/jxl/dec_modular.h                         |  6 +-
 lib/jxl/frame_header.cc                       |  3 +-
 lib/jxl/modular/encoding/encoding.cc          |  1 +
 lib/jxl/modular/modular_image.cc              | 16 +++++
 lib/jxl/modular/modular_image.h               |  3 +
 .../low_memory_render_pipeline.cc             | 72 +++++++++++--------
 lib/jxl/render_pipeline/render_pipeline.cc    |  6 +-
 .../render_pipeline/simple_render_pipeline.cc |  7 +-
 lib/jxl/render_pipeline/stage_epf.cc          |  8 +--
 lib/jxl/render_pipeline/stage_from_linear.cc  | 13 ++--
 lib/jxl/render_pipeline/stage_noise.cc        | 26 +++----
 lib/jxl/render_pipeline/stage_to_linear.cc    | 12 ++--
 lib/jxl/render_pipeline/stage_tone_mapping.cc | 12 ++--
 lib/jxl/render_pipeline/stage_write.cc        | 16 ++---
 lib/jxl/sanitizers.h                          | 17 +++--
 18 files changed, 199 insertions(+), 96 deletions(-)

diff --git a/lib/jxl/dec_frame.cc b/lib/jxl/dec_frame.cc
