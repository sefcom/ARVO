Subject: [PATCH] check for atexit needs stdlib.h on OSX, fixes configure sed
 error

---
 configure.ac | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/configure.ac b/configure.ac
index 215b119465e..3a18ec58c17 100644
--- a/configure.ac
+++ b/configure.ac
@@ -133,6 +133,9 @@ fi
 #ifdef HAVE_TIME_H
     #include <time.h>
 #endif
