From e2cb33534a9b9b32dd530d687dada1bafbdf7179 Mon Sep 17 00:00:00 2001
From: "Diego F. Aranha" <dfaranha@gmail.com>
Date: Fri, 5 Feb 2021 19:32:15 +0100
Subject: [PATCH] Make sure c has space for result.

---
 src/bn/relic_bn_shift.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/bn/relic_bn_shift.c b/src/bn/relic_bn_shift.c
index be1f08408..85c0c2bfe 100644
--- a/src/bn/relic_bn_shift.c
+++ b/src/bn/relic_bn_shift.c
@@ -112,6 +112,8 @@ void bn_rsh(bn_t c, const bn_t a, int bits) {
 
 	RLC_RIP(bits, digits, bits);
 
+	bn_grow(c, a->used - digits);
+
 	if (digits > 0) {
 		bn_rshd_low(c->dp, a->dp, a->used, digits);
 	}
