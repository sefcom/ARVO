From 5e7cedab7afec3dc8c8fdaa81f99a13e4850b8a0 Mon Sep 17 00:00:00 2001
From: Ram Mohan <ram.mohan@ittiam.com>
Date: Tue, 24 Sep 2024 17:34:02 +0530
Subject: [PATCH] update fuzzers for improved coverage

- add missing apis to enc/dec fuzzers
- increase the range of params used for fuzzing
- consume bytes from data provider as per need
- reduce max dimensions of the library to address timeouts

Test: ./ultrahdr_enc_fuzzer
Test: ./ultrahdr_dec_fuzzer
---
 fuzzer/ossfuzz.sh              |   2 +-
 fuzzer/ultrahdr_dec_fuzzer.cpp |  32 ++++---
 fuzzer/ultrahdr_enc_fuzzer.cpp | 147 ++++++++++++++++++++++-----------
 3 files changed, 120 insertions(+), 61 deletions(-)

diff --git a/fuzzer/ossfuzz.sh b/fuzzer/ossfuzz.sh
index 3f241e77..a0d3f06b 100755
--- a/fuzzer/ossfuzz.sh
+++ b/fuzzer/ossfuzz.sh
@@ -29,7 +29,7 @@ rm -rf ${build_dir}
 mkdir -p ${build_dir}
 pushd ${build_dir}
 
-cmake $SRC/libultrahdr -DUHDR_BUILD_FUZZERS=1
+cmake $SRC/libultrahdr -DUHDR_BUILD_FUZZERS=1 -DUHDR_MAX_DIMENSION=1280
 make -j$(nproc) ultrahdr_dec_fuzzer ultrahdr_enc_fuzzer
 cp ${build_dir}/ultrahdr_dec_fuzzer $OUT/
 cp ${build_dir}/ultrahdr_enc_fuzzer $OUT/
