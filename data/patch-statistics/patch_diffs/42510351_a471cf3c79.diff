From 864a817f6cd509e72ee453f7f7d75f9b9f0754df Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Wed, 13 Dec 2017 14:42:07 +0000
Subject: [PATCH] GRIB: avoid use of uninitialized memory

git-svn-id: https://svn.osgeo.org/gdal/trunk@41018 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/grib/gribdataset.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/gdal/frmts/grib/gribdataset.cpp b/gdal/frmts/grib/gribdataset.cpp
index 8ed93ca5e10a..5ce5c24fb4f4 100644
--- a/gdal/frmts/grib/gribdataset.cpp
+++ b/gdal/frmts/grib/gribdataset.cpp
@@ -319,7 +319,12 @@ void GRIBRasterBand::FindPDSTemplate()
         {
             GByte *pabyBody = static_cast<GByte *>(CPLMalloc(nSectSize));
             memcpy(pabyBody, abyHead, 5);
-            VSIFReadL(pabyBody + 5, 1, nSectSize - 5, poGDS->fp);
+            if( VSIFReadL(pabyBody + 5, 1, nSectSize - 5, poGDS->fp) !=
+                    nSectSize - 5 )
+            {
+                CPLFree(pabyBody);
+                return;
+            }
 
             GUInt16 nCoordCount = 0;
             memcpy(&nCoordCount, pabyBody + 6-1, 2);
