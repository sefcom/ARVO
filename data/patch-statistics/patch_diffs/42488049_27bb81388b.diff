From 7d0c940768fa3f7d07396dbae1d668cfded6bf05 Mon Sep 17 00:00:00 2001
From: Dan Bloomberg <dan.bloomberg@gmail.com>
Date: Sun, 25 Oct 2020 00:18:10 -0700
Subject: [PATCH] Issue 26260: fpix2_fuzzer: heap use after free in
 fpixChangeRefcount()

---
 prog/fuzzing/fpix2_fuzzer.cc | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/prog/fuzzing/fpix2_fuzzer.cc b/prog/fuzzing/fpix2_fuzzer.cc
index 5da7a76f7..513b21c22 100644
--- a/prog/fuzzing/fpix2_fuzzer.cc
+++ b/prog/fuzzing/fpix2_fuzzer.cc
@@ -105,8 +105,7 @@ LLVMFuzzerTestOneInput(const uint8_t* data, size_t size) {
     FPIX *fpix5 = fpixCreate(300, 300);
     FPIX *fpix6 = fpixCreate(300, 300);
     FPIX *fpix_copy3 = fpixCopy(NULL, fpix_payload);
-    FPIX *fpix_return1 = fpixLinearCombination(fpix_copy3, fpix5, fpix6, 1.1, 1.1);
-    fpixDestroy(&fpix_return1);
+    fpixLinearCombination(fpix_copy3, fpix5, fpix6, 1.1, 1.1);
     fpixDestroy(&fpix_copy3);
     fpixDestroy(&fpix5);
     fpixDestroy(&fpix6);
@@ -129,4 +128,4 @@ LLVMFuzzerTestOneInput(const uint8_t* data, size_t size) {
     dpixDestroy(&dpix_payload);
     fpixDestroy(&fpix_payload);
     return 0;
-}
\ No newline at end of file
+}
