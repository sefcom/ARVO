 	if (val >= 0)
-		SStream_concat(O, "#%" PRIu32, val);
+		SStream_concat(ss, "#%" PRIu32, val);
 	else {
 		if (val == INT32_MIN)
-			SStream_concat(O, "#-%" PRIu32, val);
