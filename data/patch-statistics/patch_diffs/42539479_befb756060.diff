From a37c17b713a675cd7e9af32175351b1a8d9557f1 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Mon, 23 Apr 2018 23:06:23 +0200
Subject: [PATCH] VFK: fix potential heap buffer overflow caused by
 66f91646136993b94566d5080b9576482cc5fe0e (refs #365). Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=7953. Credit to OSS
 Fuzz

---
 gdal/ogr/ogrsf_frmts/vfk/vfkfeature.cpp | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/ogr/ogrsf_frmts/vfk/vfkfeature.cpp b/gdal/ogr/ogrsf_frmts/vfk/vfkfeature.cpp
index f24f1e1481d1..420c3f926814 100644
--- a/gdal/ogr/ogrsf_frmts/vfk/vfkfeature.cpp
+++ b/gdal/ogr/ogrsf_frmts/vfk/vfkfeature.cpp
@@ -404,6 +404,8 @@ bool VFKFeature::SetProperties(const char *pszLine)
                        -> only last two quotes used */
                     poChar -= 2;
                 }
+                else if( *poChar == '\0' )
+                    break;
                 /* odd number of quotes -> none of quotes used */
             }
         }
