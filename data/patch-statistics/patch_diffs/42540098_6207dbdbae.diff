From c9650369c5dd74812db515d986ded898b9002ae4 Mon Sep 17 00:00:00 2001
From: Albert Astals Cid <aacid@kde.org>
Date: Thu, 24 May 2018 18:20:12 +0200
Subject: [PATCH] Splash::scaleMaskYuXu: Free internal bitmap data on error

this way we don't try to use it later, which will be an uninitialized memory read

fixes oss-fuzz/8511
---
 splash/Splash.cc | 1 +
 1 file changed, 1 insertion(+)

diff --git a/splash/Splash.cc b/splash/Splash.cc
index 7a7721447..a95cc8058 100644
--- a/splash/Splash.cc
+++ b/splash/Splash.cc
@@ -3573,6 +3573,7 @@ void Splash::scaleMaskYuXu(SplashImageMaskSource src, void *srcData,
 
   if (unlikely(srcWidth <= 0 || srcHeight <= 0)) {
     error(errSyntaxError, -1, "srcWidth <= 0 || srcHeight <= 0 in Splash::scaleMaskYuXu");
+    gfree(dest->takeData());
     return;
   }
 
