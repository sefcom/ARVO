From 3354edcdd48e0c0c9d4639a6f9513d3e3d44eaa1 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Tue, 5 Mar 2019 16:18:29 +0800
Subject: [PATCH] Bug 700712: Set unspecified PDF function input to zero.

Previously evaluating a PDF function with too few inputs would
copy the specified inputs along with all uninitialized inputs.
The uninitialized inputs were never zeroed as intended. Now
that the typo is fixed any unspecified input will be set
to zero.
---
 source/pdf/pdf-function.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/source/pdf/pdf-function.c b/source/pdf/pdf-function.c
index 4cc1bfc118..99b324e22a 100644
--- a/source/pdf/pdf-function.c
+++ b/source/pdf/pdf-function.c
@@ -1389,9 +1389,9 @@ pdf_eval_function(fz_context *ctx, pdf_function *func, const float *in, int inle
 
 	if (inlen < func->m)
 	{
-		for (i = 0; i < func->m; ++i)
+		for (i = 0; i < inlen; ++i)
 			fakein[i] = in[i];
-		for (; i < inlen; ++i)
+		for (; i < func->m; ++i)
 			fakein[i] = 0;
 		in = fakein;
 	}
