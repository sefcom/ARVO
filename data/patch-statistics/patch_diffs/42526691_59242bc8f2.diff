Subject: [PATCH] Fix crash on numeric comparison (ref #2804) (#2818)

---
 src/jv.c      | 2 +-
 tests/jq.test | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/src/jv.c b/src/jv.c
index 3812777358..933ed7bee1 100644
--- a/src/jv.c
+++ b/src/jv.c
@@ -536,7 +536,7 @@ static decContext* tsd_dec_ctx_get(pthread_key_t *key) {
     if (key == &dec_ctx_key)
     {
       decContextDefault(ctx, DEC_INIT_BASE);
-      ctx->digits = DEC_MAX_DIGITS;
+      ctx->digits = DEC_MAX_DIGITS - 1;
       ctx->traps = 0; /*no errors*/
     }
     else if (key == &dec_ctx_dbl_key)
diff --git a/tests/jq.test b/tests/jq.test
index 246da0fcca..3ba29add24 100644
--- a/tests/jq.test
+++ b/tests/jq.test
@@ -556,6 +556,10 @@ null
 null
 1e+17
 
+5E500000000>5E-5000000000
+null
+true
+
 25 % 7
 null
