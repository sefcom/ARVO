From e7cb76c0b3ab4416187fb2c495b25c28af10357c Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Fri, 9 Jun 2017 07:59:43 +0000
Subject: [PATCH] netCDF: fix (harmless) integer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2170. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39008 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/netcdf/netcdfdataset.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/gdal/frmts/netcdf/netcdfdataset.cpp b/gdal/frmts/netcdf/netcdfdataset.cpp
index f1b8f57863b2..9efc097af402 100644
--- a/gdal/frmts/netcdf/netcdfdataset.cpp
+++ b/gdal/frmts/netcdf/netcdfdataset.cpp
@@ -8563,6 +8563,10 @@ static bool NCDFIsGDALVersionGTE(const char *pszVersion, int nTarget)
          iToken++ )
     {
         nVersions[iToken] = atoi(papszTokens[iToken]);
+        if( nVersions[iToken] < 0 )
+            nVersions[iToken] = 0;
+        else if( nVersions[iToken] > 99 )
+            nVersions[iToken] = 99;
     }
 
     int nVersion = 0;
