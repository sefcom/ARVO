From 0520d30ffa07f3ecddd177140a66dd736e615190 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Wed, 8 Nov 2023 13:35:57 +0100
Subject: [PATCH] indxf: fix stack-buffer-overflow

Fixes ossfuzz 63919
---
 src/in_dxf.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/in_dxf.c b/src/in_dxf.c
index dc85c8dbec..e03cef7038 100644
--- a/src/in_dxf.c
+++ b/src/in_dxf.c
@@ -1114,6 +1114,7 @@ dxf_header_read (Bit_Chain *restrict dat, Dwg_Data *restrict dwg)
       LOG_TRACE ("SUMMARY.%s = %s [T16 1]\n", &field[1], pair->value.s);      \
       bit_utf8_to_TV (dest, (unsigned char *)pair->value.s, 1024,             \
                       strlen (pair->value.s), 0, dat->codepage);              \
+      dest[1023] = '\0';                                                      \
       dwg->summaryinfo.name = strdup (dest);                                  \
     }
 
