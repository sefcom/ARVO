From b79d3f2ab9df07be675d262474a70f59eae55a66 Mon Sep 17 00:00:00 2001
From: Roman Lebedev <lebedev.ri@gmail.com>
Date: Sat, 23 Dec 2023 02:27:08 +0300
Subject: [PATCH] DngDecoder::parseColorMatrix(): validate color matrix size

---
 src/librawspeed/decoders/DngDecoder.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/librawspeed/decoders/DngDecoder.cpp b/src/librawspeed/decoders/DngDecoder.cpp
index 657d7e87b..32402bd9d 100644
--- a/src/librawspeed/decoders/DngDecoder.cpp
+++ b/src/librawspeed/decoders/DngDecoder.cpp
@@ -279,6 +279,10 @@ void DngDecoder::parseColorMatrix() const {
   if (!mat)
     return;
 
+  // Color matrix size *MUST* be a multiple of 3 (number of channels in XYZ).
+  if (mat->count % 3 != 0)
+    return;
+
   const auto srat_vals = mat->getSRationalArray(mat->count);
   bool Success = true;
   mRaw->metadata.colorMatrix.reserve(mat->count);
