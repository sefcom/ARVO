From 3dae79daa70c0b62e64fc6bf1b7e68757a812db0 Mon Sep 17 00:00:00 2001
From: Victor Toso <victortoso@redhat.com>
Date: Mon, 9 Aug 2021 12:23:36 +0200
Subject: [PATCH] Prepare for 0.11.0 release

Signed-off-by: Victor Toso <victortoso@redhat.com>
---
 ChangeLog.md               | 9 +++++++++
 meson.build                | 2 +-
 usbredirparser/meson.build | 6 +++---
 3 files changed, 13 insertions(+), 4 deletions(-)

diff --git a/ChangeLog.md b/ChangeLog.md
index 30ea755..9c8c4c7 100644
--- a/ChangeLog.md
+++ b/ChangeLog.md
@@ -1,3 +1,12 @@
+# usbredir-0.11.0 - 10 Aug 2021
+
+- !40 Fixes use-after-free on usbredirparser serialization
+- !25 Fixes memory leak in usbredirparser
+- !32 Fixes build in MacOS related to visibility of exported symbols
+- !36 Adds usbredirfilter_free function
+- !29 Adds Fuzzing for Filters
+- !34 Improvements to usbredirfilter_string_to_rules()
+
 # usbredir-0.10.0 - 27 May 2021
 
 - !23 Fixes 0.9.0 regression in bulk transfer message size
diff --git a/meson.build b/meson.build
index 8b80742..6e773a7 100644
--- a/meson.build
+++ b/meson.build
@@ -1,5 +1,5 @@
 project('usbredir', 'c', 'cpp',
-    version: '0.10.0',
+    version: '0.11.0',
     license: 'LGPLv2.1+',
     meson_version : '>= 0.53',
     default_options : [
diff --git a/usbredirparser/meson.build b/usbredirparser/meson.build
index 0902fa7..0077669 100644
--- a/usbredirparser/meson.build
+++ b/usbredirparser/meson.build
@@ -1,8 +1,8 @@
 # so verison, see:
 # http://www.gnu.org/software/libtool/manual/html_node/Updating-version-info.html
-usbredir_parser_current = 1
-usbredir_parser_revision = 3
-usbredir_parser_age = 0
+usbredir_parser_current = 2
+usbredir_parser_revision = 0
+usbredir_parser_age = 1
 usbredir_parser_so_version = '@0@.@1@.@2@'.format(
     usbredir_parser_current - usbredir_parser_age,
     usbredir_parser_age,
-- 
GitLab

