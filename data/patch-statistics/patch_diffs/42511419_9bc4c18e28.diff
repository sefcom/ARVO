From d11acc2d0684534bf855667caef7e49faf3f3433 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Mon, 12 Dec 2022 16:03:55 +0100
Subject: [PATCH] decode: fix double-free of XRECORD.objid_handles

silly code.
Fixes GH #518
---
 src/dwg.spec | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/dwg.spec b/src/dwg.spec
index d39f372ac5..53191f4d68 100644
--- a/src/dwg.spec
+++ b/src/dwg.spec
@@ -6794,8 +6794,10 @@ DWG_OBJECT (XRECORD)
           FIELD_HANDLE_N (objid_handles[vcount], vcount, ANYCODE, 0);
           if (!FIELD_VALUE (objid_handles[vcount]))
             {
-              if (!vcount)
+              if (!vcount) {
                 free (FIELD_VALUE (objid_handles));
+                FIELD_VALUE (objid_handles) = NULL;
+              }
               break;
             }
         }
