ReadMNGImage(): Eliminate use of uninitialized header magic data by checking for EOF first.

diff --git a/ChangeLog b/ChangeLog
--- a/ChangeLog
+++ b/ChangeLog
@@ -1,3 +1,10 @@
+2018-05-30  Bob Friesenhahn  <bfriesen@simple.dallas.tx.us>
+
+	* coders/png.c (ReadMNGImage): Eliminate use of uninitialized
+	header magic data by checking for EOF first.  Fixes oss-fuzz 8597
+	"graphicsmagick/coder_MNG_fuzzer: Use-of-uninitialized-value in
+	ReadMNGImage". (Credit to OSS-Fuzz)
+
 2018-05-25  Bob Friesenhahn  <bfriesen@simple.dallas.tx.us>
 
 	* fuzzing/oss-fuzz-build.sh: More fixes based on what is observed
diff --git a/VisualMagick/installer/inc/version.isx b/VisualMagick/installer/inc/version.isx
--- a/VisualMagick/installer/inc/version.isx
+++ b/VisualMagick/installer/inc/version.isx
@@ -10,5 +10,5 @@
 
 #define public MagickPackageName "GraphicsMagick"
 #define public MagickPackageVersion "1.4"
-#define public MagickPackageVersionAddendum ".020180525"
-#define public MagickPackageReleaseDate "snapshot-20180525"
+#define public MagickPackageVersionAddendum ".020180530"
+#define public MagickPackageReleaseDate "snapshot-20180530"
diff --git a/coders/png.c b/coders/png.c
--- a/coders/png.c
+++ b/coders/png.c
@@ -4139,8 +4139,8 @@
       /*
         Verify MNG signature.
       */
-      (void) ReadBlob(image,8,magic_number);
-      if (memcmp(magic_number,"\212MNG\r\n\032\n",8) != 0)
+      if ((ReadBlob(image,8,magic_number) != 8) ||
+          (memcmp(magic_number,"\212MNG\r\n\032\n",8) != 0))
         {
           MngInfoFreeStruct(mng_info,&have_mng_structure);
           ThrowReaderException(CorruptImageError,ImproperImageHeader,image);
diff --git a/magick/version.h b/magick/version.h
--- a/magick/version.h
+++ b/magick/version.h
@@ -38,8 +38,8 @@
 #define MagickLibVersion  0x211800
 #define MagickLibVersionText  "1.4"
 #define MagickLibVersionNumber 21,18,0
-#define MagickChangeDate   "20180525"
-#define MagickReleaseDate  "snapshot-20180525"
+#define MagickChangeDate   "20180530"
+#define MagickReleaseDate  "snapshot-20180530"
 	
