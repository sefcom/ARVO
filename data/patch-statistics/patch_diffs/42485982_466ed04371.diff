From d3fa315e436db38863297f074de11af359dbeefb Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sat, 1 Jul 2017 11:00:36 +0000
Subject: [PATCH] PCIDSK: for band interleave channel, correctly use
 pixel_offset in case it is different from pixel_size. Fix heap buffer
 overflow of https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2440.
 Credit to OSS Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39420 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/pcidsk/sdk/channel/cbandinterleavedchannel.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gdal/frmts/pcidsk/sdk/channel/cbandinterleavedchannel.cpp b/gdal/frmts/pcidsk/sdk/channel/cbandinterleavedchannel.cpp
index 8ff3b037c42a..0f7787785ef8 100644
--- a/gdal/frmts/pcidsk/sdk/channel/cbandinterleavedchannel.cpp
+++ b/gdal/frmts/pcidsk/sdk/channel/cbandinterleavedchannel.cpp
@@ -187,7 +187,7 @@ int CBandInterleavedChannel::ReadBlock( int block_index, void *buffer,
         {
             memcpy( ((char *) buffer) + pixel_size * i, 
                     this_pixel, pixel_size );
-            this_pixel += pixel_size;
+            this_pixel += pixel_offset;
         }
     }
 
