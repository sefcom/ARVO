Date: Fri, 18 Apr 2025 13:37:08 +0200
Subject: [PATCH] fix(NTLMCredentials): fix potentially uninitialized variable

---
 Net/src/NTLMCredentials.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Net/src/NTLMCredentials.cpp b/Net/src/NTLMCredentials.cpp
index 57340dc912..bfe1beecc2 100644
--- a/Net/src/NTLMCredentials.cpp
+++ b/Net/src/NTLMCredentials.cpp
@@ -209,7 +209,7 @@ bool NTLMCredentials::parseChallengeMessage(const unsigned char* buffer, std::si
 	reader.readRaw(7, signature);
 	if (signature != NTLMSSP) return false;
 
-	Poco::UInt8 zero;
+	Poco::UInt8 zero = 1;
 	reader >> zero;
 	if (zero != 0) return false;
 
