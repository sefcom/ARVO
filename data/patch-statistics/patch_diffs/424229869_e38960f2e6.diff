From a3992815b3d4caa4a6709406ca085c9f93856809 Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Thu, 12 Jun 2025 13:51:37 +0200
Subject: [PATCH] parser: Fix buffer overflow when parsing PublicIds

Regressed with 8231c0366 and 30665ae4.
---
 parser.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/parser.c b/parser.c
index 9ca094552..f47f6b809 100644
--- a/parser.c
+++ b/parser.c
@@ -4446,7 +4446,7 @@ xmlParsePubidLiteral(xmlParserCtxt *ctxt) {
                 xmlFree(buf);
                 return(NULL);
             }
-	    tmp = xmlRealloc(buf, size);
+	    tmp = xmlRealloc(buf, newSize);
 	    if (tmp == NULL) {
 		xmlErrMemory(ctxt);
 		xmlFree(buf);
