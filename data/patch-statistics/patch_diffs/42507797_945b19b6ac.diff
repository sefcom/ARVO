From 16432022a82ecbf22802680d42bf9adacefef6da Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Sun, 26 Nov 2017 12:53:42 +0100
Subject: [PATCH] axisswap: validate axis number. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=4404. Credit to OSS
 Fuzz

---
 src/PJ_axisswap.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/PJ_axisswap.c b/src/PJ_axisswap.c
index 53c93cc999..f8f17380da 100644
--- a/src/PJ_axisswap.c
+++ b/src/PJ_axisswap.c
@@ -187,6 +187,10 @@ PJ *CONVERSION(axisswap,0) {
     /* read axes numbers and signs */
     for ( s = order, n = 0; *s != '\0' && n < 4; ) {
         Q->axis[n] = abs(atoi(s))-1;
+        if (Q->axis[n] >= 4) {
+            proj_log_error(P, "swapaxis: invalid axis '%s'", s);
+            return pj_default_destructor(P, PJD_ERR_AXIS);
+        }
         Q->sign[n++] = sign(atoi(s));
         while ( *s != '\0' && *s != ',' )
             s++;
