From acbfb3c93c0bf3118412baf7499a8467a490b277 Mon Sep 17 00:00:00 2001
From: James Bonfield <jkb@sanger.ac.uk>
Date: Mon, 8 Feb 2021 10:20:50 +0000
Subject: [PATCH] Fix off-by-one error in array bounds checking.

Credit to OSS-Fuzz
Fixes oss-fuzz 30381
Fixes oss-fuzz 30395
---
 htscodecs/rle.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/htscodecs/rle.c b/htscodecs/rle.c
index fd0965a..7b6bdc9 100644
--- a/htscodecs/rle.c
+++ b/htscodecs/rle.c
@@ -169,7 +169,7 @@ uint8_t *rle_decode(uint8_t *lit, uint64_t lit_len,
 	    uint32_t rlen;
 	    run += var_get_u32(run, run_end, &rlen);
 	    if (rlen) {
-		if (outp + rlen > out_end)
+		if (outp + rlen >= out_end)
 		    goto err;
 		memset(outp, b, rlen+1);
 		outp += rlen+1;
