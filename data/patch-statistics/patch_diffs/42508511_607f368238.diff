From: David Garske <david@wolfssl.com>
Date: Thu, 31 Mar 2022 15:09:55 -0700
Subject: [PATCH] Fix to ensure the packet object is reset after use.

---
 src/mqtt_client.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/mqtt_client.c b/src/mqtt_client.c
index 102c550d8..ceb6951e7 100644
--- a/src/mqtt_client.c
+++ b/src/mqtt_client.c
@@ -1033,6 +1033,8 @@ static int MqttClient_WaitType(MqttClient *client, void *packet_obj,
                 break;
             }
         #endif
+            /* Make sure shared packet object is reset */
+            XMEMSET(&client->msg, 0, sizeof(client->msg));
 
             /* handle success case */
             if (rc >= 0) {
