From 0cb976489e93b92987fa1fd5bbdafe69d5a587d8 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Tue, 30 May 2017 10:22:06 +0000
Subject: [PATCH] NITF: error out on unsupported combination of ABPP and IMODE
 to avoid later heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=1924. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@38684 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/nitf/nitfimage.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/gdal/frmts/nitf/nitfimage.c b/gdal/frmts/nitf/nitfimage.c
index b805b6d90b18..471c45c78718 100644
--- a/gdal/frmts/nitf/nitfimage.c
+++ b/gdal/frmts/nitf/nitfimage.c
@@ -1317,6 +1317,13 @@ int NITFReadImageBlock( NITFImage *psImage, int nBlockX, int nBlockY,
 
                 return BLKREAD_OK;
             }
+            else
+            {
+                CPLError( CE_Failure, CPLE_NotSupported,
+                          "ABPP=%d and IMODE=%c not supported",
+                          psImage->nBitsPerSample, psImage->chIMODE );
+                return BLKREAD_FAIL;
+            }
         }
     }
 
