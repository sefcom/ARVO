-  mrb_define_class_method_id(mrb, file, MRB_SYM(_getwd),    mrb_file__getwd,     MRB_ARGS_NONE());
-  mrb_define_class_method_id(mrb, file, MRB_SYM(_gethome),  mrb_file__gethome,   MRB_ARGS_OPT(1));
