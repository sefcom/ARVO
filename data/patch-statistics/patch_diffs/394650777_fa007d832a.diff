-        else
-          expand_path_array << path_token
-        end
-      end
-
-      expanded_path = expand_path_array.join("/")
-      if expanded_path.empty?
-        expanded_path = '/'
-      end
-    end
-    if drive_prefix.empty?
-      expanded_path
-    else
-      drive_prefix + expanded_path
-    end
-  end
-
