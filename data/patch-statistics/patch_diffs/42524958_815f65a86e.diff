From ed31ab4c83eb3c745e61222be0f4d06689a821a5 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Thu, 1 Jun 2023 14:36:12 -0700
Subject: [PATCH] libsnmp: Fix a buffer overflow in
 sprint_realloc_hinted_integer()

See also https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=59491.
---
 snmplib/mib.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/snmplib/mib.c b/snmplib/mib.c
index b117aba080..3f619fc384 100644
--- a/snmplib/mib.c
+++ b/snmplib/mib.c
@@ -1284,9 +1284,9 @@ sprint_realloc_hinted_integer(u_char ** buf, size_t * buf_len,
 	    bit >>= 1;
 	}
 	*bp = 0;
+    } else {
+        snprintf(tmp, sizeof(tmp), fmt, val);
     }
-    else
-	sprintf(tmp, fmt, val);
 
     if (shift != 0) {
         len = strlen(tmp);
