From 52da2ef6b33c26d4ffd72d1d4ae6c42631ea433f Mon Sep 17 00:00:00 2001
From: jeanlf <jeanlf@gpac.io>
Date: Mon, 22 Jan 2024 13:35:07 +0100
Subject: [PATCH] fixed possible stack overflow with broken rtsp urls

---
 src/ietf/rtsp_session.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ietf/rtsp_session.c b/src/ietf/rtsp_session.c
index 987e5eb2c0..694828cd81 100644
--- a/src/ietf/rtsp_session.c
+++ b/src/ietf/rtsp_session.c
@@ -72,6 +72,7 @@ GF_Err RTSP_UnpackURL(char *sURL, char Server[1024], u16 *Port, char Service[102
 	//extract the schema
 	i = 0;
 	while (i<=strlen(sURL)) {
+		if (i==10) return GF_BAD_PARAM;
 		if (sURL[i] == ':') goto found;
 		schema[i] = sURL[i];
 		i += 1;
