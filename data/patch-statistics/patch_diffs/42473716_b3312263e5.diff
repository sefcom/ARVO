Date: Sun, 24 Feb 2019 11:55:33 +0100
Subject: [PATCH] Fix overflow introduced in
 ce0d453222ca51c056f4f442988710eb0b696365

---
 lib/puny_decode.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/lib/puny_decode.c b/lib/puny_decode.c
index 13a5fe6..0d5f3f2 100644
--- a/lib/puny_decode.c
+++ b/lib/puny_decode.c
@@ -161,7 +161,9 @@ int punycode_decode(
     if (!basic(input[j])) return punycode_bad_input;
     output[out++] = input[j];
   }
-  b += delim(input[b]);
+
+  if (input_length)
+    b += delim(input[b]);
 
   for (j = b;  j < input_length;  ++j)
     if (!basic(input[j])) return punycode_bad_input;
