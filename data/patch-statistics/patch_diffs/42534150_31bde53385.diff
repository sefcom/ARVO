From 4b40a3bc2a069854c0633896c8960b2d097b3eb0 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Sun, 31 Mar 2024 19:47:51 +0200
Subject: [PATCH] Patches due to changes in the ImageMagick-Windows repository.

---
 .github/workflows/daily.yml | 6 +++---
 .github/workflows/main.yml  | 4 ++--
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/.github/workflows/daily.yml b/.github/workflows/daily.yml
index 35562442be8..0da40c2e19b 100644
--- a/.github/workflows/daily.yml
+++ b/.github/workflows/daily.yml
@@ -151,7 +151,7 @@ jobs:
       run: |
         for /f "tokens=* USEBACKQ" %%F IN (`git -C ImageMagick rev-parse HEAD`) do set COMMIT_SHA=%%F
         cd ImageMagick-Windows
-        CloneRepositories.cmd %COMMIT_SHA%
+        CloneRepositories.IM7.cmd %COMMIT_SHA%
 
     - name: Download ChangeLog.md
       uses: actions/download-artifact@v4
@@ -206,7 +206,7 @@ jobs:
       run: |
         for /f "tokens=* USEBACKQ" %%F IN (`git -C ImageMagick rev-parse HEAD`) do set COMMIT_SHA=%%F
         cd ImageMagick-Windows
-        CloneRepositories.cmd %COMMIT_SHA%
+        CloneRepositories.IM7.cmd %COMMIT_SHA%
 
     - name: Build configure
       shell: cmd
@@ -259,7 +259,7 @@ jobs:
         update: true
 
     - name: Building ImageMagick
-      run: cd ImageMagick-Windows && makepkg-mingw --noconfirm --syncdeps
+      run: cd ImageMagick-Windows\Build\MSYS2 && makepkg-mingw --noconfirm --syncdeps
       env:
         MINGW_ARCH: ${{ matrix.msystem }}
         PKGEXT: ".pkg.tar.xz"
diff --git a/.github/workflows/main.yml b/.github/workflows/main.yml
index 284e4a8d238..71ff76a07dd 100644
--- a/.github/workflows/main.yml
+++ b/.github/workflows/main.yml
@@ -136,7 +136,7 @@ jobs:
       run: |
         for /f "tokens=* USEBACKQ" %%F IN (`git -C ImageMagick rev-parse HEAD`) do set COMMIT_SHA=%%F
         cd ImageMagick-Windows
-        CloneRepositories.cmd %COMMIT_SHA%
+        CloneRepositories.IM7.cmd %COMMIT_SHA%
 
     - name: Build configure
       shell: cmd
@@ -180,7 +180,7 @@ jobs:
         update: true
 
     - name: Building ImageMagick
-      run: cd ImageMagick-Windows && makepkg-mingw --noconfirm --syncdeps
+      run: cd ImageMagick-Windows\Build\MSYS2 && makepkg-mingw --noconfirm --syncdeps
       env:
         MINGW_ARCH: mingw64
         PKGEXT: ".pkg.tar.xz"
