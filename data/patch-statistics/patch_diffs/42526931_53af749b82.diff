From 5f77d022733a5b7e2ff1e3d80b547c0d89811efe Mon Sep 17 00:00:00 2001
From: Philip Hazel <Philip.Hazel@gmail.com>
Date: Tue, 8 Aug 2023 15:15:24 +0100
Subject: [PATCH] Fix regression buffer overflow introduced in recent new code
 - fixes ClusterFuzz 61268

---
 src/pcre2_match.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/pcre2_match.c b/src/pcre2_match.c
index 537e5f3d2..ad4a43c0e 100644
--- a/src/pcre2_match.c
+++ b/src/pcre2_match.c
@@ -5792,7 +5792,7 @@ fprintf(stderr, "++ op=%d\n", *Fecode);
       if (Lmax-- <= Lmin) RRETURN(MATCH_NOMATCH);
       Feptr++;
 #ifdef SUPPORT_UNICODE
-      if (utf) { FORWARDCHAR(Feptr); }
+      if (utf) { FORWARDCHARTEST(Feptr, mb->end_subject); }
 #endif
       }
     /* Control never reaches here */
