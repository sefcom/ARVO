From: Cristy <urban-warrior@imagemagick.org>
Date: Sun, 4 Feb 2018 15:02:15 -0500
Subject: [PATCH] https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=5365

---
 MagickCore/property.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/MagickCore/property.c b/MagickCore/property.c
index 685eabe87c2..b06d80be240 100644
--- a/MagickCore/property.c
+++ b/MagickCore/property.c
@@ -1742,6 +1742,8 @@ static MagickBooleanType GetXMPProperty(const Image *image,const char *property)
   profile=GetImageProfile(image,"xmp");
   if (profile == (StringInfo *) NULL)
     return(MagickFalse);
+  if (GetStringInfoLength(profile) < 17)
+    return(MagickFalse);
   if ((property == (const char *) NULL) || (*property == '\0'))
     return(MagickFalse);
   xmp_profile=StringInfoToString(profile);
