Subject: [PATCH] fuzz: initialize text, splt structs

---
 tests/spng_read_fuzzer.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/tests/spng_read_fuzzer.c b/tests/spng_read_fuzzer.c
index 9a06abe8..f66c7a8c 100644
--- a/tests/spng_read_fuzzer.c
+++ b/tests/spng_read_fuzzer.c
@@ -54,11 +54,11 @@ int LLVMFuzzerTestOneInput(const uint8_t* data, size_t size)
     struct spng_iccp iccp;
     struct spng_sbit sbit;
     uint8_t srgb_rendering_intent;
-    struct spng_text text[4];
+    struct spng_text text[4] = {0};
     struct spng_bkgd bkgd;
     struct spng_hist hist;
     struct spng_phys phys;
-    struct spng_splt splt[4];
