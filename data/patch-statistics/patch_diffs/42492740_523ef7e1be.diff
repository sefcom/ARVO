From 0886abbb8596c875ccf25981e4cde3a4dd902365 Mon Sep 17 00:00:00 2001
From: "Diego F. Aranha" <dfaranha@gmail.com>
Date: Sun, 7 Feb 2021 13:19:06 +0100
Subject: [PATCH] Fix invalid write.

---
 src/bn/relic_bn_mul.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/bn/relic_bn_mul.c b/src/bn/relic_bn_mul.c
index f8902cf8b..ac92a52a4 100644
--- a/src/bn/relic_bn_mul.c
+++ b/src/bn/relic_bn_mul.c
@@ -64,8 +64,8 @@ static void bn_mul_karat_imp(bn_t c, const bn_t a, const bn_t b, int level) {
 	RLC_TRY {
 		/* Allocate the temp variables. */
 		bn_new_size(a0, h);
-		bn_new_size(a1, h);
-		bn_new_size(b0, a->used - h);
+		bn_new_size(b0, h);
+		bn_new_size(a1, a->used - h);
 		bn_new_size(b1, b->used - h);
 		bn_new(a0b0);
 		bn_new(a1b1);
