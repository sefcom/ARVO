From 81c4a0f08c48c17988aad2441cc14c26f8c3ea8e Mon Sep 17 00:00:00 2001
From: Ivan Nardi <nardi.ivan@gmail.com>
Date: Thu, 7 Aug 2025 20:08:08 +0200
Subject: [PATCH] Fix another heap-buffer-overflow

---
 src/lib/ndpi_utils.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/lib/ndpi_utils.c b/src/lib/ndpi_utils.c
index 039a1259967..1b51589c8c4 100644
--- a/src/lib/ndpi_utils.c
+++ b/src/lib/ndpi_utils.c
@@ -3237,7 +3237,7 @@ bool ndpi_is_valid_hostname(char * const hostname, size_t len) {
   size_t label_len = 0, idx = 0;
   bool has_valid_label = false;
 
-  if(!hostname || *hostname == '\0')
+  if(!hostname || len == 0 || *hostname == '\0')
     return(false); /* Empty string or NULL pointer */
 
   if(len > 253) /* Maximum length of a full hostname */
