From 69f7141f5d47eae33ecdd8e88ca0b50e25ce883a Mon Sep 17 00:00:00 2001
From: tbeu <tbeu@users.noreply.github.com>
Date: Thu, 29 Aug 2019 20:20:42 +0200
Subject: [PATCH] Fix uninitialized variable

As reported by https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=16834
---
 src/mat4.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/mat4.c b/src/mat4.c
index a786c217..601a3d6b 100644
--- a/src/mat4.c
+++ b/src/mat4.c
@@ -865,7 +865,7 @@ Mat_VarReadNextInfo4(mat_t *mat)
     }
 
     matvar->rank = 2;
-    matvar->dims = (size_t*)malloc(2*sizeof(*matvar->dims));
+    matvar->dims = (size_t*)calloc(2, sizeof(*matvar->dims));
     if ( NULL == matvar->dims ) {
         Mat_VarFree(matvar);
         return NULL;
