From e1a691ca498dd4aa4808b94edfb9b3448ca7ed51 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Fri, 3 Aug 2018 12:28:23 +0800
Subject: [PATCH] jbig2dec: Initialize entire page structure upon allocation.

Without this uninitialized values in the page structure will be
used when parsing segments. An example of this is in
jbig2_immediate_generic_region() when a the height of the page is
used to determine if the region is outside of the page.
---
 jbig2.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/jbig2.c b/jbig2.c
index 38d10bb..ab507a7 100644
--- a/jbig2.c
+++ b/jbig2.c
@@ -150,6 +150,14 @@ jbig2_ctx_new(Jbig2Allocator *allocator, Jbig2Options options, Jbig2GlobalCtx *g
         for (index = 0; index < result->max_page_index; index++) {
             result->pages[index].state = JBIG2_PAGE_FREE;
             result->pages[index].number = 0;
+            result->pages[index].width = 0;
+            result->pages[index].height = 0xffffffff;
+            result->pages[index].x_resolution = 0;
+            result->pages[index].y_resolution = 0;
+            result->pages[index].stripe_size = 0;
+            result->pages[index].striped = 0;
+            result->pages[index].end_row = 0;
+            result->pages[index].flags = 0;
             result->pages[index].image = NULL;
         }
     }
