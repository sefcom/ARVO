From 7f9016032a29873a9c30c6d6548cda13e67fd335 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Sun, 1 Jan 2023 18:27:06 +0100
Subject: [PATCH] decode_r11: fix ossfuzz 47189

entities_end overflow
---
 src/decode.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/decode.c b/src/decode.c
index 8679cbf690..1877ea86b5 100644
--- a/src/decode.c
+++ b/src/decode.c
@@ -5858,6 +5858,11 @@ decode_preR13_entities (BITCODE_RL start, BITCODE_RL end,
              blocks_max != (BITCODE_RL)0 ? "block " : "", start, end, num_entities,
              size, blocks_max);
   LOG_INFO ("==========================================\n");
+  if (size > dat->size || end > dat->size)
+    {
+      LOG_ERROR ("size overflow")
+      return DWG_ERR_INVALIDDWG;
+    }
   if (end != 0 && start == end)
     // with empty entities, ignore num_entities as they include block ents
     return 0;
