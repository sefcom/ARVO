From 6ecb04980813d693234190021bd1cf874c05b1b4 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Mon, 15 Jul 2024 14:48:34 +0200
Subject: [PATCH] jbig2dec: Avoid releasing symbol bitmap image twice upon
 error.

This fixes OSS-fuzz issue 57266.
---
 jbig2_text.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/jbig2_text.c b/jbig2_text.c
index 9505517..c5ac72c 100644
--- a/jbig2_text.c
+++ b/jbig2_text.c
@@ -404,7 +404,6 @@ cleanup1:
                 }
 
                 if (code1 < 0 || code2 < 0 || code3 < 0 || code4 < 0 || code5 < 0 || code6 < 0) {
-                    jbig2_image_release(ctx, IB);
                     code = jbig2_error(ctx, JBIG2_SEVERITY_WARNING, segment->number, "failed to decode data");
                     goto cleanup2;
                 }
