From 8bde21c2f062b4f9a865263eb3256949ec3d75a3 Mon Sep 17 00:00:00 2001
From: tbeu <tbeu@users.noreply.github.com>
Date: Wed, 11 Sep 2019 20:53:47 +0200
Subject: [PATCH] Avoid uninitialized memory

As reported by https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=17108
---
 src/mat5.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/mat5.c b/src/mat5.c
index 82508e7f..d6094316 100644
--- a/src/mat5.c
+++ b/src/mat5.c
@@ -3020,7 +3020,7 @@ Mat_VarRead5(mat_t *mat, matvar_t *matvar)
             mat_sparse_t *sparse;
 
             matvar->data_size = sizeof(mat_sparse_t);
-            matvar->data      = malloc(matvar->data_size);
+            matvar->data      = calloc(1, matvar->data_size);
             if ( matvar->data == NULL ) {
                 Mat_Critical("Mat_VarRead5: Allocation of data pointer failed");
                 err = 1;
