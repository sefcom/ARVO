From 25f4212f48563db7e37c606f04826ffd32b8b198 Mon Sep 17 00:00:00 2001
From: Michael Tuexen <tuexen@fh-muenster.de>
Date: Wed, 8 Jul 2020 14:29:17 +0200
Subject: [PATCH] Improve handling of PKTDROP chunks. This includes the input
 validation to address two issues found by ossfuzz testing the userland stack:
 * https://oss-fuzz.com/testcase-detail/5387560242380800 *
 https://oss-fuzz.com/testcase-detail/4887954068865024 and adding support for
 I-DATA chunks in addition to DATA chunks.

---
 usrsctplib/netinet/sctp_input.c | 199 +++++++++++++++++---------------
 1 file changed, 106 insertions(+), 93 deletions(-)

diff --git a/usrsctplib/netinet/sctp_input.c b/usrsctplib/netinet/sctp_input.c
index f082ff731..f97ac7812 100755
--- a/usrsctplib/netinet/sctp_input.c
+++ b/usrsctplib/netinet/sctp_input.c
@@ -34,7 +34,7 @@
 
 #if defined(__FreeBSD__) && !defined(__Userspace__)
 #include <sys/cdefs.h>
-__FBSDID("$FreeBSD: head/sys/netinet/sctp_input.c 362722 2020-06-28 14:11:36Z tuexen $");
+__FBSDID("$FreeBSD: head/sys/netinet/sctp_input.c 363008 2020-07-08 12:25:19Z tuexen $");
 #endif
 
 #include <netinet/sctp_os.h>
