From 1d77acc7e284a4f99d64468ca292e9fc0e7aa6fe Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Mon, 29 Jul 2024 12:51:09 +0200
Subject: [PATCH] dmx_gsf add size overflow check

ossfuzz issue 70703
---
 src/filters/dmx_gsf.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/filters/dmx_gsf.c b/src/filters/dmx_gsf.c
index 6549d09e14..850d16cbb0 100644
--- a/src/filters/dmx_gsf.c
+++ b/src/filters/dmx_gsf.c
@@ -1249,7 +1249,7 @@ static GF_Err gsfdmx_demux(GF_Filter *filter, GSF_DemuxCtx *ctx, char *data, u32
 					}
 
 					if (append) {
-						if (block_offset + pck_len > gpck->full_block_size) {
+						if ( (block_offset >= GF_UINT_MAX - pck_len) || (block_offset + pck_len > gpck->full_block_size) ) {
 							GF_LOG(GF_LOG_ERROR, GF_LOG_CONTAINER, ("[GSFDemux] packet fragment out of bounds of current frame (offset %d size %d max size %d)\n", block_offset,  pck_len, gpck->full_block_size));
 							e = GF_NON_COMPLIANT_BITSTREAM;
 						} else {
