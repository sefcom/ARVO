From ef9a61bbb0063f23bc9628a329571297ec8953fa Mon Sep 17 00:00:00 2001
From: James Bonfield <jkb@sanger.ac.uk>
Date: Fri, 22 Jan 2021 12:51:20 +0000
Subject: [PATCH] Fix OSS fuzz 1-byte buffer read-overrun.

Credit to OSS-Fuzz
Fixes oss-fuzz 29795
---
 htscodecs/rANS_static4x16pr.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/htscodecs/rANS_static4x16pr.c b/htscodecs/rANS_static4x16pr.c
index 41582e9..9c3e925 100644
--- a/htscodecs/rANS_static4x16pr.c
+++ b/htscodecs/rANS_static4x16pr.c
@@ -1544,6 +1544,8 @@ unsigned char *rans_uncompress_to_4x16(unsigned char *in,  unsigned int in_size,
 
 	// Decode lengths
 	c_meta_len += var_get_u32(in+c_meta_len, in_end, &ulen);
+	if (c_meta_len >= in_size)
+	    return NULL;
 	unsigned int N = in[c_meta_len++];
 	unsigned int clenN[256], ulenN[256], idxN[256];
 	if (!out) {
