diff --git a/Packet++/src/IPLayer.cpp b/Packet++/src/IPLayer.cpp
new file mode 100644
index 0000000000..fc2d40d3e9
--- /dev/null
+++ b/Packet++/src/IPLayer.cpp
@@ -0,0 +1,26 @@
+#include "IPLayer.h"
+
+namespace pcpp
+{
+	ProtocolType IPLayer::getIPVersion(uint8_t const* data, size_t dataLen)
+	{
+		// The data requires at least 1 byte of valid buffer
+		if (data == nullptr || dataLen < 1)
+		{
+			return UnknownProtocol;
+		}
+
+		// The first 4 bits of the first byte of the IP header represent the IP version
+		uint8_t version = data[0] >> 4;
+
+		switch (version)
+		{
+		case 4:
+			return IPv4;
+		case 6:
+			return IPv6;
+		default:
+			return UnknownProtocol;
+		}
+	}
+}  // namespace pcpp
