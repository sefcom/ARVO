Date: Wed, 24 Apr 2019 09:40:20 +0200
Subject: [PATCH] Fix heap buffer overflow introduced in previous commit

* libwget/iri.c (_iri_unescape_inline): Add missing 'continue'

Found by OSS-FUZZ (Issue 14428)
---
 libwget/iri.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/libwget/iri.c b/libwget/iri.c
index 6d50f3e8f..46e4f1903 100644
--- a/libwget/iri.c
+++ b/libwget/iri.c
@@ -254,6 +254,7 @@ static char *_iri_unescape_inline(char *src, int ctype)
 				*d++ = '\'';
 				s += 6;
 				ret = src;
+				continue;
 			}
 		} else if (*s == '#') {
 			uint32_t value = 0;
