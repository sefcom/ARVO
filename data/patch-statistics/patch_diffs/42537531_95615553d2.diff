From ab10c15fc73e8d79aea1599a61f491b5a1ddee63 Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Tue, 30 Jul 2024 17:57:44 +0200
Subject: [PATCH] utils: Account for libxml2 change

---
 libxslt/xsltutils.c | 2 --
 1 file changed, 2 deletions(-)

diff --git a/libxslt/xsltutils.c b/libxslt/xsltutils.c
index d493905b..0e9dc62f 100644
--- a/libxslt/xsltutils.c
+++ b/libxslt/xsltutils.c
@@ -1884,8 +1884,6 @@ xsltSaveResultToString(xmlChar **doc_txt_ptr, int * doc_txt_len,
             (xmlStrcasecmp(encoding, BAD_CAST "UTF8") != 0))
 	    encoder = xmlFindCharEncodingHandler((char *) encoding);
 	buf = xmlAllocOutputBuffer(encoder);
-        if (buf == NULL)
-            xmlCharEncCloseFunc(encoder);
     } else {
 	buf = xmlAllocOutputBuffer(NULL);
     }
