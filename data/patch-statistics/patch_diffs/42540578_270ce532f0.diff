ReadPNGImage(): Detect EOF when reading magic_number. (Credit to OSS-Fuzz)

diff --git a/ChangeLog b/ChangeLog
--- a/ChangeLog
+++ b/ChangeLog
@@ -1,3 +1,10 @@
+2018-06-17  Bob Friesenhahn  <bfriesen@simple.dallas.tx.us>
+
+	* coders/png.c (ReadPNGImage): Detect EOF when reading
+	magic_number.  Fixes oss-fuzz 8944
+	"graphicsmagick/coder_PNG_fuzzer: Use-of-uninitialized-value in
+	ReadPNGImage".  (Credit to OSS-Fuzz)
+
 2018-06-16  Bob Friesenhahn  <bfriesen@simple.dallas.tx.us>
 
 	* coders/tiff.c (ReadTIFFImage): Re-structure exception reporting
diff --git a/VisualMagick/installer/inc/version.isx b/VisualMagick/installer/inc/version.isx
--- a/VisualMagick/installer/inc/version.isx
+++ b/VisualMagick/installer/inc/version.isx
@@ -10,5 +10,5 @@
 
 #define public MagickPackageName "GraphicsMagick"
 #define public MagickPackageVersion "1.4"
-#define public MagickPackageVersionAddendum ".020180616"
-#define public MagickPackageReleaseDate "snapshot-20180616"
+#define public MagickPackageVersionAddendum ".020180617"
+#define public MagickPackageReleaseDate "snapshot-20180617"
diff --git a/coders/png.c b/coders/png.c
--- a/coders/png.c
+++ b/coders/png.c
@@ -2918,8 +2918,8 @@
   /*
     Verify PNG signature.
   */
-  (void) ReadBlob(image,8,magic_number);
-  if (memcmp(magic_number,"\211PNG\r\n\032\n",8) != 0)
+  if ((ReadBlob(image,8,magic_number) != 8) ||
+      (memcmp(magic_number,"\211PNG\r\n\032\n",8) != 0))
   {
     ThrowReaderException(CorruptImageError,ImproperImageHeader,image);
   }
diff --git a/magick/version.h b/magick/version.h
--- a/magick/version.h
+++ b/magick/version.h
@@ -38,8 +38,8 @@
 #define MagickLibVersion  0x211800
 #define MagickLibVersionText  "1.4"
 #define MagickLibVersionNumber 21,18,0
-#define MagickChangeDate   "20180616"
-#define MagickReleaseDate  "snapshot-20180616"
+#define MagickChangeDate   "20180617"
+#define MagickReleaseDate  "snapshot-20180617"
 	
 /*
   The MagickLibInterfaceNewest and MagickLibInterfaceOldest defines
