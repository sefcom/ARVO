From 352a9ab54ef228553d793c148c717d9f0beac864 Mon Sep 17 00:00:00 2001
From: Cristy <urban-warrior@imagemagick.org>
Date: Sat, 19 Feb 2022 10:25:25 -0500
Subject: [PATCH] off-by-one fix

---
 MagickCore/draw.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/MagickCore/draw.c b/MagickCore/draw.c
index 4cd641c4409..0408c517aeb 100644
--- a/MagickCore/draw.c
+++ b/MagickCore/draw.c
@@ -4888,7 +4888,7 @@ static double GetFillAlpha(PolygonInfo *polygon_info,const double mid,
         continue;
       }
     i=(ssize_t) MagickMax((double) p->highwater,1.0);
-    for ( ; i < (ssize_t) p->number_points; i++)
+    for ( ; i < (ssize_t) (p->number_points-1); i++)
       if ((double) y <= p->points[i].y)
         break;
     q=p->points+i-1;
