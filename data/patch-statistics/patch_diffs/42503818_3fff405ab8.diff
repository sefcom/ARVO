Subject: [PATCH] Corrected setting delay instead.

---
 MagickCore/constitute.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/MagickCore/constitute.c b/MagickCore/constitute.c
index 4ca29e1227a..1c2893b049f 100644
--- a/MagickCore/constitute.c
+++ b/MagickCore/constitute.c
@@ -838,8 +838,7 @@ MagickExport Image *ReadImage(const ImageInfo *image_info,
           if ((flags & LessValue) != 0)
             {
               if (next->delay < (size_t) floor(geometry_info.rho+0.5))
-                next->ticks_per_second=CastDoubleToLong(floor(
-                  geometry_info.sigma+0.5));
+                next->delay=(size_t) floor(geometry_info.rho+0.5);
             }
           else
             next->delay=(size_t) floor(geometry_info.rho+0.5);
