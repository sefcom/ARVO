From c01f316370fb1425338a643caf4c1c8d3d652bc2 Mon Sep 17 00:00:00 2001
From: Dirk Farin <dirk.farin@gmail.com>
Date: Wed, 21 Aug 2024 18:44:36 +0200
Subject: [PATCH] fix compiler warnings

---
 libheif/api/libheif/heif.cc | 4 +++-
 libheif/codecs/tild.h       | 2 +-
 libheif/file.h              | 1 +
 3 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/libheif/api/libheif/heif.cc b/libheif/api/libheif/heif.cc
index 939ee50197..96fd1ff746 100644
--- a/libheif/api/libheif/heif.cc
+++ b/libheif/api/libheif/heif.cc
@@ -1619,7 +1619,9 @@ int heif_image_list_channels(struct heif_image* image,
     *p++ = c;
   }
 
-  return channels.size();
+  assert(channels.size() < std::numeric_limits<int>::max());
+
+  return static_cast<int>(channels.size());
 }
 
 
diff --git a/libheif/codecs/tild.h b/libheif/codecs/tild.h
index f2bc58f3d2..2966caa522 100644
--- a/libheif/codecs/tild.h
+++ b/libheif/codecs/tild.h
@@ -79,7 +79,7 @@ class TildHeader
   // TODO uint64_t m_start_of_offset_table_in_file = 0;
   std::vector<TileOffset> m_offsets;
 
-  size_t m_offset_table_start = 0; // start of offset table (= number of bytes in header)
+  // TODO size_t m_offset_table_start = 0; // start of offset table (= number of bytes in header)
   size_t m_header_size = 0; // including offset table
 };
 
diff --git a/libheif/file.h b/libheif/file.h
index a7a4125f0e..97120f6e41 100644
--- a/libheif/file.h
+++ b/libheif/file.h
@@ -35,6 +35,7 @@
 #include <map>
 #include <vector>
 #include <unordered_set>
+#include <limits>
 
 #if ENABLE_PARALLEL_TILE_DECODING
 
