From 14ecc478ad48b4df8b0892a7f25cae90a714f059 Mon Sep 17 00:00:00 2001
From: jeanlf <jeanlf@gpac.io>
Date: Wed, 17 Jan 2024 14:24:22 +0100
Subject: [PATCH] fixed index out of band in hevc ref pics with broken streams

---
 src/media_tools/av_parsers.c | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/media_tools/av_parsers.c b/src/media_tools/av_parsers.c
index 811f1cbfc9..b8bf16390b 100644
--- a/src/media_tools/av_parsers.c
+++ b/src/media_tools/av_parsers.c
@@ -7089,10 +7089,11 @@ static Bool hevc_parse_short_term_ref_pic_set(GF_BitStream *bs, HEVC_SPS *sps, u
 			}
 			if ((ref_idc == 1) || (ref_idc == 2)) {
 				s32 deltaPOC = deltaRPS;
-				if (i < nb_ref_pics)
+				if ((i < nb_ref_pics) && (i<16))
 					deltaPOC += ref_ps->delta_poc[i];
 
-				rps->delta_poc[k] = deltaPOC;
+				if (k<16)
+					rps->delta_poc[k] = deltaPOC;
 
 				if (deltaPOC < 0)  k0++;
 				else k1++;
