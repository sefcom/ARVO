Subject: [PATCH] Update minimum cratios, as these seem machine-dependent

---
 tests/test_dict_schunk.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/tests/test_dict_schunk.c b/tests/test_dict_schunk.c
index 91e0f6e33..ec982ff17 100644
--- a/tests/test_dict_schunk.c
+++ b/tests/test_dict_schunk.c
@@ -122,11 +122,11 @@ static char* test_dict(void) {
         break;
       case 256 * KB:
         mu_assert("ERROR: Dict does not reach expected compression ratio",
-                  200 * cbytes < nbytes);
+                  180 * cbytes < nbytes);
         break;
       default:
         mu_assert("ERROR: Dict does not reach expected compression ratio",
-                  200 * cbytes < nbytes);
+                  180 * cbytes < nbytes);
     }
   }
 
