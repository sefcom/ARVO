From 28a4b16ec292d181b7227040dd47925e3b0949d9 Mon Sep 17 00:00:00 2001
From: Chris Liddell <chris.liddell@artifex.com>
Date: Tue, 25 Oct 2022 14:41:24 +0100
Subject: oss-fuzz 52691: Bounds check op stack for "index" op code

in the Type 2 charstring interpreter.
---
 base/gstype2.c | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/base/gstype2.c b/base/gstype2.c
index 428317909..211ba10e6 100644
--- a/base/gstype2.c
+++ b/base/gstype2.c
@@ -797,10 +797,11 @@ gs_type2_interpret(gs_type1_state * pcis, const gs_glyph_data_t *pgd,
                         }
                         break;
                     case ce2_index:
-                        if (!CS_CHECK_CSTACK_BOUNDS(&csp[-1], cstack))
+                        if (!CS_CHECK_CSTACK_BOUNDS(&csp[-1], cstack) ||
+                            !CS_CHECK_CSTACK_BOUNDS(&csp[0], cstack) ||
+                            !CS_CHECK_CSTACK_BOUNDS(&csp[-1 - fixed2int_var(csp[-1])], cstack))
                             return_error(gs_error_invalidfont);
-                        *csp =
-                            (*csp < 0 ? csp[-1] : csp[-1 - fixed2int_var(csp[-1])]);
+                        *csp = (*csp < 0 ? csp[-1] : csp[-1 - fixed2int_var(csp[-1])]);
                         break;
                     case ce2_roll:
                         if (!CS_CHECK_CSTACK_BOUNDS(&csp[-1], cstack))
