 wolfcrypt/test/test.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/wolfcrypt/test/test.c b/wolfcrypt/test/test.c
index 829e260d088..b51b1ad93ae 100644
--- a/wolfcrypt/test/test.c
+++ b/wolfcrypt/test/test.c
