From 75f9c33cef261046f75c6fe3a02f9912e55211ee Mon Sep 17 00:00:00 2001
From: Frederik Deweerdt <fdeweerdt@fastly.com>
Date: Fri, 12 Apr 2019 10:30:49 -0700
Subject: [PATCH] Check that there was no previous decode error

---
 lib/minicrypto-pem.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/lib/minicrypto-pem.c b/lib/minicrypto-pem.c
index f40d2255a..8e068d3f4 100644
--- a/lib/minicrypto-pem.c
+++ b/lib/minicrypto-pem.c
@@ -106,7 +106,7 @@ size_t ptls_minicrypto_asn1_decode_private_key(ptls_asn1_pkcs8_private_key_t *pk
         }
     }
 
-    if (last_byte1 < byte_index) {
+    if (*decode_error == 0 && last_byte1 < byte_index) {
         byte_index = ptls_asn1_error_message("Length larger than message", bytes_max, byte_index, 0, log_ctx);
         *decode_error = PTLS_ERROR_BER_EXCESSIVE_LENGTH;
     }
