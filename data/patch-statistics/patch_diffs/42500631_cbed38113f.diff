From ac8fdfa944724cf5565b33d3f876d5ebdefded71 Mon Sep 17 00:00:00 2001
From: Cristy <mikayla-grace@urban-warrior.org>
Date: Tue, 24 Aug 2021 19:28:44 -0400
Subject: [PATCH] ./configure --help no longer lists -disable-assert twice

---
 ChangeLog    |  6 ++++++
 configure    | 20 ++------------------
 configure.ac | 11 -----------
 3 files changed, 8 insertions(+), 29 deletions(-)

diff --git a/ChangeLog b/ChangeLog
index e7aeb99bf8f..d6a89165f8d 100644
--- a/ChangeLog
+++ b/ChangeLog
@@ -1,3 +1,9 @@
+2021-08-21  7.1.0-6  <quetzlzacatenango@image...>
+  * Release ImageMagick version 7.1.0-6 GIT revision 18...
+
+2021-08-21  7.1.0-6  <quetzlzacatenango@image...>
+  * 
+
 2021-08-21  7.1.0-5  <quetzlzacatenango@image...>
   * Release ImageMagick version 7.1.0-5 GIT revision 18995:8f77c3c9c:20210821 
 
diff --git a/configure b/configure
index 59e76652ca1..340bcb8907f 100755
--- a/configure
+++ b/configure
@@ -1176,7 +1176,6 @@ enable_cipher
 enable_zero_configuration
 enable_hdri
 enable_pipes
-enable_assert
 enable_maintainer_mode
 enable_hugepages
 enable_ccmalloc
@@ -1198,6 +1197,7 @@ with_jemalloc
 with_tcmalloc
 with_umem
 with_libstdc
+enable_assert
 with_bzlib
 with_x
 with_zip
@@ -1972,7 +1972,6 @@ Optional Features:
   --enable-hdri           accurately represent the wide range of intensity
                           levels found in real scenes
   --enable-pipes          enable pipes (|) in filenames
-  --disable-assert        disable assert() statements in build
   --enable-maintainer-mode
                           enable make rules and dependencies not useful (and
                           sometimes confusing) to the casual installer
@@ -4564,7 +4563,7 @@ MAGICK_PATCHLEVEL_VERSION=6
 
 MAGICK_VERSION=7.1.0-6
 
-MAGICK_GIT_REVISION=19000:74f815413:20210822
+MAGICK_GIT_REVISION=19001:2d444c93b:20210824
 
 
 # Substitute library versioning
@@ -22048,21 +22047,6 @@ $as_echo "#define PIPES_SUPPORT 1" >>confdefs.h
     MAGICK_FEATURES="Pipes $MAGICK_FEATURES"
 fi
 
-# Build a version of ImageMagick with assert statements.
-# Check whether --enable-assert was given.
-if test "${enable_assert+set}" = set; then :
-  enableval=$enable_assert; enable_assert=$enableval
-else
-  enable_assert='yes'
-fi
-
-
-if test "$enable_assert" = 'no'; then
-
-$as_echo "#define NDEBUG 1" >>confdefs.h
-
-fi
-
 # Don't emit "rebuild rules" for configure, Makefile.ins, etc.
 
 { $as_echo "$as_me:${as_lineno-$LINENO}: checking whether to enable maintainer-specific portions of Makefiles" >&5
diff --git a/configure.ac b/configure.ac
index edcda4fb727..d9b94fc4b76 100644
--- a/configure.ac
+++ b/configure.ac
@@ -690,17 +690,6 @@ if test "$enable_pipes" = 'yes'; then
     MAGICK_FEATURES="Pipes $MAGICK_FEATURES"
 fi
 
-# Build a version of ImageMagick with assert statements.
-AC_ARG_ENABLE([assert],
-    [AC_HELP_STRING([--disable-assert],
-                    [disable assert() statements in build])],
-    [enable_assert=$enableval],
-    [enable_assert='yes'])
-
-if test "$enable_assert" = 'no'; then
-    AC_DEFINE([NDEBUG],[1],[Turn off assert statements])
-fi
-
 # Don't emit "rebuild rules" for configure, Makefile.ins, etc.
 AM_MAINTAINER_MODE
 
