
# HG changeset patch
# User Dmitry Volyntsev <xeioex@nginx.com>
# Date 1751586813 25200
# Node ID a4061187dd872064aa28dac506e877df90bd128b
# Parent  579688a17e3754a0f000b83611e99371896bfc02
Fixed RegExp compilation after 17124c81.

Previously, heap-buffer-overflow happened due to incorrect copying of
[...] regexp parts.

Found by OSS-Fuzz.

diff -r 579688a17e37 -r a4061187dd87 external/njs_regex.c
--- a/external/njs_regex.c	Fri Jun 27 09:45:48 2025 -0700
+++ b/external/njs_regex.c	Thu Jul 03 16:53:33 2025 -0700
@@ -177,11 +177,16 @@
                 continue;
 
             } else {
-                *dst++ = *p;
+                *dst++ = *p++; /* Copy '['. */
+
                 while (p < end && *p != ']') {
                     *dst++ = *p++;
                 }
 
+                if (p < end) {
+                    *dst++ = *p; /* Copy ']'. */
+                }
+
                 continue;
             }
         }
@@ -189,6 +194,8 @@
         *dst++ = *p;
     }
 
+    njs_assert(dst == text->start + text->length);
+
     return NJS_OK;
 
 #else
