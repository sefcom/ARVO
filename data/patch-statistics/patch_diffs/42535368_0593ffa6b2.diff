From 360f7fa620d2e1dcb1900d8245effede11bf79a9 Mon Sep 17 00:00:00 2001
From: Denis Ovsienko <denis@ovsienko.info>
Date: Tue, 7 Jan 2025 19:28:18 +0000
Subject: [PATCH] Initialize the scratch memory store to 0.

Originally raised by Michal Ruprich on tcpdump-workers, later reported
by Richard Lloyd of Connect Internet Solutions as a warning from HP ANSI
C compiler:

"./bpf_filter.c", line 220: warning #2549-D: variable "mem" is used
  before its value is set
  			A = mem[pc->k];
---
 CHANGES      | 1 +
 bpf_filter.c | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/CHANGES b/CHANGES
index 8eed16d154..b86fb4f4e1 100644
--- a/CHANGES
+++ b/CHANGES
@@ -44,6 +44,7 @@ DayOfTheWeek, Month DD, YYYY / The Tcpdump Group
       Eliminate trailing space in bpf_image() result.
       Fix DECnet packet filtering on big-endian hosts.
       Require "vpi" and "vci" values to be within valid ranges.
+      Initialize the scratch memory store to 0.
     rpcap:
       Support user names and passwords in rpcap:// and rpcaps:// URLs.
       Add a -t flag to rpcapd to specify the data channel port; from
diff --git a/bpf_filter.c b/bpf_filter.c
index 9b899bbb36..1a8ae8c843 100644
--- a/bpf_filter.c
+++ b/bpf_filter.c
@@ -94,7 +94,6 @@ pcapint_filter_with_aux_data(const struct bpf_insn *pc, const u_char *p,
 {
 	register uint32_t A, X;
 	register bpf_u_int32 k;
-	uint32_t mem[BPF_MEMWORDS];
 
 	if (pc == 0)
 		/*
@@ -103,6 +102,7 @@ pcapint_filter_with_aux_data(const struct bpf_insn *pc, const u_char *p,
 		return (u_int)-1;
 	A = 0;
 	X = 0;
+	uint32_t mem[BPF_MEMWORDS] = {0};
 	--pc;
 	for (;;) {
 		++pc;
