From a0b34a732d7822734a4aa034306a0fd2d2a659e8 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Tue, 30 May 2017 11:11:04 +0000
Subject: [PATCH] ILI1: fix heap-buffer-overflow on corrupted files. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=1926. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@38686 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/ogr/ogrsf_frmts/ili/ili1reader.cpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gdal/ogr/ogrsf_frmts/ili/ili1reader.cpp b/gdal/ogr/ogrsf_frmts/ili/ili1reader.cpp
index 25ad54f88b0b..99ca95e60a75 100644
--- a/gdal/ogr/ogrsf_frmts/ili/ili1reader.cpp
+++ b/gdal/ogr/ogrsf_frmts/ili/ili1reader.cpp
@@ -694,7 +694,8 @@ char ** ILI1Reader::ReadParseLine()
           break;
       }
       char **conttok = CSLTokenizeString2( pszLine, " ", CSLT_PRESERVEESCAPES );
-      if (!conttok || conttok[0] == NULL || !EQUAL(conttok[0], "CONT"))
+      if (!conttok || conttok[0] == NULL || !EQUAL(conttok[0], "CONT") ||
+          conttok[1] == NULL)
       {
           CSLDestroy(conttok);
           break;
