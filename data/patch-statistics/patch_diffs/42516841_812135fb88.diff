From 2dfbdcbceb6c17abb6a0b5ac5ba86e955db6f2f8 Mon Sep 17 00:00:00 2001
From: Daiki AMINAKA <1991.daiki@gmail.com>
Date: Tue, 11 Oct 2022 05:17:14 -0700
Subject: [PATCH] Fix passing pointer-pointer, skip inevitable SEGV case
 (#3122)

* Fix passing pointer-pointer, skip inevitable SEGV case

* Update src/fuzzing/fuzz.cc

Co-authored-by: Nick Banks <nibanks@microsoft.com>

* Fix spaces

Co-authored-by: Nick Banks <nibanks@microsoft.com>
---
 src/fuzzing/fuzz.cc | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/src/fuzzing/fuzz.cc b/src/fuzzing/fuzz.cc
index 656d9540d0..cfdf5407e8 100644
--- a/src/fuzzing/fuzz.cc
+++ b/src/fuzzing/fuzz.cc
@@ -9,6 +9,7 @@
 
 --*/
 
+#define QUIC_API_ENABLE_PREVIEW_FEATURES 1
 #define CX_PLATFORM_LINUX 1
 #define QUIC_TEST_APIS 1
 
@@ -19,7 +20,6 @@
 #include "msquic.hpp"
 #include "quic_platform.h"
 
-
 extern "C" int LLVMFuzzerTestOneInput(const uint8_t *data, size_t size)
 {
 	const MsQuicApi* MsQuic = new(std::nothrow) MsQuicApi();
@@ -27,11 +27,13 @@ extern "C" int LLVMFuzzerTestOneInput(const uint8_t *data, size_t size)
 	for (uint32_t Param = QUIC_PARAM_GLOBAL_RETRY_MEMORY_PERCENT;
 		Param <= QUIC_PARAM_GLOBAL_TLS_PROVIDER;
 		Param++) {
-		MsQuic->SetParam(
-			nullptr,
-			Param,
-			size,
-			&data);
+        if (Param != QUIC_PARAM_GLOBAL_VERSION_SETTINGS) {
+            MsQuic->SetParam(
+                nullptr,
+                Param,
+                size,
+                data);
+        }
 	}
 
 	delete MsQuic;
