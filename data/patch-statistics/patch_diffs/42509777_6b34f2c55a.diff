From d3ccd9060bf52848970d331c4025f64fe93a3490 Mon Sep 17 00:00:00 2001
From: Luca Versari <veluca@google.com>
Date: Mon, 21 Mar 2022 15:14:43 +0100
Subject: [PATCH] Do not assume that the RP has as many channels as the image.

In particular, noise will cause 3 additional channels to be present in
the RP.
---
 lib/jxl/render_pipeline/stage_blending.cc | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/lib/jxl/render_pipeline/stage_blending.cc b/lib/jxl/render_pipeline/stage_blending.cc
index d2d583be0fa..b1e569dabd0 100644
--- a/lib/jxl/render_pipeline/stage_blending.cc
+++ b/lib/jxl/render_pipeline/stage_blending.cc
@@ -126,7 +126,8 @@ class BlendingStage : public RenderPipelineStage {
     }
     std::vector<const float*> bg_row_ptrs_(input_rows.size());
     std::vector<float*> fg_row_ptrs_(input_rows.size());
-    for (size_t c = 0; c < input_rows.size(); ++c) {
+    size_t num_c = std::min(input_rows.size(), extra_channel_info_->size() + 3);
+    for (size_t c = 0; c < num_c; ++c) {
       fg_row_ptrs_[c] = GetInputRow(input_rows, c, 0) + offset;
       if (c < 3) {
         bg_row_ptrs_[c] =
