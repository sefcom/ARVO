From 3fe14382ac0cb578b7b5a978942b64dab97e2346 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Fri, 6 Jul 2018 15:06:26 +0200
Subject: [PATCH] RLE::decompress(): avoid index out-of-bound error on
 corrupted file. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=9282. Credit to OSS
 Fuzz

---
 gdal/third_party/LercLib/RLE.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/gdal/third_party/LercLib/RLE.cpp b/gdal/third_party/LercLib/RLE.cpp
index 57d71522d5d5..09eb8a274b0f 100644
--- a/gdal/third_party/LercLib/RLE.cpp
+++ b/gdal/third_party/LercLib/RLE.cpp
@@ -307,8 +307,8 @@ bool RLE::decompress(const Byte* arrRLE, size_t nBytesRemaining, Byte* arr, size
   short cnt = readCount(&srcPtr);
   while (cnt != -32768)
   {
-    size_t i = cnt < 0 ? -cnt : cnt;
-    size_t m = cnt < 0 ? 1 : i;
+    size_t i = cnt <= 0 ? -cnt : cnt;
+    size_t m = cnt <= 0 ? 1 : i;
 
     if (nBytesRemaining < m + 2 || arrIdx + i > arrSize)
       return false;
