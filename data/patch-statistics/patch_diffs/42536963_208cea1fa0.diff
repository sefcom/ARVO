From aa6aec19b094bb26e75c6582de2d429a8e134688 Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Thu, 11 Jul 2024 12:37:25 +0200
Subject: [PATCH] parser: Fix xmlInputSetEncodingHandler again

Short-lived regression.
---
 parserInternals.c | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/parserInternals.c b/parserInternals.c
index 6d962c6f9..b8388abfa 100644
--- a/parserInternals.c
+++ b/parserInternals.c
@@ -1299,6 +1299,7 @@ xmlInputSetEncodingHandler(xmlParserInputPtr input,
     xmlParserInputBufferPtr in;
     xmlBufPtr buf;
     int nbchars;
+    int code = XML_ERR_OK;
 
     if ((input == NULL) || (input->buf == NULL)) {
         xmlCharEncCloseFunc(handler);
@@ -1348,7 +1349,7 @@ xmlInputSetEncodingHandler(xmlParserInputPtr input,
     /*
      * Is there already some content down the pipe to convert ?
      */
-    if (input->end > input->cur) {
+    if (input->end > input->base) {
         size_t processed;
 
         /*
@@ -1361,12 +1362,13 @@ xmlInputSetEncodingHandler(xmlParserInputPtr input,
         in->rawconsumed = processed;
 
         nbchars = xmlCharEncInput(in);
-        xmlBufResetInput(in->buffer, input);
         if (nbchars < 0)
-            return(in->error);
+            code = in->error;
     }
 
-    return(XML_ERR_OK);
+    xmlBufResetInput(in->buffer, input);
+
+    return(code);
 }
 
