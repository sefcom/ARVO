From 4391214fa1168f8f7b12a1eca115d76fa07466c3 Mon Sep 17 00:00:00 2001
From: Eduardo Silva <eduardo@treasure-data.com>
Date: Mon, 11 May 2020 15:38:09 -0600
Subject: [PATCH] filter: pass null terminated tag to filter callback (#1343)

Signed-off-by: Eduardo Silva <eduardo@treasure-data.com>
---
 src/flb_filter.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/src/flb_filter.c b/src/flb_filter.c
index 0e3cf95de32..750a152f456 100644
--- a/src/flb_filter.c
+++ b/src/flb_filter.c
@@ -86,7 +86,6 @@ void flb_filter_do(struct flb_input_chunk *ic,
     memcpy(ntag, tag, tag_len);
     ntag[tag_len] = '\0';
 
-
     work_data = (const char *) data;
     work_size = bytes;
 
@@ -118,7 +117,7 @@ void flb_filter_do(struct flb_input_chunk *ic,
             /* Invoke the filter callback */
             ret = f_ins->p->cb_filter(work_data,      /* msgpack buffer   */
                                       work_size,      /* msgpack size     */
-                                      tag, tag_len,   /* input tag        */
+                                      ntag, tag_len,  /* input tag        */
                                       &out_buf,       /* new data         */
                                       &out_size,      /* new data size    */
                                       f_ins,          /* filter instance  */
