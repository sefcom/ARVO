From 7b5cf98a62896386ba7a473f18ca0e0c94902236 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Sat, 4 May 2024 18:58:59 +0200
Subject: [PATCH] Removed call to DestroyStringInfo that should not be done
 when using SetImageProfilePrivate.

---
 coders/meta.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/coders/meta.c b/coders/meta.c
index 7b00176bc3e..214d72484a5 100644
--- a/coders/meta.c
+++ b/coders/meta.c
@@ -1381,7 +1381,6 @@ static Image *ReadMETAImage(const ImageInfo *image_info,
       profile=BlobToProfileStringInfo("xmp",GetBlobStreamData(buff),(size_t)
         GetBlobSize(buff),exception);
       (void) SetImageProfilePrivate(image,profile,exception);
-      profile=DestroyStringInfo(profile);
       blob=(unsigned char *) DetachBlob(buff->blob);
       blob=(unsigned char *) RelinquishMagickMemory(blob);
       buff=DestroyImage(buff);
