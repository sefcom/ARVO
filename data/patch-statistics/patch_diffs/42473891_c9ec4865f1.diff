From 1175a0de53d9a22112b2cf119f653861a660f236 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@spatialys.com>
Date: Sun, 10 Mar 2019 15:09:44 +0100
Subject: [PATCH] DXF: fix double-free issue in case of writing error. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=13516. Credit to OSS
 Fuzz

---
 gdal/ogr/ogrsf_frmts/dxf/ogrdxfwriterds.cpp | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/gdal/ogr/ogrsf_frmts/dxf/ogrdxfwriterds.cpp b/gdal/ogr/ogrsf_frmts/dxf/ogrdxfwriterds.cpp
index 20a51898c521..396947dd29c3 100644
--- a/gdal/ogr/ogrsf_frmts/dxf/ogrdxfwriterds.cpp
+++ b/gdal/ogr/ogrsf_frmts/dxf/ogrdxfwriterds.cpp
@@ -583,18 +583,19 @@ bool OGRDXFWriterDS::TransferUpdateTrailer( VSILFILE *fpOut )
 /* -------------------------------------------------------------------- */
 /*      Copy the remainder of the file.                                 */
 /* -------------------------------------------------------------------- */
+    bool ret = true;
     while( (nCode = oReader.ReadValue( szLineBuf, sizeof(szLineBuf) )) != -1 )
     {
         if( !WriteValue( fpOut, nCode, szLineBuf ) )
         {
-            VSIFCloseL( fp );
-            return false;
+            ret = false;
+            break;
         }
     }
 
     VSIFCloseL( l_fp );
 
-    return true;
+    return ret;
 }
 
