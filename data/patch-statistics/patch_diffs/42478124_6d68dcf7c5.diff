From d255262c794a56d6f1c6dfca3e3025e7865c22f3 Mon Sep 17 00:00:00 2001
From: tbeu <tbeu@users.noreply.github.com>
Date: Tue, 26 Nov 2019 21:58:15 +0100
Subject: [PATCH] Avoid uninitialized memory

As reported by https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=18974
---
 src/mat5.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/mat5.c b/src/mat5.c
index 05c42487..41907c15 100644
--- a/src/mat5.c
+++ b/src/mat5.c
@@ -1474,7 +1474,7 @@ ReadNextStructField( mat_t *mat, matvar_t *matvar )
         Mat_Critical("Not compiled with zlib support");
 #endif
     } else {
-        mat_uint32_t buf[6];
+        mat_uint32_t buf[6] = {0,};
         mat_uint32_t array_flags, len;
 
         bytesread+=fread(buf,4,2,(FILE*)mat->fp);
