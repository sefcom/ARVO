From 74bfcfea5faa35ee3c5e7e2690b2473e0c4aac59 Mon Sep 17 00:00:00 2001
From: Ken Sharp <Ken.Sharp@artifex.com>
Date: Tue, 31 Oct 2023 12:12:58 +0000
Subject: pdfwrite device - prevent buffer underrun with corrupt TT font

OSS-fuzz #63648

A corrupted TrueType font could execute a jump instruction where the
distance to jump moved the instruction pointer back before the start
of the glyph program.

Detect that here, and if it happens move the instruction pointer to the
end of the glyph program so we terminate processing it. We can't return
an error at this level.
---
 base/ttinterp.c | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/base/ttinterp.c b/base/ttinterp.c
index e0248e1d0..6dba3b67e 100644
--- a/base/ttinterp.c
+++ b/base/ttinterp.c
@@ -1783,6 +1783,12 @@ static int nInstrCount=0;
       CUR.IP      += (Int)(args[0]);
       CUR.step_ins = FALSE;
 
+      /* If the instruction pointer moves back past the start of the description
+       * assume there is a fatal error, and move to the end of the description instead.
+       */
+      if(CUR.IP < 0)
+          CUR.IP = CUR.codeSize;
+
       /* See JMPR below */
       if(CUR.IP > CUR.codeSize ||
          (CUR.code[CUR.IP] != 0x2D && CUR.code[CUR.IP - 1] == 0x2D))
@@ -1805,6 +1811,12 @@ static int nInstrCount=0;
     CUR.IP      += (Int)(args[0]);
     CUR.step_ins = FALSE;
 
+    /* If the instruction pointer moves back past the start of the description
+     * assume there is a fatal error, and move to the end of the description instead.
+     */
+    if(CUR.IP < 0)
+        CUR.IP = CUR.codeSize;
+
     if(CUR.IP > CUR.codeSize ||
        (CUR.code[CUR.IP] != 0x2D && CUR.code[CUR.IP - 1] == 0x2D))
     /* The JPMR is meant to stop at the ENDF instruction to finish
@@ -1834,6 +1846,12 @@ static int nInstrCount=0;
       CUR.IP      += (Int)(args[0]);
       CUR.step_ins = FALSE;
 
+      /* If the instruction pointer moves back past the start of the description
+       * assume there is a fatal error, and move to the end of the description instead.
+       */
+      if(CUR.IP < 0)
+          CUR.IP = CUR.codeSize;
+
       /* See JMPR above */
       if(CUR.code[CUR.IP] != 0x2D && CUR.code[CUR.IP - 1] == 0x2D)
         CUR.IP -= 1;
