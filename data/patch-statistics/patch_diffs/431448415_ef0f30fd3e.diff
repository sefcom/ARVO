-        }
-
-        // Push the sample and activate the timestamp
-        if (ThreadSampler_Push(*d3d_tree, name_hash, 0, &sample) == RMT_ERROR_NONE)
-        {
-            D3D11Sample* d3d_sample = (D3D11Sample*)sample;
