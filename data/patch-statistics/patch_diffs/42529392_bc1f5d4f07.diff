From 5b4c2fce7262b2bec00fa679e472559ab268d0c7 Mon Sep 17 00:00:00 2001
From: Reini Urban <rurban@cpan.org>
Date: Mon, 30 Oct 2023 14:07:39 +0100
Subject: [PATCH] decode_r11: fix heap-overflow by 1

Fixes ossfuzz 63483
---
 src/decode.c     | 1 +
 src/decode_r11.c | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/decode.c b/src/decode.c
index 6d58f1f73a..a843214f4e 100644
--- a/src/decode.c
+++ b/src/decode.c
@@ -5658,6 +5658,7 @@ dwg_decode_unknown_rest (Bit_Chain *restrict dat, Dwg_Object *restrict obj)
   if (!obj->unknown_rest)
     {
       bit_set_position (dat, pos);
+      obj->num_unknown_rest = 0;
       return DWG_ERR_VALUEOUTOFBOUNDS;
     }
   // [num_bits (commonsize, hdlpos, strsize) num_bytes TF]
diff --git a/src/decode_r11.c b/src/decode_r11.c
index b62b3f95db..409cac04eb 100644
--- a/src/decode_r11.c
+++ b/src/decode_r11.c
@@ -377,7 +377,7 @@ decode_preR13_section (Dwg_Section_Type_r11 id, Bit_Chain *restrict dat,
         {                                                                     \
           BITCODE_RL offset = (BITCODE_RL)(pos - dat->byte);                  \
           obj->num_unknown_rest = 8 * offset;                                 \
-          obj->unknown_rest = (BITCODE_TF)calloc (offset, 1);                 \
+          obj->unknown_rest = (BITCODE_TF)calloc (offset + 1, 1);             \
           if (obj->unknown_rest)                                              \
             {                                                                 \
               memcpy (obj->unknown_rest, &dat->chain[dat->byte], offset);     \
