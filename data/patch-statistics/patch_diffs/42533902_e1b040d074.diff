From 09139341f38a1551d163d012a09bee35e5c8c8f9 Mon Sep 17 00:00:00 2001
From: Philip Hazel <Philip.Hazel@gmail.com>
Date: Thu, 21 Mar 2024 17:25:07 +0000
Subject: [PATCH] Fix yet another fuzz support oversight; add a test for a
 recent JIT fix

---
 src/pcre2_fuzzsupport.c | 4 +++-
 testdata/testinput2     | 5 +++++
 testdata/testoutput2    | 6 ++++++
 3 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/src/pcre2_fuzzsupport.c b/src/pcre2_fuzzsupport.c
index 2fa36afc8..8fba81502 100644
--- a/src/pcre2_fuzzsupport.c
+++ b/src/pcre2_fuzzsupport.c
@@ -335,7 +335,9 @@ if (size > 3)
         {
         if (wdata[j] == ' ' || wdata[j] == '\t')
           {
-          do j++; while (j < size && (wdata[j] == ' ' || wdata[j] == '\t'));
+          j++;
+          while (j < size && (wdata[j] == ' ' || wdata[j] == '\t')) j++;
+          if (j >= size) goto OUTERLOOP;
           if (wdata[j] != '}' && wdata[j] != ',') goto OUTERLOOP;
           }
         if (wdata[j] == '}' || (ii == 0 && wdata[j] == ',')) break;
diff --git a/testdata/testinput2 b/testdata/testinput2
index d63b74c43..412d58b4c 100644
--- a/testdata/testinput2
+++ b/testdata/testinput2
@@ -6102,5 +6102,10 @@ a)"xI
 /(((?<=123?456456|ABC)))(?<=\2)../
     ABCDEFG
     12345645678910 
+    
+# This test is crashing Perl 5.38.2.
+
+/[^\S\W]{6}/
+    .abc def..
 
 # End of testinput2
diff --git a/testdata/testoutput2 b/testdata/testoutput2
index 0c7948251..0116727a1 100644
--- a/testdata/testoutput2
+++ b/testdata/testoutput2
@@ -18047,6 +18047,12 @@ Failed: error -47: match limit exceeded
  0: 78
  1: 
  2: 
+    
+# This test is crashing Perl 5.38.2.
+
+/[^\S\W]{6}/
+    .abc def..
+No match
 
 # End of testinput2
 Error -70: PCRE2_ERROR_BADDATA (unknown error number)
