n 0;</div><div class='ctx'> 		}</div><div class='del'>-</div><div class='del'>-		if (asn1_get_next(hdr.payload + hdr.length, len - hdr.length,</div><div class='del'>-				  &amp;hdr) &lt; 0 ||</div><div class='add'>+		if (asn1_get_next(pos, end_seq - pos, &amp;hdr) &lt; 0 ||</div><div class='ctx'> 		    hdr.class != ASN1_CLASS_UNIVERSAL) {</div><div class='ctx'> 			wpa_printf(MSG_DEBUG, "X509: Failed to parse "</div><div class='ctx'> 				   "BasicConstraints");</div></td></tr></table></div> <!-- class=content -->
