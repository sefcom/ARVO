-    -0.3046875, 0.1953125,  -0.4296875, 0.0703125,   //
-    -0.2734375, 0.2265625,  -0.3984375, 0.1015625,   //
-    0.4453125,  -0.0546875, 0.3203125,  -0.1796875,  //
-    0.4765625,  -0.0234375, 0.3515625,  -0.1484375,  //
-    -0.4453125, 0.0546875,  -0.3203125, 0.1796875,   //
