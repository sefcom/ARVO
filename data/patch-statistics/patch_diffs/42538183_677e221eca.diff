From fddc7650cac071a6986dcd12264a8beef31f82b2 Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Sun, 15 Sep 2024 04:00:52 +0900
Subject: [PATCH] numeric.c (int_ceil): should rename mrb_bint_add_d to
 mrb_bint_add_n

---
 src/numeric.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/numeric.c b/src/numeric.c
index a8979d2b6f..bfa8465f35 100644
--- a/src/numeric.c
+++ b/src/numeric.c
@@ -1481,7 +1481,7 @@ int_ceil(mrb_state *mrb, mrb_value x)
   if (mrb_nil_p(f)) return x;
 #ifdef MRB_USE_BIGINT
   if (mrb_bigint_p(x)) {
-    x = mrb_bint_add_d(mrb, x, f);
+    x = mrb_bint_add_n(mrb, x, f);
     return mrb_bint_sub(mrb, x, mrb_bint_mod(mrb, x, f));
   }
 #endif
