From c181a6c7dbbfe9464cc4c56b93faa07e32c08e08 Mon Sep 17 00:00:00 2001
From: Ram Mohan M <ram.mohan@ittiam.com>
Date: Tue, 1 Apr 2025 11:21:37 +0530
Subject: [PATCH] update dependency libjpeg-turbo version to 3.1.0

Test: Build
---
 CMakeLists.txt | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 396db555..195131ce 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -458,7 +458,7 @@ if(NOT JPEG_FOUND)
   set(JPEGTURBO_PREFIX_DIR ${CMAKE_CURRENT_BINARY_DIR}/${JPEGTURBO_TARGET_NAME})
   set(JPEGTURBO_SOURCE_DIR ${THIRD_PARTY_DIR}/${JPEGTURBO_TARGET_NAME})
   set(JPEGTURBO_BINARY_DIR ${JPEGTURBO_PREFIX_DIR}/src/${JPEGTURBO_TARGET_NAME}-build)
-  set(JPEG_INCLUDE_DIRS ${JPEGTURBO_SOURCE_DIR} ${JPEGTURBO_BINARY_DIR})
+  set(JPEG_INCLUDE_DIRS ${JPEGTURBO_SOURCE_DIR}/src ${JPEGTURBO_BINARY_DIR})
   if(MSVC)
     set(JPEG_LIB ${CMAKE_STATIC_LIBRARY_PREFIX}jpeg-static${CMAKE_STATIC_LIBRARY_SUFFIX})
   else()
@@ -473,7 +473,7 @@ if(NOT JPEG_FOUND)
   if(EMSCRIPTEN)
     ExternalProject_Add(${JPEGTURBO_TARGET_NAME}
         GIT_REPOSITORY https://github.com/libjpeg-turbo/libjpeg-turbo.git
-        GIT_TAG 3.0.1
+        GIT_TAG 3.1.0
         PREFIX ${JPEGTURBO_PREFIX_DIR}
         SOURCE_DIR ${JPEGTURBO_SOURCE_DIR}
         BINARY_DIR ${JPEGTURBO_BINARY_DIR}
@@ -486,7 +486,7 @@ if(NOT JPEG_FOUND)
   else()
     ExternalProject_Add(${JPEGTURBO_TARGET_NAME}
         GIT_REPOSITORY https://github.com/libjpeg-turbo/libjpeg-turbo.git
-        GIT_TAG 3.0.1
+        GIT_TAG 3.1.0
         PREFIX ${JPEGTURBO_PREFIX_DIR}
         SOURCE_DIR ${JPEGTURBO_SOURCE_DIR}
         BINARY_DIR ${JPEGTURBO_BINARY_DIR}
