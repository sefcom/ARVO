+#endif
+
 #include <string.h>
 
 #include "../../cs_priv.h"
diff --git a/arch/X86/X86IntelInstPrinter.c b/arch/X86/X86IntelInstPrinter.c
index c650b0a617..29a1f15cdf 100644
