From: vit9696 <4348897+vit9696@users.noreply.github.com>
Date: Fri, 15 Jun 2018 00:12:26 +0300
Subject: [PATCH] Add Availability.h include to fix macOS SDK instrinsics

---
 MCInst.c                       | 1 +
 SStream.c                      | 1 +
 arch/X86/X86ATTInstPrinter.c   | 1 +
 arch/X86/X86Disassembler.c     | 5 +++++
 arch/X86/X86IntelInstPrinter.c | 1 +
 arch/X86/X86Mapping.c          | 4 ++++
 cs.c                           | 1 +
 utils.c                        | 1 +
 8 files changed, 15 insertions(+)

diff --git a/MCInst.c b/MCInst.c
index 40d1aba0ac..1694e5de1f 100644
--- a/MCInst.c
+++ b/MCInst.c
@@ -2,6 +2,7 @@
 /* By Nguyen Anh Quynh <aquynh@gmail.com>, 2013-2015 */
 
 #if defined(CAPSTONE_HAS_OSXKERNEL)
+#include <Availability.h>
 #include <libkern/libkern.h>
 #else
 #include <stdio.h>
diff --git a/SStream.c b/SStream.c
index 71d65f2b12..90cef53ee9 100644
--- a/SStream.c
+++ b/SStream.c
@@ -3,6 +3,7 @@
 
