From 3341c1a171494071ce12c75fca9a85135a616b96 Mon Sep 17 00:00:00 2001
From: Connor Rigby <connorr@hey.com>
Date: Mon, 26 Jun 2023 10:14:58 -0600
Subject: [PATCH] use calloc for cs_insn instead of malloc (#1972)

Signed-off-by: Connor Rigby <connorr@hey.com>
---
 cs.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/cs.c b/cs.c
index 1b7ba05f01..6f37b26ba1 100644
--- a/cs.c
+++ b/cs.c
@@ -586,6 +586,7 @@ static void fill_insn(struct cs_struct *handle, cs_insn *insn, char *buffer, MCI
 
 #ifndef CAPSTONE_DIET
 	mnem = insn->mnemonic;
+	// memset(mnem, 0, CS_MNEMONIC_SIZE);
 	for (sp = buffer; *sp; sp++) {
 		if (*sp == ' '|| *sp == '\t')
 			break;
@@ -896,7 +897,7 @@ size_t CAPSTONE_API cs_disasm(csh ud, const uint8_t *buffer, size_t size, uint64
 	size_org = size;
 
 	total_size = sizeof(cs_insn) * cache_size;
-	total = cs_mem_malloc(total_size);
+	total = cs_mem_calloc(sizeof(cs_insn), cache_size);
 	if (total == NULL) {
 		// insufficient memory
 		handle->errnum = CS_ERR_MEM;
