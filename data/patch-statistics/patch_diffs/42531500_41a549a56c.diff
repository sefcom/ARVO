From c3ce6dd423aa459de3690016833ed740df54f989 Mon Sep 17 00:00:00 2001
From: jeanlf <jeanlf@gpac.io>
Date: Wed, 17 Jan 2024 14:50:14 +0100
Subject: [PATCH] fixed bug in vorbis header parsing

---
 src/media_tools/av_parsers.c | 6 +++++-
 src/media_tools/gpac_ogg.c   | 1 +
 2 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/src/media_tools/av_parsers.c b/src/media_tools/av_parsers.c
index b8bf16390b..49054a966a 100644
--- a/src/media_tools/av_parsers.c
+++ b/src/media_tools/av_parsers.c
@@ -9709,7 +9709,11 @@ Bool gf_vorbis_parse_header(GF_VorbisParser *vp, u8 *data, u32 data_len)
 			gf_free(class_dims);
 		}
 		else {
-			oggpack_read(&opb, 8 + 16 + 16 + 6 + 8);
+			oggpack_read(&opb, 8);
+			oggpack_read(&opb, 16);
+			oggpack_read(&opb, 16);
+			oggpack_read(&opb, 6);
+			oggpack_read(&opb, 8);
 			nb_books = oggpack_read(&opb, 4) + 1;
 			for (j = 0; j < nb_books; j++)
 				oggpack_read(&opb, 8);
diff --git a/src/media_tools/gpac_ogg.c b/src/media_tools/gpac_ogg.c
index fb8eae119b..1b5eea7c7e 100644
--- a/src/media_tools/gpac_ogg.c
+++ b/src/media_tools/gpac_ogg.c
@@ -363,6 +363,7 @@ void oggpackB_adv1(oggpack_buffer *b) {
 /* bits <= 32 */
 s32 oggpack_read(oggpack_buffer *b,s32 bits) {
 	u32 ret;
+	gf_assert(bits<33);
 	u32 m=mask[bits];
 
 	bits+=b->endbit;
