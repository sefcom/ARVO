From 7d6937cde95559e9362e8e3b31a4f61ef00f30e4 Mon Sep 17 00:00:00 2001
From: Even Rouault <even.rouault@mines-paris.org>
Date: Sat, 5 Aug 2017 21:46:49 +0000
Subject: [PATCH] SDTS: avoid read heap buffer overflow. Fixes
 https://bugs.chromium.org/p/oss-fuzz/issues/detail?id=2870. Credit to OSS
 Fuzz

git-svn-id: https://svn.osgeo.org/gdal/trunk@39760 f0d54148-0727-0410-94bb-9a71ac55c965
---
 gdal/frmts/sdts/sdtslib.cpp | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/gdal/frmts/sdts/sdtslib.cpp b/gdal/frmts/sdts/sdtslib.cpp
index 93cc63c19132..110b1d2840e7 100644
--- a/gdal/frmts/sdts/sdtslib.cpp
+++ b/gdal/frmts/sdts/sdtslib.cpp
@@ -71,6 +71,8 @@ void SDTSFeature::ApplyATID( DDFField * poField )
         {
             const char * pabyData
                 = poField->GetSubfieldData( poMODN, NULL, iRepeat );
+            if( strlen(pabyData) < 5 )
+                return;
 
             memcpy( poModId->szModule, pabyData, 4 );
             poModId->szModule[4] = '\0';
