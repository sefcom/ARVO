From ea841107d6aa00b71e512960c8cb38774f0a0fa5 Mon Sep 17 00:00:00 2001
From: Dirk Lemstra <dirk@lemstra.org>
Date: Mon, 6 May 2024 07:56:58 +0200
Subject: [PATCH] Set the parameters to NAN inside GetImageMean when
 GetImageStatistics returns null.

---
 MagickCore/statistic.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/MagickCore/statistic.c b/MagickCore/statistic.c
index 2d7ec67d3e3..ff893f03d6a 100644
--- a/MagickCore/statistic.c
+++ b/MagickCore/statistic.c
@@ -1352,7 +1352,11 @@ MagickExport MagickBooleanType GetImageMean(const Image *image,double *mean,
     (void) LogMagickEvent(TraceEvent,GetMagickModule(),"%s",image->filename);
   channel_statistics=GetImageStatistics(image,exception);
   if (channel_statistics == (ChannelStatistics *) NULL)
-    return(MagickFalse);
+    {
+      *mean=NAN;
+      *standard_deviation=NAN;
+      return(MagickFalse);
+    }
   *mean=channel_statistics[CompositePixelChannel].mean;
   *standard_deviation=
     channel_statistics[CompositePixelChannel].standard_deviation;
