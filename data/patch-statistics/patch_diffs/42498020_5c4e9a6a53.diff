 lib/jxl/epf.cc             | 64 +++++++++++++++++++++++++-------------
 lib/jxl/epf.h              | 22 +++++++++++--
 lib/jxl/filters.cc         | 37 +++++++++++++++-------
 lib/jxl/filters.h          | 56 ++++++++++++++++++++++++---------
 5 files changed, 132 insertions(+), 75 deletions(-)

