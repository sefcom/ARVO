@@ -937,9 +937,13 @@ extern void uITRON4_free(void *p) ;
         #endif
     #endif
 
+    #if (WINMSP3)
+        #define strtok_r strtok_s
+    #endif
+
     #define XMALLOC(s, h, type) ((void *)rtp_malloc((s), SSL_PRO_MALLOC))
     #define XFREE(p, h, type) (rtp_free(p))
-    #define XREALLOC(p, n, h, t) (rtp_realloc((p), (n)))
