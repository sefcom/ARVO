From cb190f0170a62999f53133d904f444557f44c394 Mon Sep 17 00:00:00 2001
From: pancake <pancake@nopcode.org>
Date: Tue, 26 Mar 2024 22:41:58 +0100
Subject: [PATCH] Add test for the fuzzed coff file ##crash

---
 libr/bin/format/coff/coff.c | 10 ++++++++++
 test/db/formats/coff        | 12 ++++++++++++
 2 files changed, 22 insertions(+)

diff --git a/libr/bin/format/coff/coff.c b/libr/bin/format/coff/coff.c
index 6e1fb42eac0b6..35a571f6a5357 100644
--- a/libr/bin/format/coff/coff.c
+++ b/libr/bin/format/coff/coff.c
@@ -382,6 +382,16 @@ static bool r_bin_coff_init_scn_hdr(RBinCoffObj *obj) {
 		f_nscns = obj->hdr.f_nscns;
 		f_magic = obj->hdr.f_magic;
 	}
+	if (ST32_MUL_OVFCHK (sizeof (struct coff_scn_hdr), f_nscns)) {
+	// if ((st32)f_nscns < 1 || f_nscns > UT16_MAX)
+		R_LOG_WARN ("Dimming f_nscns count because is poluted or too large");
+		f_nscns &= 0xff;
+		if (obj->type == COFF_TYPE_BIGOBJ) {
+			obj->bigobj_hdr.f_nscns = f_nscns;
+		} else {
+			obj->hdr.f_nscns = f_nscns;
+		}
+	}
 
 	if (f_magic == COFF_FILE_TI_COFF) {
 		offset += 2;
diff --git a/test/db/formats/coff b/test/db/formats/coff
index 77856994946ea..93325b3384ffd 100644
--- a/test/db/formats/coff
+++ b/test/db/formats/coff
@@ -1,3 +1,15 @@
+NAME=fuzzed coffy
+FILE=bins/coff/coffydis
+CMDS=<<EOF
+aa
+EOF
+EXPECT=<<EOF
+format   coff
+arm
+32
+EOF
+RUN
+
 NAME=arm coff
 FILE=bins/coff/arm.obj
 CMDS=<<EOF
