From 598745d7f7330c45df80a0bad7a8bae8d9e5cc32 Mon Sep 17 00:00:00 2001
From: DavidKorczynski <david@adalogics.com>
Date: Tue, 2 Mar 2021 16:38:20 +0000
Subject: [PATCH] gzip: fix size check leading to overflow. OSS-Fuzz
 6354610792693760 (#3138)

Signed-off-by: davkor <david@adalogics.com>
---
 src/flb_gzip.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/flb_gzip.c b/src/flb_gzip.c
index c3b1d33933f..012b7d3c743 100644
--- a/src/flb_gzip.c
+++ b/src/flb_gzip.c
@@ -275,6 +275,11 @@ int flb_gzip_uncompress(void *in_data, size_t in_len,
     }
     out_size = dlen;
 
+    /* Ensure size is above 0 */
+    if (((p + in_len) - start - 8) <= 0) {
+        return -1;
+    }
+
     /* Map zip content */
     zip_data = (uint8_t *) start;
     zip_len = (p + in_len) - start - 8;
