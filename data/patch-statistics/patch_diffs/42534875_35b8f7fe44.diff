From 9ae7a3634fe814bb86d600bfdec19e74f6cfd7ad Mon Sep 17 00:00:00 2001
From: "K.Kosako" <kkosako0@gmail.com>
Date: Fri, 3 May 2024 10:53:19 +0900
Subject: [PATCH] fix: oss-fuzz Issue 68418: Use-of-uninitialized-value

---
 src/regparse.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/regparse.c b/src/regparse.c
index 4f8128f6..3f764cb7 100644
--- a/src/regparse.c
+++ b/src/regparse.c
@@ -4835,6 +4835,7 @@ fetch_name_with_level(OnigCodePoint start_code, UChar** src, UChar* end,
 
   end_code = get_name_end_code_point(start_code);
 
+  *rlevel = 0;
   digit_count = 0;
   name_end = end;
   r = 0;
@@ -5918,6 +5919,7 @@ fetch_token(PToken* tok, UChar** src, UChar* end, ParseEnv* env)
         tok->u.backref.by_name = 0;
 #ifdef USE_BACKREF_WITH_LEVEL
         tok->u.backref.exist_level = 0;
+        tok->u.backref.level = 0;
 #endif
         break;
       }
