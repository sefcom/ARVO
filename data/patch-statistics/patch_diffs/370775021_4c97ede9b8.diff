From 7c69a37aa6f7d3ef2a39714ec7c1e4e0282d710e Mon Sep 17 00:00:00 2001
From: dearblue <dearblue@users.osdn.me>
Date: Mon, 23 Dec 2024 22:45:47 +0900
Subject: [PATCH] `FileTest` is a module

It has been incorrectly defined as a class.
---
 mrbgems/mruby-io/src/file_test.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mrbgems/mruby-io/src/file_test.c b/mrbgems/mruby-io/src/file_test.c
index 342c29a70e..72dcc254b0 100644
--- a/mrbgems/mruby-io/src/file_test.c
+++ b/mrbgems/mruby-io/src/file_test.c
@@ -338,7 +338,7 @@ mrb_init_file_test(mrb_state *mrb)
 {
   struct RClass *f;
 
-  f = mrb_define_class_id(mrb, MRB_SYM(FileTest), mrb->object_class);
+  f = mrb_define_module_id(mrb, MRB_SYM(FileTest));
 
   mrb_define_class_method_id(mrb, f, MRB_SYM_Q(directory), mrb_filetest_s_directory_p, MRB_ARGS_REQ(1));
   mrb_define_class_method_id(mrb, f, MRB_SYM_Q(exist),     mrb_filetest_s_exist_p,     MRB_ARGS_REQ(1));
