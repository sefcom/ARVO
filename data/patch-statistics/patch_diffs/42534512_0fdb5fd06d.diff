From a0341ac8e94d08a2a0204c2217a5cc95bd7b2a5f Mon Sep 17 00:00:00 2001
From: Nick Wellnhofer <wellnhofer@aevum.de>
Date: Thu, 18 Apr 2024 12:08:30 +0200
Subject: [PATCH] tree: Don't return empty localname in xmlSplitQName{2,3}

Match the behavior of xmlSplitQName and xmlSplitQName4.
---
 tree.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/tree.c b/tree.c
index 0e7293138..68973e136 100644
--- a/tree.c
+++ b/tree.c
@@ -226,7 +226,7 @@ xmlSplitQName2(const xmlChar *name, xmlChar **prefix) {
     while ((name[len] != 0) && (name[len] != ':'))
 	len++;
 
-    if (name[len] == 0)
+    if ((name[len] == 0) || (name[len+1] == 0))
 	return(NULL);
 
     *prefix = xmlStrndup(name, len);
@@ -274,7 +274,7 @@ xmlSplitQName3(const xmlChar *name, int *len) {
     while ((name[l] != 0) && (name[l] != ':'))
 	l++;
 
-    if (name[l] == 0)
+    if ((name[l] == 0) || (name[l+1] == 0))
 	return(NULL);
 
     *len = l;
-- 
