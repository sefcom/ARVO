From 2342de96b4968969e2f01f3970905963053b0504 Mon Sep 17 00:00:00 2001
From: Bart Van Assche <bvanassche@acm.org>
Date: Sun, 16 Feb 2025 08:45:02 -0800
Subject: [PATCH] libsnmp: Fix a stack buffer overflow in se_read_conf()

Fixes: https://issues.oss-fuzz.com/issues/396958482
---
 snmplib/snmp_enum.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/snmplib/snmp_enum.c b/snmplib/snmp_enum.c
index 8ef167ff8d..93fa1626bd 100644
--- a/snmplib/snmp_enum.c
+++ b/snmplib/snmp_enum.c
@@ -150,7 +150,7 @@ se_read_conf(const char *word, const char *cptr)
                 break;
             }
             cp2 = e_enum;
-            while (*(cp2++) != ':')
+            while (*cp2 && *(cp2++) != ':')
                 ;
             se_add_pair_to_slist(e_name, strdup(cp2), value);
             if (!cp)
