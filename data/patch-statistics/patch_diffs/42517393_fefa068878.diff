+            json_type_object )
     {
         json_object *poVal = json_object_new_double( dfValue );
         json_object_object_add( TO_JSONOBJ(object.GetInternalHandle()),
@@ -463,7 +469,9 @@ void CPLJSONObject::Add(const std::string &osName, int nValue)
