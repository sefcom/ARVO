     std::string objectName;
     CPLJSONObject object = GetObjectByPath( osName, objectName );
-    if( object.IsValid() )
+    if( object.IsValid() &&
+        json_object_get_type(TO_JSONOBJ(object.m_poJsonObject)) ==
